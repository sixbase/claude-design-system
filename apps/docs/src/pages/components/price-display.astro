---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { PriceDisplayDefault, PriceDisplayWithCompare, PriceDisplaySizes } from '../../components/PriceDisplayGallery';
---

<ComponentPage
  title="Price Display"
  description="Displays a product price with an optional compare-at / original price shown with a strikethrough. Used on product cards, PDPs, and cart line items."
  installCode="import { PriceDisplay } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>price</code>', '<code>string</code>', '—', 'Current / sale price (pre-formatted, e.g. "$48.00")'],
        ['<code>comparePrice</code>', '<code>string</code>', '—', 'Original price shown with strikethrough'],
        ['<code>size</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Size variant'],
      ],
    },
  ]}
  accessibility={[
    'Compare price includes a <code>&lt;span class="ds-sr-only"&gt;Original price:&lt;/span&gt;</code> for screen readers',
    'Strikethrough is visual only — screen readers get the semantic context from the hidden label',
  ]}
>
  <h2>Default</h2>
  <PriceDisplayDefault client:load />
  <pre><code>{`<PriceDisplay price="$48.00" />`}</code></pre>

  <h2>With compare price</h2>
  <p>Show the original price with a strikethrough when an item is on sale.</p>
  <PriceDisplayWithCompare client:load />
  <pre><code>{`<PriceDisplay price="$89.00" comparePrice="$112.00" />`}</code></pre>

  <h2>Sizes</h2>
  <PriceDisplaySizes client:load />
  <pre><code>{`<PriceDisplay price="$48.00" comparePrice="$65.00" size="sm" />
<PriceDisplay price="$48.00" comparePrice="$65.00" size="md" />
<PriceDisplay price="$48.00" comparePrice="$65.00" size="lg" />`}</code></pre>
</ComponentPage>
