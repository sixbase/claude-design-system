{{ 'newsletter.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.heading
  assign body = section.settings.body
  assign placeholder = section.settings.placeholder
  assign button_label = section.settings.button_label
-%}

<div class="ds-page-container ds-section">
  <section class="ds-newsletter">
    <div class="ds-newsletter__content">
      {%- if heading != blank -%}
        <h2 class="ds-heading ds-heading--xl">{{ heading | escape }}</h2>
      {%- endif -%}
      {%- if body != blank -%}
        <p class="ds-text ds-text--sm ds-text--muted">{{ body | escape }}</p>
      {%- endif -%}
    </div>

    {%- form 'customer', class: 'ds-newsletter__form', id: 'home-newsletter' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="hidden" name="contact[accepts_marketing]" value="true">

      <label for="home-newsletter-email" class="ds-sr-only">
        {{ placeholder | default: 'your@email.com' | escape }}
      </label>

      <div class="ds-input-root ds-newsletter__input-wrap">
        <input
          id="home-newsletter-email"
          type="email"
          name="contact[email]"
          class="ds-input-field ds-input-field--md"
          placeholder="{{ placeholder | default: 'your@email.com' | escape }}"
          autocomplete="email"
          required
          {% if form.errors %}aria-invalid="true" aria-describedby="home-newsletter-errors"{% endif %}
          value="{{ form.email }}"
        >
      </div>

      <button type="submit" class="ds-button ds-button--primary ds-button--md" name="commit">
        {{ button_label | default: 'Subscribe' | escape }}
      </button>

      {%- if form.posted_successfully? -%}
        <p class="ds-newsletter__success" role="status">Thanks for subscribing.</p>
      {%- endif -%}

      {%- if form.errors -%}
        <ul
          id="home-newsletter-errors"
          class="ds-newsletter__errors"
          role="alert"
        >
          {%- for field in form.errors -%}
            <li>
              {%- if field == 'form' -%}
                {{ form.errors.messages[field] }}
              {%- else -%}
                {{ form.errors.translated_fields[field] | capitalize }}
                {{ form.errors.messages[field] }}
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- endform -%}
  </section>
</div>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in the Loop" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "New drops, restocks, and stories — delivered to your inbox. No spam, ever." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "your@email.com" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
