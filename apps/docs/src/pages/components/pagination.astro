---
import ComponentPage from '../../layouts/ComponentPage.astro';
import {
  PaginationDefault,
  PaginationFewPages,
  PaginationManyPages,
  PaginationSizes,
  PaginationSSR,
  PaginationEdgeCases,
  PaginationWiderSiblings,
} from '../../components/PaginationGallery';
---

<ComponentPage
  title="Pagination"
  description="Navigation for multi-page content. SPA mode uses buttons with <code>onPageChange</code>. SSR/Shopify mode renders crawlable <code>&lt;a&gt;</code> tags with <code>baseUrl</code>. Automatically hides when there is only one page."
  installCode="import { Pagination } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>currentPage</code>', '<code>number</code>', '—', 'Current active page (1-indexed)'],
        ['<code>totalPages</code>', '<code>number</code>', '—', 'Total number of pages'],
        ['<code>onPageChange</code>', '<code>(page: number) =&gt; void</code>', '—', 'SPA mode — callback when page changes'],
        ['<code>baseUrl</code>', '<code>string</code>', '—', 'SSR mode — renders anchor tags with <code>?page=N</code>'],
        ['<code>siblingCount</code>', '<code>number</code>', '<code>1</code>', 'Pages shown around current page'],
        ['<code>size</code>', "<code>'sm' | 'md'</code>", "<code>'md'</code>", 'Size of pagination controls'],
      ],
    },
  ]}
  accessibility={[
    'Wrapping <code>&lt;nav&gt;</code> with <code>aria-label="Pagination"</code>',
    'Current page has <code>aria-current="page"</code> and is not clickable',
    'Previous/Next buttons have <code>aria-label="Go to previous/next page"</code>',
    'Previous disabled on first page, Next disabled on last page',
    'All page buttons have <code>aria-label="Go to page N"</code>',
    'Mobile layout shows "Page X of Y" text for context',
    'Ellipsis markers are <code>aria-hidden="true"</code>',
  ]}
>
  <h2>Default</h2>
  <p>Interactive pagination with truncation. Click through to see ellipsis behavior.</p>
  <PaginationDefault client:load />
  <pre><code>{`<Pagination
  currentPage={page}
  totalPages={20}
  onPageChange={setPage}
/>`}</code></pre>

  <h2>Few pages</h2>
  <p>7 or fewer pages show all numbers without ellipsis.</p>
  <PaginationFewPages client:load />
  <pre><code>{`<Pagination currentPage={1} totalPages={5} onPageChange={setPage} />`}</code></pre>

  <h2>Many pages</h2>
  <p>100+ pages with correct truncation.</p>
  <PaginationManyPages client:load />
  <pre><code>{`<Pagination currentPage={50} totalPages={100} onPageChange={setPage} />`}</code></pre>

  <h2>Sizes</h2>
  <PaginationSizes client:load />
  <pre><code>{`<Pagination size="sm" ... />
<Pagination size="md" ... />  {/* default */}`}</code></pre>

  <h2>SSR / Shopify mode</h2>
  <p>Pass <code>baseUrl</code> to render anchor tags instead of buttons. Page 1 links to the bare URL; subsequent pages append <code>?page=N</code>.</p>
  <PaginationSSR client:load />
  <pre><code>{`<Pagination
  currentPage={3}
  totalPages={10}
  baseUrl="/collections/all"
/>`}</code></pre>

  <h2>Edge cases</h2>
  <p>Disabled states on first/last page, and minimal two-page pagination.</p>
  <PaginationEdgeCases client:load />

  <h2>Wider sibling count</h2>
  <p>Increase <code>siblingCount</code> to show more pages around the current page.</p>
  <PaginationWiderSiblings client:load />
  <pre><code>{`<Pagination siblingCount={2} currentPage={10} totalPages={20} onPageChange={setPage} />`}</code></pre>
</ComponentPage>
