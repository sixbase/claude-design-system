{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'alert.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_text = section.settings.heading
  if heading_text == blank
    assign heading_text = 'Activate your account'
  endif
-%}

<section class="ds-page-container ds-section ds-customer ds-customer--narrow" aria-labelledby="CustomerActivateTitle">
  <div class="ds-customer__inner">
    <header class="ds-customer__header">
      <h1 id="CustomerActivateTitle" class="ds-heading ds-heading--2xl ds-customer__title">
        {{ heading_text }}
      </h1>
      <p class="ds-text ds-text--sm ds-customer__subtitle">
        Create a password to complete your account activation.
      </p>
    </header>

    {%- form 'activate_customer_password', class: 'ds-customer__form', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <div class="ds-customer__alerts">
          <div class="ds-alert ds-alert--destructive" role="alert">
            <div class="ds-alert__content">
              <p class="ds-text ds-text--sm ds-alert__title">
                We couldn't activate your account.
              </p>
              <ul class="ds-text ds-text--sm ds-alert__description">
                {%- for field in form.errors -%}
                  <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          </div>
        </div>
      {%- endif -%}

      <div class="ds-input-root">
        <label for="CustomerActivatePassword" class="ds-input-label ds-input-label--required">
          Password
        </label>
        <input
          type="password"
          name="customer[password]"
          id="CustomerActivatePassword"
          class="ds-input-field ds-input-field--md"
          autocomplete="new-password"
          minlength="5"
          required
        >
        <span class="ds-input-hint">
          At least 5 characters.
        </span>
      </div>

      <div class="ds-input-root">
        <label for="CustomerActivatePasswordConfirm" class="ds-input-label ds-input-label--required">
          Confirm password
        </label>
        <input
          type="password"
          name="customer[password_confirmation]"
          id="CustomerActivatePasswordConfirm"
          class="ds-input-field ds-input-field--md"
          autocomplete="new-password"
          minlength="5"
          required
        >
      </div>

      <div class="ds-customer__actions">
        <button type="submit" class="ds-button ds-button--primary ds-button--md ds-button--full-width">
          Activate account
        </button>
        <button type="submit" name="decline" class="ds-button ds-button--ghost ds-button--md ds-button--full-width">
          Decline invitation
        </button>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Activate account",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Activate your account"
    }
  ],
  "presets": [{ "name": "Activate account" }]
}
{% endschema %}
