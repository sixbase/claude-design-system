---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { StarRatingDefault, StarRatingSizes, StarRatingValues, StarRatingWithCount } from '../../components/StarRatingGallery';
---

<BaseLayout title="Star Rating">
  <div class="prose">
    <h1>Star Rating</h1>
    <p>
      Displays a visual rating using filled, half-filled, and empty stars.
      Supports an optional review count and three size variants.
    </p>

    <h2>Installation</h2>
    <pre><code>{`import { StarRating } from '@ds/components';`}</code></pre>

    <h2>Default</h2>
    <StarRatingDefault client:load />
    <pre><code>{`<StarRating rating={4.5} reviewCount={128} />`}</code></pre>

    <h2>Sizes</h2>
    <StarRatingSizes client:load />
    <pre><code>{`<StarRating rating={4} reviewCount={42} size="sm" />
<StarRating rating={4} reviewCount={42} size="md" />  {/* default */}
<StarRating rating={4} reviewCount={42} size="lg" />`}</code></pre>

    <h2>Rating values</h2>
    <p>Supports whole and half-star values from 0 to 5. Values are clamped to this range.</p>
    <StarRatingValues client:load />
    <pre><code>{`<StarRating rating={5} />
<StarRating rating={4.5} />
<StarRating rating={3} />
<StarRating rating={1.5} />
<StarRating rating={0} />`}</code></pre>

    <h2>With review count</h2>
    <p>The review count is optional. When provided, it renders next to the stars with automatic singular/plural handling.</p>
    <StarRatingWithCount client:load />
    <pre><code>{`<StarRating rating={4.5} reviewCount={1} />
<StarRating rating={4} reviewCount={128} />
<StarRating rating={3.5} reviewCount={2403} />`}</code></pre>

    <h2>Props</h2>
    <table class="props-table">
      <thead>
        <tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>rating</code></td><td><code>number</code></td><td>—</td><td>Rating value from 0 to 5. Supports halves (e.g. 4.5).</td></tr>
        <tr><td><code>reviewCount</code></td><td><code>number</code></td><td>—</td><td>Total number of reviews displayed next to stars</td></tr>
        <tr><td><code>size</code></td><td><code>'sm' | 'md' | 'lg'</code></td><td><code>'md'</code></td><td>Size variant — sm (14px), md (16px), lg (20px)</td></tr>
      </tbody>
    </table>

    <h2>Accessibility</h2>
    <ul>
      <li>Container has <code>role="img"</code> with <code>aria-label="4.5 out of 5 stars"</code></li>
      <li>Individual star SVGs are hidden from screen readers with <code>aria-hidden="true"</code></li>
      <li>Review count text is accessible to screen readers</li>
    </ul>
  </div>
</BaseLayout>

<style>
  .props-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
    margin: var(--spacing-4) 0;
    background-color: var(--color-background-surface);
    border: 1px solid var(--color-border);
  }
  .props-table th {
    text-align: left;
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 2px solid var(--color-border);
    font-weight: var(--font-weight-semibold);
    color: var(--color-foreground);
  }
  .props-table td {
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-foreground-subtle);
    vertical-align: top;
  }
</style>
