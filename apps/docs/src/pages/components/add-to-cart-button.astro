---
import ComponentPage from '../../layouts/ComponentPage.astro';
import {
  AddToCartButtonDefault,
  AddToCartButtonStatuses,
  AddToCartButtonSizes,
  AddToCartButtonFullWidth,
  AddToCartButtonCustomLabels,
  AddToCartButtonInteractive,
} from '../../components/AddToCartButtonGallery';
---

<ComponentPage
  title="Add to Cart Button"
  description="A specialized shopping CTA with domain-specific states: idle, loading, success feedback, sold out, and pre-order. Composes the base Button component with ecommerce-specific behavior."
  installCode="import { AddToCartButton } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>status</code>', "<code>'idle' | 'loading' | 'success' | 'sold-out' | 'pre-order'</code>", "<code>'idle'</code>", 'Current status of the add-to-cart action'],
        ['<code>size</code>', "<code>'md' | 'lg'</code>", "<code>'lg'</code>", 'Size of the button'],
        ['<code>fullWidth</code>', '<code>boolean</code>', '<code>false</code>', 'Stretch to fill parent container width'],
        ['<code>labels</code>', '<code>AddToCartButtonLabels</code>', '—', 'Override default labels for each status'],
        ['<code>onClick</code>', '<code>() =&gt; void</code>', '—', 'Click handler for idle and pre-order states'],
      ],
    },
    {
      name: 'AddToCartButtonLabels',
      headers: ['Key', 'Type', 'Default'],
      rows: [
        ['<code>idle</code>', '<code>string</code>', '<code>"Add to Bag"</code>'],
        ['<code>loading</code>', '<code>string</code>', '<code>"Adding\u2026"</code>'],
        ['<code>success</code>', '<code>string</code>', '<code>"Added!"</code>'],
        ['<code>soldOut</code>', '<code>string</code>', '<code>"Sold Out"</code>'],
        ['<code>preOrder</code>', '<code>string</code>', '<code>"Pre-Order"</code>'],
      ],
    },
  ]}
  accessibility={[
    '<code>aria-busy="true"</code> during loading state',
    '<code>aria-disabled="true"</code> for sold-out state (screen readers still announce the button)',
    'Status changes announced via <code>aria-live="polite"</code> region',
    'Full keyboard support inherited from Button component',
    'Respects <code>prefers-reduced-motion</code> for success transition',
  ]}
>
  <h2>Default</h2>
  <p>Renders in idle state with the default "Add to Bag" label.</p>
  <AddToCartButtonDefault client:load />
  <pre><code>{`<AddToCartButton />`}</code></pre>

  <h2>Statuses</h2>
  <p>Five domain-specific states driven by the <code>status</code> prop.</p>
  <AddToCartButtonStatuses client:load />
  <pre><code>{`<AddToCartButton status="idle" />
<AddToCartButton status="loading" />
<AddToCartButton status="success" />
<AddToCartButton status="sold-out" />
<AddToCartButton status="pre-order" />`}</code></pre>

  <h2>Sizes</h2>
  <p>Two sizes: <code>md</code> for compact layouts and <code>lg</code> (default) for product detail pages.</p>
  <AddToCartButtonSizes client:load />
  <pre><code>{`<AddToCartButton size="md" />
<AddToCartButton size="lg" />`}</code></pre>

  <h2>Full width</h2>
  <p>Stretch to fill the parent container.</p>
  <AddToCartButtonFullWidth client:load />
  <pre><code>{`<AddToCartButton fullWidth />`}</code></pre>

  <h2>Custom labels</h2>
  <p>Override default labels to match your store's voice.</p>
  <AddToCartButtonCustomLabels client:load />
  <pre><code>{`<AddToCartButton labels={{ idle: 'Add to Cart' }} />
<AddToCartButton status="sold-out" labels={{ soldOut: 'Notify Me' }} />
<AddToCartButton status="pre-order" labels={{ preOrder: 'Reserve Now' }} />`}</code></pre>

  <h2>Interactive demo</h2>
  <p>Click to see the full idle → loading → success → idle cycle.</p>
  <AddToCartButtonInteractive client:load />
  <pre><code>{`const [status, setStatus] = useState('idle');

const handleClick = () => {
  setStatus('loading');
  setTimeout(() => {
    setStatus('success');
    setTimeout(() => setStatus('idle'), 2000);
  }, 1500);
};

<AddToCartButton status={status} onClick={handleClick} fullWidth />`}</code></pre>
</ComponentPage>
