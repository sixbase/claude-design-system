---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { HeadingGallery, TextGallery, InlineGallery } from '../../components/TypographyGallery';
---

<ComponentPage
  title="Typography"
  description="Four building blocks for all text: <code>Heading</code>, <code>Text</code>, <code>Caption</code>, and <code>Code</code>. They all consume design tokens, so swapping a token updates every piece of text at once."
  installCode="import { Heading, Text, Caption, Code } from '@ds/components';"
  props={[
    {
      name: 'Heading',
      headers: ['Prop', 'Type', 'Default', 'What it does'],
      rows: [
        ['<code>as</code>', "<code>'h1' | 'h2' | 'h3' | 'h4'</code>", "<code>'h2'</code>", 'HTML element + visual size'],
        ['<code>muted</code>', '<code>boolean</code>', '<code>false</code>', 'Lighter color'],
        ['<code>truncate</code>', '<code>boolean</code>', '<code>false</code>', 'Cuts off with … if too long'],
      ],
    },
    {
      name: 'Text',
      headers: ['Prop', 'Type', 'Default', 'What it does'],
      rows: [
        ['<code>as</code>', "<code>'p' | 'span' | 'div' | 'label' | 'strong' | 'em'</code>", "<code>'p'</code>", 'HTML element to render'],
        ['<code>size</code>', "<code>'sm' | 'base' | 'lg'</code>", "<code>'base'</code>", 'Font size'],
        ['<code>weight</code>', "<code>'normal' | 'medium' | 'semibold' | 'bold'</code>", '—', 'Font weight'],
        ['<code>muted</code>', '<code>boolean</code>', '<code>false</code>', 'Lighter color'],
        ['<code>truncate</code>', '<code>boolean</code>', '<code>false</code>', 'Cuts off with … if too long'],
      ],
    },
  ]}
>
  <h2>Heading</h2>
  <p>Use for page titles, section headers, and card titles. Pick the level that matches the page structure — don't pick based on size alone.</p>
  <HeadingGallery client:load />
  <pre><code>{`<Heading as="h1">Page title</Heading>
<Heading as="h2">Section title</Heading>
<Heading as="h3">Subsection</Heading>
<Heading as="h4">Card title</Heading>

<Heading as="h2" muted>Muted heading</Heading>`}</code></pre>

  <h2>Text</h2>
  <p>General body copy. Use <code>size</code> to control how big it is, <code>weight</code> to control boldness.</p>
  <TextGallery client:load />
  <pre><code>{`<Text size="lg">Lead paragraph</Text>
<Text size="base">Body copy</Text>        {/* default */}
<Text size="sm">Secondary text</Text>

<Text weight="semibold">Emphasized</Text>
<Text muted>Subdued text</Text>
<Text truncate>Long text that gets cut off...</Text>`}</code></pre>

  <h2>Caption & Code</h2>
  <p><code>Caption</code> is extra-small muted text for timestamps and metadata. <code>Code</code> is inline monospace for variable names or short snippets.</p>
  <InlineGallery client:load />
  <pre><code>{`<Caption>Last updated March 14, 2026</Caption>

<Text>Use the <Code>variant</Code> prop to change the style.</Text>`}</code></pre>
</ComponentPage>
