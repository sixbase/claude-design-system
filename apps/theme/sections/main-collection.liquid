{{ 'collection.css' | asset_url | stylesheet_tag }}
{{ 'product-card.css' | asset_url | stylesheet_tag }}
{{ 'collection-filters.css' | asset_url | stylesheet_tag }}
{{ 'pagination.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 24
  assign columns_desktop = section.settings.columns_desktop | default: 3
  assign show_vendor = section.settings.show_vendor
  assign enable_filters = section.settings.enable_filters
  assign enable_sort = section.settings.enable_sort
-%}

<section
  class="ds-collection ds-page-container"
  data-columns="{{ columns_desktop }}"
>
  {%- comment -%} Breadcrumb (handles its own BreadcrumbList JSON-LD) {%- endcomment -%}
  {% render 'breadcrumb' %}

  <header class="ds-collection__header">
    <h1 class="ds-heading ds-heading--3xl ds-collection__title">
      {{ collection.title | escape }}
    </h1>
    {%- if collection.description != blank -%}
      <div class="ds-text ds-text--base ds-collection__description">
        {{ collection.description }}
      </div>
    {%- endif -%}
  </header>

  {%- paginate collection.products by products_per_page -%}
    <div class="ds-collection__toolbar" role="region" aria-label="Collection controls">
      <span class="ds-collection__results-count">
        {{ collection.products_count }}
        {%- if collection.products_count == 1 %} product{% else %} products{% endif -%}
      </span>

      {%- if enable_filters and collection.filters.size > 0 -%}
        <div class="ds-collection__mobile-only">
          {% render 'collection-filters', context: 'mobile' %}
        </div>
      {%- endif -%}

      {%- if enable_sort -%}
        <form method="get" class="ds-collection__sort">
          <label for="SortBy" class="ds-collection__sort-label">Sort by</label>
          <select
            id="SortBy"
            name="sort_by"
            class="ds-collection__sort-select"
            data-auto-submit
          >
            {%- for option in collection.sort_options -%}
              <option
                value="{{ option.value }}"
                {% if option.value == collection.sort_by or option.value == collection.default_sort_by %}selected{% endif %}
              >
                {{ option.name | escape }}
              </option>
            {%- endfor -%}
          </select>
          {%- comment -%} Preserve active filters when sort changes {%- endcomment -%}
          {%- for filter in collection.filters -%}
            {%- for value in filter.active_values -%}
              <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
            {%- endfor -%}
            {%- if filter.type == 'price_range' -%}
              {%- if filter.min_value.value != blank -%}
                <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}">
              {%- endif -%}
              {%- if filter.max_value.value != blank -%}
                <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}">
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          <noscript>
            <button type="submit" class="ds-button ds-button--secondary ds-button--sm">Apply</button>
          </noscript>
        </form>
      {%- endif -%}
    </div>

    <div
      class="ds-collection__body{% if enable_filters and collection.filters.size > 0 %} ds-collection__body--with-filters{% endif %}"
    >
      {%- if enable_filters and collection.filters.size > 0 -%}
        <aside class="ds-collection__sidebar" aria-label="Filters">
          {% render 'collection-filters', context: 'desktop' %}
        </aside>
      {%- endif -%}

      <div class="ds-collection__main" id="MainContent">
        {%- if collection.products.size > 0 -%}
          <div class="ds-collection__grid" role="list">
            {%- for product in collection.products -%}
              {%- assign card_loading = 'lazy' -%}
              {%- if forloop.index0 < 4 -%}
                {%- assign card_loading = 'eager' -%}
              {%- endif -%}
              <div role="listitem">
                {% render 'product-card',
                  product: product,
                  show_vendor: show_vendor,
                  loading: card_loading
                %}
              </div>
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <div class="ds-collection__pagination">
              <nav class="ds-pagination ds-pagination--md" aria-label="Pagination">
                <div class="ds-pagination__desktop">
                  {%- if paginate.previous -%}
                    <a
                      href="{{ paginate.previous.url }}"
                      class="ds-button ds-button--secondary ds-button--md"
                      aria-label="Go to previous page"
                    >
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span class="ds-pagination__prev-label">Previous</span>
                    </a>
                  {%- else -%}
                    <button
                      type="button"
                      class="ds-button ds-button--secondary ds-button--md"
                      disabled
                      aria-label="Go to previous page"
                    >
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span class="ds-pagination__prev-label">Previous</span>
                    </button>
                  {%- endif -%}

                  <div class="ds-pagination__pages">
                    {%- for part in paginate.parts -%}
                      {%- if part.is_link -%}
                        <a
                          href="{{ part.url }}"
                          class="ds-button ds-button--ghost ds-button--md ds-button--icon-only"
                          aria-label="Go to page {{ part.title }}"
                        >{{ part.title }}</a>
                      {%- elsif part.title == paginate.current_page -%}
                        <span
                          class="ds-pagination__page ds-pagination__page--current ds-pagination__page--md"
                          aria-current="page"
                          aria-label="Page {{ part.title }}"
                        >{{ part.title }}</span>
                      {%- else -%}
                        <span class="ds-pagination__ellipsis" aria-hidden="true">{{ part.title }}</span>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>

                  {%- if paginate.next -%}
                    <a
                      href="{{ paginate.next.url }}"
                      class="ds-button ds-button--secondary ds-button--md"
                      aria-label="Go to next page"
                    >
                      <span class="ds-pagination__next-label">Next</span>
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  {%- else -%}
                    <button
                      type="button"
                      class="ds-button ds-button--secondary ds-button--md"
                      disabled
                      aria-label="Go to next page"
                    >
                      <span class="ds-pagination__next-label">Next</span>
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                  {%- endif -%}
                </div>

                <div class="ds-pagination__mobile">
                  {%- if paginate.previous -%}
                    <a
                      href="{{ paginate.previous.url }}"
                      class="ds-button ds-button--secondary ds-button--md"
                      aria-label="Go to previous page"
                    >
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      Previous
                    </a>
                  {%- else -%}
                    <button type="button" class="ds-button ds-button--secondary ds-button--md" disabled aria-label="Go to previous page">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      Previous
                    </button>
                  {%- endif -%}

                  <span class="ds-pagination__info">
                    Page {{ paginate.current_page }} of {{ paginate.pages }}
                  </span>

                  {%- if paginate.next -%}
                    <a
                      href="{{ paginate.next.url }}"
                      class="ds-button ds-button--secondary ds-button--md"
                      aria-label="Go to next page"
                    >
                      Next
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  {%- else -%}
                    <button type="button" class="ds-button ds-button--secondary ds-button--md" disabled aria-label="Go to next page">
                      Next
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                  {%- endif -%}
                </div>
              </nav>
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="ds-collection__empty">
            <p class="ds-text ds-text--base">No products match the current filters.</p>
            {%- if collection.all_products_count > 0 -%}
              <a
                href="{{ collection.url }}"
                class="ds-button ds-button--secondary ds-button--sm"
              >
                Clear filters
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endpaginate -%}
</section>

<script>
  (function () {
    document.querySelectorAll('[data-auto-submit]').forEach(function (el) {
      el.addEventListener('change', function () {
        if (el.form) el.form.submit();
      });
    });
  })();
</script>

{%- comment -%} CollectionPage + ItemList JSON-LD {%- endcomment -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": {{ collection.title | json }},
    {% if collection.description != blank %}
      "description": {{ collection.description | strip_html | truncate: 300 | json }},
    {% endif %}
    "url": {{ shop.url | append: collection.url | json }},
    "mainEntity": {
      "@type": "ItemList",
      "numberOfItems": {{ collection.products_count }},
      "itemListElement": [
        {%- for product in collection.products limit: 24 -%}
          {
            "@type": "ListItem",
            "position": {{ forloop.index }},
            "url": {{ shop.url | append: product.url | json }},
            "name": {{ product.title | json }}
            {%- if product.featured_image -%},
              "image": {{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}
            {%- endif -%}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  }
</script>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 12,
      "max": 48,
      "step": 12,
      "label": "Products per page",
      "default": 24
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on desktop",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_filters",
      "label": "Enable filters",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sort",
      "label": "Enable sort",
      "default": true
    }
  ],
  "presets": [{ "name": "Collection" }]
}
{% endschema %}
