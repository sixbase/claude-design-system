---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { SkeletonDefault, SkeletonVariants, SkeletonText, SkeletonProductCard, SkeletonAvatarWithText, SkeletonProductGrid, SkeletonStatic } from '../../components/SkeletonGallery';
---

<ComponentPage
  title="Skeleton"
  description="A pulsing placeholder that indicates content is loading. Matches the shape of what it replaces — text, images, avatars, or entire card layouts."
  installCode="import { Skeleton } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>variant</code>', "<code>'text' | 'circular' | 'rectangular'</code>", "<code>'rectangular'</code>", 'Shape of the skeleton placeholder'],
        ['<code>width</code>', '<code>string | number</code>', '<code>100%</code>', 'CSS width value or number (px)'],
        ['<code>height</code>', '<code>string | number</code>', '—', 'CSS height value or number (px)'],
        ['<code>lines</code>', '<code>number</code>', '<code>1</code>', 'Number of text lines (text variant only)'],
        ['<code>animate</code>', '<code>boolean</code>', '<code>true</code>', 'Enable shimmer animation'],
      ],
    },
  ]}
  accessibility={[
    'All skeletons render with <code>aria-hidden="true"</code> — purely decorative',
    'Wrap skeleton groups in a container with <code>role="status"</code>, <code>aria-busy="true"</code>, and <code>aria-label="Loading"</code>',
    'Shimmer animation pauses automatically when <code>prefers-reduced-motion: reduce</code> is active',
  ]}
>
  <h2>Default</h2>
  <p>A simple rectangular placeholder. Fills container width by default.</p>
  <SkeletonDefault client:load />
  <pre><code>{`<Skeleton variant="rectangular" width={300} height={120} />`}</code></pre>

  <h2>Variants</h2>
  <p>Three shape variants to match the content being loaded: rectangular for images and cards, circular for avatars, and text for paragraph lines.</p>
  <SkeletonVariants client:load />
  <pre><code>{`<Skeleton variant="rectangular" height={100} />
<Skeleton variant="circular" width={48} height={48} />
<Skeleton variant="text" />
<Skeleton variant="text" lines={3} />`}</code></pre>

  <h2>Text lines</h2>
  <p>Use the <code>lines</code> prop to render multiple text placeholders. The last line is shorter (75%) to mimic natural paragraph endings.</p>
  <SkeletonText client:load />
  <pre><code>{`<Skeleton variant="text" lines={4} />`}</code></pre>

  <h2>Product card skeleton</h2>
  <p>Compose multiple skeletons to match a product card layout — image, title, price, and metadata.</p>
  <SkeletonProductCard client:load />
  <pre><code>{`<div style={{ width: '280px', display: 'flex', flexDirection: 'column', gap: 'var(--spacing-3)' }}>
  <Skeleton variant="rectangular" height={280} />
  <Skeleton variant="text" />
  <Skeleton variant="text" width="60%" />
  <Skeleton variant="text" width="40%" />
</div>`}</code></pre>

  <h2>Avatar with text</h2>
  <p>Common pattern for user profiles, reviews, and comment sections.</p>
  <SkeletonAvatarWithText client:load />
  <pre><code>{`<div style={{ display: 'flex', gap: 'var(--spacing-3)', alignItems: 'center' }}>
  <Skeleton variant="circular" width={40} height={40} />
  <div style={{ flex: 1 }}>
    <Skeleton variant="text" width="50%" />
    <Skeleton variant="text" width="80%" />
  </div>
</div>`}</code></pre>

  <h2>Product grid</h2>
  <p>Full loading state for a collection grid. Replace with real <code>ProductCard</code> components when data loads.</p>
  <SkeletonProductGrid client:load />

  <h2>Static (no animation)</h2>
  <p>Set <code>animate={'{false}'}</code> to disable the shimmer effect. Useful for print or low-motion contexts.</p>
  <SkeletonStatic client:load />
  <pre><code>{`<Skeleton variant="rectangular" width={300} height={100} animate={false} />`}</code></pre>
</ComponentPage>
