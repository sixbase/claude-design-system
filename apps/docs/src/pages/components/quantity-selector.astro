---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { QuantitySelectorDefault, QuantitySelectorSizes, QuantitySelectorStates } from '../../components/QuantitySelectorGallery';
---

<ComponentPage
  title="Quantity Selector"
  description="A controlled stepper for numeric values. Common in ecommerce for cart item quantities. Supports min/max bounds, step increments, and three sizes."
  installCode="import { QuantitySelector } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>value</code>', '<code>number</code>', '—', 'Current value (controlled)'],
        ['<code>onChange</code>', '<code>(value: number) =&gt; void</code>', '—', 'Called when value changes'],
        ['<code>min</code>', '<code>number</code>', '<code>1</code>', 'Minimum value'],
        ['<code>max</code>', '<code>number</code>', '<code>99</code>', 'Maximum value'],
        ['<code>step</code>', '<code>number</code>', '<code>1</code>', 'Step increment'],
        ['<code>size</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Size variant'],
        ['<code>disabled</code>', '<code>boolean</code>', '<code>false</code>', 'Disable interaction'],
      ],
    },
  ]}
  accessibility={[
    'Wraps in <code>role="group"</code> with <code>aria-label="Quantity"</code>',
    'Decrement/increment buttons have descriptive <code>aria-label</code>',
    'Buttons are automatically disabled at min/max bounds',
    'Value is rendered as <code>&lt;output&gt;</code> for live region semantics',
  ]}
>
  <h2>Default</h2>
  <QuantitySelectorDefault client:load />
  <pre><code>{`const [qty, setQty] = useState(1);

<QuantitySelector value={qty} onChange={setQty} />`}</code></pre>

  <h2>Sizes</h2>
  <QuantitySelectorSizes client:load />
  <pre><code>{`<QuantitySelector size="sm" value={qty} onChange={setQty} />
<QuantitySelector size="md" value={qty} onChange={setQty} />  {/* default */}
<QuantitySelector size="lg" value={qty} onChange={setQty} />`}</code></pre>

  <h2>States</h2>
  <p>Disabled state and constrained range (min 1, max 5).</p>
  <QuantitySelectorStates client:load />
  <pre><code>{`<QuantitySelector disabled value={1} onChange={setQty} />
<QuantitySelector value={qty} onChange={setQty} min={1} max={5} />`}</code></pre>
</ComponentPage>
