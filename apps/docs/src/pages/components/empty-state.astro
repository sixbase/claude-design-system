---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { EmptyStateDefault, EmptyStateEcommerce, EmptyStateInformational, EmptyStateCompact } from '../../components/EmptyStateGallery';
---

<ComponentPage
  title="Empty State"
  description="Consistent &ldquo;nothing here&rdquo; message pattern for empty cart, no search results, no orders, and empty wishlist screens. A centered layout pattern that composes Heading, Text, and Button."
  installCode="import { EmptyState } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>icon</code>', '<code>ReactNode</code>', '—', 'Optional icon or illustration'],
        ['<code>heading</code>', '<code>string</code>', '—', 'Main heading text (required)'],
        ['<code>description</code>', '<code>string</code>', '—', 'Supporting description'],
        ['<code>action</code>', '<code>{ label: string; href: string }</code>', '—', 'Primary call-to-action link'],
        ['<code>secondaryAction</code>', '<code>{ label: string; href: string }</code>', '—', 'Secondary call-to-action link'],
        ['<code>compact</code>', '<code>boolean</code>', '<code>false</code>', 'Smaller padding and heading for constrained contexts'],
      ],
    },
  ]}
  accessibility={[
    'Uses semantic <code>&lt;h2&gt;</code> via <code>Heading</code> component',
    'Action links use <code>Button asChild</code> for proper link semantics — screen readers announce them as links',
    'Add <code>role="status"</code> when empty state appears dynamically (e.g., after clearing a cart) so screen readers announce the change',
    'Icons are decorative (<code>aria-hidden="true"</code>) — text carries the meaning',
  ]}
>
  <h2>Default</h2>
  <p>Icon, heading, description, and one or two action buttons. The standard empty state for most contexts.</p>
  <EmptyStateDefault client:load />
  <pre><code>{`<EmptyState
  icon={<ShoppingBagIcon />}
  heading="Your bag is empty"
  description="Looks like you haven't added anything yet."
  action={{ label: 'Browse collection', href: '/collections' }}
  secondaryAction={{ label: 'Continue shopping', href: '/' }}
/>`}</code></pre>

  <h2>Ecommerce contexts</h2>
  <p>Empty states for cart, search, orders, and wishlist — each with contextual icon and action.</p>
  <EmptyStateEcommerce client:load />

  <h2>Informational only</h2>
  <p>Omit <code>icon</code> and <code>action</code> for a minimal text-only empty state, such as filter results.</p>
  <EmptyStateInformational client:load />
  <pre><code>{`<EmptyState
  heading="No items match your filters"
  description="Try removing some filters to see more results."
/>`}</code></pre>

  <h2>Compact</h2>
  <p>Use <code>compact</code> in constrained contexts like a Cart Drawer. Reduces padding and heading size.</p>
  <EmptyStateCompact client:load />
  <pre><code>{`<EmptyState
  icon={<ShoppingBagIcon />}
  heading="Your bag is empty"
  description="You haven't added anything yet."
  action={{ label: 'Browse collection', href: '/collections' }}
  compact
/>`}</code></pre>
</ComponentPage>
