---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { HighlightsDefault } from '../../components/HighlightsGallery';
---

<ComponentPage
  title="Highlights"
  description="A responsive row of image cards, each a 4:5 portrait on a light surface with large (34px) corners and an inline title + description. One column on phones, two from 640px, three from 1024px. Compose <code>Highlights</code> with <code>Highlight</code> children."
  installCode="import { Highlights, Highlight } from '@ds/components';"
  props={[
    {
      name: 'Highlights',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>children</code>', '<code>ReactNode</code>', '—', 'One or more <code>Highlight</code> cards'],
      ],
    },
    {
      name: 'Highlight',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>image</code>', '<code>ReactNode</code>', '—', 'Image for the 4:5 card; omit for an empty light placeholder'],
        ['<code>title</code>', '<code>string</code>', '—', 'Lead phrase — heavier, with a trailing period'],
        ['<code>description</code>', '<code>string</code>', '—', 'Supporting copy — lighter and muted, inline after the title'],
      ],
    },
  ]}
  accessibility={[
    'Image content should include appropriate <code>alt</code> text (empty <code>alt</code> for decorative images)',
    'Title and description render as inline spans within a single <code>&lt;p&gt;</code>, read as one continuous sentence',
    'The trailing period is decorative (CSS <code>::after</code>) and excluded from the accessible text',
  ]}
>
  <h2>Default</h2>
  <HighlightsDefault client:load />
  <pre><code>{`<Highlights>
  <Highlight
    title="Thoughtfully sourced materials"
    description="Organic cotton, vegetable-tanned leather..."
    image={<img src="..." alt="" className="ds-highlights__img" />}
  />
  <Highlight title="Designed to last" description="..." image={/* ... */} />
  <Highlight title="Small-batch, zero waste" description="..." image={/* ... */} />
</Highlights>`}</code></pre>
</ComponentPage>
