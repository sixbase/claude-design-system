---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { TabsDefault, TabsControlled, TabsDisabled, TabsOverflow } from '../../components/TabsGallery';
---

<ComponentPage
  title="Tabs"
  description="A tabbed content switcher for organizing related content into panels. Built on <a href='https://www.radix-ui.com/primitives/docs/components/tabs'>Radix Tabs</a> for full keyboard and screen reader support."
  installCode="import { Tabs, TabsList, TabsTrigger, TabsContent } from '@ds/components';"
  props={[
    {
      name: 'Tabs (Root)',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>defaultValue</code>', '<code>string</code>', '—', 'Initial active tab (uncontrolled)'],
        ['<code>value</code>', '<code>string</code>', '—', 'Active tab value (controlled)'],
        ['<code>onValueChange</code>', '<code>(value: string) =&gt; void</code>', '—', 'Callback when the active tab changes'],
      ],
    },
    {
      name: 'TabsTrigger',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>value</code>', '<code>string</code>', '—', 'Unique value identifying this tab (required)'],
        ['<code>disabled</code>', '<code>boolean</code>', '<code>false</code>', 'Prevents activation of this tab'],
      ],
    },
    {
      name: 'TabsContent',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>value</code>', '<code>string</code>', '—', 'Value matching the corresponding TabsTrigger (required)'],
      ],
    },
  ]}
  accessibility={[
    'Built on Radix Tabs — <code>role="tablist"</code>, <code>role="tab"</code>, <code>role="tabpanel"</code> automatically applied',
    '<code>aria-selected</code> on the active tab, <code>aria-controls</code> linking each tab to its panel',
    'Arrow keys navigate between tabs horizontally; Home/End jump to first/last tab',
    'Tab panel receives focus via <code>tabIndex={0}</code> for keyboard navigation',
    'Disabled tabs are skipped during keyboard navigation',
  ]}
>
  <h2>Default</h2>
  <p>Uncontrolled tabs with a <code>defaultValue</code>. Click tabs or use arrow keys to navigate.</p>
  <TabsDefault client:load />
  <pre><code>{`<Tabs defaultValue="description">
  <TabsList>
    <TabsTrigger value="description">Description</TabsTrigger>
    <TabsTrigger value="reviews">Reviews</TabsTrigger>
    <TabsTrigger value="specs">Specifications</TabsTrigger>
  </TabsList>
  <TabsContent value="description">...</TabsContent>
  <TabsContent value="reviews">...</TabsContent>
  <TabsContent value="specs">...</TabsContent>
</Tabs>`}</code></pre>

  <h2>Controlled</h2>
  <p>Use <code>value</code> and <code>onValueChange</code> for controlled tab state.</p>
  <TabsControlled client:load />
  <pre><code>{`const [value, setValue] = useState('reviews');

<Tabs value={value} onValueChange={setValue}>
  <TabsList>
    <TabsTrigger value="description">Description</TabsTrigger>
    <TabsTrigger value="reviews">Reviews</TabsTrigger>
  </TabsList>
  <TabsContent value="description">...</TabsContent>
  <TabsContent value="reviews">...</TabsContent>
</Tabs>`}</code></pre>

  <h2>Disabled Tab</h2>
  <p>Individual tabs can be disabled. They are visually muted and skipped by keyboard navigation.</p>
  <TabsDisabled client:load />
  <pre><code>{`<TabsTrigger value="reviews" disabled>
  Reviews (Coming Soon)
</TabsTrigger>`}</code></pre>

  <h2>Overflow (Scrollable)</h2>
  <p>When tabs overflow their container, the list scrolls horizontally with subtle edge fades. This preserves the tab pattern on mobile without collapsing to an accordion.</p>
  <TabsOverflow client:load />
  <pre><code>{`<div style={{ maxWidth: '400px' }}>
  <Tabs defaultValue="tab-1">
    <TabsList>
      <TabsTrigger value="tab-1">Description</TabsTrigger>
      <TabsTrigger value="tab-2">Reviews</TabsTrigger>
      {/* ...more tabs */}
    </TabsList>
    ...
  </Tabs>
</div>`}</code></pre>
</ComponentPage>
