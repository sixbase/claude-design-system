---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { ModalDefault, ModalSizes, ModalConfirmation, ModalControlled } from '../../components/ModalGallery';
---

<ComponentPage
  title="Modal"
  description="An accessible dialog overlay built on Radix UI Dialog. Traps focus, returns focus on close, supports Escape key, and prevents background scrolling. Common ecommerce uses: confirmation dialogs, quick-edit forms, order detail previews, cart item removal."
  installCode={`import {
  Modal, ModalTrigger, ModalContent,
  ModalHeader, ModalTitle, ModalDescription,
  ModalBody, ModalFooter, ModalClose,
} from '@ds/components';`}
  accessibility={[
    'Focus is trapped inside the modal while open',
    'Focus returns to the trigger element when the modal closes',
    'Escape key closes the modal',
    'Background content is hidden from screen readers via <code>aria-hidden</code>',
    '<code>ModalTitle</code> is linked via <code>aria-labelledby</code>',
    '<code>ModalDescription</code> is linked via <code>aria-describedby</code>',
    'The dialog has <code>role="dialog"</code>',
  ]}
>
  <h2>Default</h2>
  <ModalDefault client:load />
  <pre><code>{`<Modal>
  <ModalTrigger asChild>
    <Button>Edit profile</Button>
  </ModalTrigger>
  <ModalContent>
    <ModalHeader>
      <ModalTitle>Edit profile</ModalTitle>
      <ModalDescription>Make changes to your profile.</ModalDescription>
    </ModalHeader>
    <ModalBody>
      <Input label="Name" defaultValue="Jane Doe" />
    </ModalBody>
    <ModalFooter>
      <ModalClose asChild>
        <Button variant="secondary">Cancel</Button>
      </ModalClose>
      <Button>Save changes</Button>
    </ModalFooter>
  </ModalContent>
</Modal>`}</code></pre>

  <h2>Sizes</h2>
  <p>Three size presets control the max-width: <code>sm</code> (400px), <code>md</code> (520px, default), <code>lg</code> (680px).</p>
  <ModalSizes client:load />
  <pre><code>{`<ModalContent size="sm">...</ModalContent>  {/* 400px — confirmations */}
<ModalContent size="md">...</ModalContent>  {/* 520px — forms, default */}
<ModalContent size="lg">...</ModalContent>  {/* 680px — detail views */}`}</code></pre>

  <h2>Confirmation dialog</h2>
  <p>For destructive actions, use a small modal with a clear title and destructive button.</p>
  <ModalConfirmation client:load />
  <pre><code>{`<Modal>
  <ModalTrigger asChild>
    <Button variant="destructive">Remove from cart</Button>
  </ModalTrigger>
  <ModalContent size="sm">
    <ModalHeader>
      <ModalTitle>Remove item?</ModalTitle>
      <ModalDescription>
        "Organic Cotton T-Shirt" will be removed from your cart.
      </ModalDescription>
    </ModalHeader>
    <ModalFooter>
      <ModalClose asChild>
        <Button variant="secondary">Keep item</Button>
      </ModalClose>
      <Button variant="destructive">Remove</Button>
    </ModalFooter>
  </ModalContent>
</Modal>`}</code></pre>

  <h2>Controlled</h2>
  <p>Pass <code>open</code> and <code>onOpenChange</code> to manage the modal state externally.</p>
  <ModalControlled client:load />
  <pre><code>{`const [open, setOpen] = useState(false);

<Button onClick={() => setOpen(true)}>Open</Button>
<Modal open={open} onOpenChange={setOpen}>
  <ModalContent>
    ...
    <Button onClick={() => setOpen(false)}>Close</Button>
  </ModalContent>
</Modal>`}</code></pre>
</ComponentPage>
