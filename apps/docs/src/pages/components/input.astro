---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { InputStates } from '../../components/InputGallery';
---

<ComponentPage
  title="Input"
  description="A text field with a built-in label, helper text, and error state. It's accessible out of the box — the label is always linked to the field, and error messages are announced to screen readers automatically."
  installCode="import { Input } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'What it does'],
      rows: [
        ['<code>label</code>', '<code>string</code>', '—', 'Visible label above the field'],
        ['<code>hint</code>', '<code>string</code>', '—', 'Helper text below the field'],
        ['<code>error</code>', '<code>string</code>', '—', 'Error message — turns border red, hides hint'],
        ['<code>disabled</code>', '<code>boolean</code>', '<code>false</code>', 'Grays out the field, blocks typing'],
        ['<code>required</code>', '<code>boolean</code>', '<code>false</code>', 'Adds * to label, marks field as required'],
        ['<code>leadingAdornment</code>', '<code>ReactNode</code>', '—', 'Icon or element before the text'],
        ['<code>trailingAdornment</code>', '<code>ReactNode</code>', '—', 'Icon or element after the text'],
      ],
    },
  ]}
  accessibility={[
    'Label is always linked to the input — never use a placeholder as a label substitute',
    'Error messages use <code>role="alert"</code> so screen readers announce them immediately',
    'Hint and error are wired up via <code>aria-describedby</code> automatically',
  ]}
>
  <h2>All states</h2>
  <InputStates client:load />

  <h2>Default</h2>
  <pre><code>{`<Input label="Email address" type="email" placeholder="you@example.com" />`}</code></pre>

  <h2>With helper text</h2>
  <p>Use <code>hint</code> to show guidance below the field.</p>
  <pre><code>{`<Input label="Password" type="password" hint="Must be at least 8 characters" />`}</code></pre>

  <h2>Error state</h2>
  <p>Pass <code>error</code> to show a red message and highlight the border. The message is read aloud by screen readers.</p>
  <pre><code>{`<Input label="Email" error="Please enter a valid email address" />`}</code></pre>

  <h2>Required</h2>
  <pre><code>{`<Input label="Full name" required />`}</code></pre>

  <h2>Disabled</h2>
  <pre><code>{`<Input label="Username" defaultValue="jane_smith" disabled />`}</code></pre>

  <h2>With icon</h2>
  <pre><code>{`<Input
  placeholder="Search..."
  leadingAdornment={<SearchIcon />}
/>`}</code></pre>
</ComponentPage>
