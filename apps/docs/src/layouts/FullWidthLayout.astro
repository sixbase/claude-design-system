---
import '@ds/tokens/css';
import '@ds/components/styles';
import './base.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Design system documentation' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Design System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Ancizar+Serif:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__logo" aria-label="Home">Mason Supply Co.
        <nav class="site-header__nav" aria-label="Main">
          <a href="#">Shop</a>
          <a href="#">Collections</a>
          <a href="#">About</a>
        </nav>
        <button type="button" class="site-header__cart" aria-label="Shopping bag (0 items)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" />
            <line x1="3" y1="6" x2="21" y2="6" />
            <path d="M16 10a4 4 0 01-8 0" />
          </svg>
        </button>
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  /* ─── Header ──────────────────────────────────────────── */
  .site-header {
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-4);
    gap: var(--spacing-4);
  }

  @media (min-width: 768px) {
    .site-header__inner {
      padding: var(--spacing-4) var(--spacing-8);
    }
  }

  @media (min-width: 1024px) {
    .site-header__inner {
      padding: var(--spacing-4) var(--spacing-16);
    }
  }

  .site-header__logo {
    font-family: var(--font-family-sans);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-foreground);
    text-decoration: none;
  }

  .site-header__nav {
    display: none;
    gap: var(--spacing-6);
  }

  @media (min-width: 768px) {
    .site-header__nav {
      display: flex;
    }
  }

  .site-header__nav a {
    font-family: var(--font-family-sans);
    font-size: var(--font-size-sm);
    color: var(--color-foreground-subtle);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .site-header__nav a:hover {
    color: var(--color-foreground);
  }

  .site-header__cart {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--color-foreground);
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast);
    padding: 0;
  }

  .site-header__cart:hover {
    background-color: var(--color-background-subtle);
  }

  .site-header__cart:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-focus-ring);
  }

  /* ─── Main ────────────────────────────────────────────── */
  main {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--spacing-4);
  }

  @media (min-width: 768px) {
    main {
      padding: var(--spacing-6) var(--spacing-8);
    }
  }

  @media (min-width: 1024px) {
    main {
      padding: var(--spacing-6) var(--spacing-16);
    }
  }
</style>
