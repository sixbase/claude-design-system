---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { CardVariants, CardProduct } from '../../components/CardGallery';
---

<ComponentPage
  title="Card"
  description="A surface for grouping related content. Compound component — compose <code>CardImage</code>, <code>CardBody</code>, and <code>CardFooter</code> as needed. The <code>interactive</code> prop adds hover lift and image zoom for clickable cards."
  installCode="import { Card, CardImage, CardBody, CardFooter } from '@ds/components';"
  props={[
    {
      name: 'Card',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>variant</code>', "<code>'elevated' | 'outlined' | 'ghost'</code>", "<code>'elevated'</code>", 'Visual style'],
        ['<code>interactive</code>', '<code>boolean</code>', '<code>false</code>', 'Hover lift + image zoom'],
      ],
    },
    {
      name: 'CardImage',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>src</code>', '<code>string</code>', '—', 'Image URL'],
        ['<code>alt</code>', '<code>string</code>', '—', 'Alt text (required)'],
        ['<code>aspectRatio</code>', '<code>string</code>', "<code>'4/3'</code>", 'CSS aspect-ratio value'],
      ],
    },
  ]}
  accessibility={[
    'Interactive cards should be wrapped in <code>&lt;a&gt;</code> or use <code>onClick</code> — the card itself doesn\'t add interactivity semantics',
    '<code>CardImage</code> requires a meaningful <code>alt</code> attribute',
    'Hover effects respect <code>prefers-reduced-motion</code>',
  ]}
>
  <h2>Variants</h2>
  <CardVariants client:load />
  <pre><code>{`<Card variant="elevated">...</Card>   {/* default — border + subtle shadow */}
<Card variant="outlined">...</Card>   {/* border only, no shadow */}
<Card variant="ghost">...</Card>      {/* subtle background fill */}`}</code></pre>

  <h2>Product card</h2>
  <p>
    Add <code>interactive</code> for clickable cards. The image zooms on hover and the card
    lifts slightly. Combine with <code>Badge</code> and <code>Button</code>.
  </p>
  <CardProduct client:load />
  <pre><code>{`<Card variant="elevated" interactive>
  <CardImage src="/product.jpg" alt="Product name" aspectRatio="4/3" />
  <CardBody>
    <div style={{ display: 'flex', justifyContent: 'space-between' }}>
      <strong>Minimalist Watch</strong>
      <Badge variant="default" size="sm">New</Badge>
    </div>
    <p>$249</p>
  </CardBody>
  <CardFooter>
    <Button size="sm" fullWidth>Add to cart</Button>
  </CardFooter>
</Card>`}</code></pre>
</ComponentPage>
