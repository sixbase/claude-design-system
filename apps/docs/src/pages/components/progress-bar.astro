---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { ProgressBarDefault, ProgressBarSizes, ProgressBarSuccess, ProgressBarCustomText, ProgressBarEcommerce } from '../../components/ProgressBarGallery';
---

<ComponentPage
  title="Progress Bar"
  description="Visual progress indicator for shipping thresholds, multi-step flows, and loading states. Built on the native <code>progress</code> element for semantic accessibility."
  installCode="import { ProgressBar } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>value</code>', '<code>number</code>', '—', 'Current progress value (0–100, or 0–max)'],
        ['<code>max</code>', '<code>number</code>', '<code>100</code>', 'Maximum value'],
        ['<code>label</code>', '<code>string</code>', '—', 'Visible label above the bar and aria-label for screen readers'],
        ['<code>showValue</code>', '<code>boolean</code>', '<code>false</code>', 'Show percentage text below the bar'],
        ['<code>valueText</code>', '<code>string</code>', '—', 'Custom value text (overrides percentage). Also sets aria-valuetext.'],
        ['<code>size</code>', "<code>'sm' | 'md'</code>", "<code>'md'</code>", 'Track height — sm: 4px, md: 8px'],
        ['<code>variant</code>', "<code>'default' | 'success'</code>", "<code>'default'</code>", 'Success variant turns green when value reaches 100%'],
      ],
    },
  ]}
  accessibility={[
    'Uses native <code>&lt;progress&gt;</code> element for built-in screen reader support',
    '<code>aria-valuenow</code>, <code>aria-valuemin</code>, <code>aria-valuemax</code> set automatically',
    '<code>aria-label</code> from the <code>label</code> prop',
    '<code>aria-valuetext</code> from <code>valueText</code> prop — screen readers announce "$12 away from free shipping" instead of "75 percent"',
    'Fill animation respects <code>prefers-reduced-motion: reduce</code>',
    'Values clamped: below 0 → 0%, above max → 100%',
  ]}
>
  <h2>Default</h2>
  <p>Basic progress bar with optional percentage display.</p>
  <ProgressBarDefault client:load />
  <pre><code>{`<ProgressBar value={60} label="Progress" />
<ProgressBar value={45} label="Upload progress" showValue />`}</code></pre>

  <h2>Sizes</h2>
  <p>Two sizes: <code>sm</code> (4px) for inline/subtle indicators, <code>md</code> (8px) for standard use.</p>
  <ProgressBarSizes client:load />
  <pre><code>{`<ProgressBar value={60} size="sm" label="Small" />
<ProgressBar value={60} size="md" label="Medium" />`}</code></pre>

  <h2>Success variant</h2>
  <p>The <code>success</code> variant shows default fill until 100%, then turns green to signal completion.</p>
  <ProgressBarSuccess client:load />
  <pre><code>{`<ProgressBar value={60} variant="success" label="In progress" showValue />
<ProgressBar value={100} variant="success" label="Complete!" showValue />`}</code></pre>

  <h2>Custom value text</h2>
  <p>Use <code>valueText</code> for contextual messaging. This also sets <code>aria-valuetext</code> for screen readers.</p>
  <ProgressBarCustomText client:load />
  <pre><code>{`<ProgressBar
  value={36}
  max={48}
  label="Free shipping progress"
  valueText="$12 away from free shipping!"
  size="sm"
/>`}</code></pre>

  <h2>Ecommerce context</h2>
  <p>Free shipping thresholds and multi-step checkout indicators.</p>
  <ProgressBarEcommerce client:load />
  <pre><code>{`<ProgressBar
  value={36} max={48}
  label="Free shipping progress"
  valueText="$12 away from free shipping!"
  size="sm"
/>
<ProgressBar
  value={48} max={48}
  variant="success"
  label="Free shipping unlocked!"
  size="sm"
/>
<ProgressBar value={33} label="Step 1 of 3: Shipping" showValue />`}</code></pre>
</ComponentPage>
