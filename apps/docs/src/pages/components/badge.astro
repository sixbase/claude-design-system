---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { BadgeVariants, BadgeSizes, BadgeEcommerce } from '../../components/BadgeGallery';
---

<ComponentPage
  title="Badge"
  description="A small label for status, category, or count. Pure styling — no interaction. Common ecommerce uses: stock status, sale labels, order state, product categories."
  installCode="import { Badge } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>variant</code>', "<code>'default' | 'secondary' | 'success' | 'warning' | 'destructive' | 'outline'</code>", '<code>\'default\'</code>', 'Visual style'],
        ['<code>size</code>', "<code>'sm' | 'md'</code>", "<code>'md'</code>", 'Size'],
      ],
    },
  ]}
  accessibility={[
    'Renders as <code>&lt;span&gt;</code> — not interactive, no keyboard behavior',
    'Color is never the only indicator — also uses distinct background tints',
    'For screen readers, consider pairing with visually hidden context: <code>&lt;Badge&gt;&lt;span aria-hidden="true"&gt;●&lt;/span&gt; In stock&lt;/Badge&gt;</code>',
  ]}
>
  <h2>Variants</h2>
  <p>Six semantic variants for different contexts.</p>
  <BadgeVariants client:load />
  <pre><code>{`<Badge variant="default">New</Badge>
<Badge variant="secondary">Sale</Badge>
<Badge variant="success">In stock</Badge>
<Badge variant="warning">Low stock</Badge>
<Badge variant="destructive">Out of stock</Badge>
<Badge variant="outline">Archive</Badge>`}</code></pre>

  <h2>Sizes</h2>
  <BadgeSizes client:load />
  <pre><code>{`<Badge size="sm">Small</Badge>
<Badge size="md">Medium</Badge>   {/* default */}`}</code></pre>

  <h2>Ecommerce context</h2>
  <p>Small badges work well as overlays or inline labels on product cards.</p>
  <BadgeEcommerce client:load />
  <pre><code>{`<Badge variant="default" size="sm">New arrival</Badge>
<Badge variant="secondary" size="sm">20% off</Badge>
<Badge variant="success" size="sm">Free shipping</Badge>
<Badge variant="destructive" size="sm">Final sale</Badge>
<Badge variant="warning" size="sm">2 left</Badge>`}</code></pre>
</ComponentPage>
