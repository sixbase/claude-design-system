{%- comment -%}
  Render a single cart line item row.

  Mirrors CartLineItem in packages/components/src/cart-line-item/.
  Outputs .ds-cart-line-item with every BEM child from the React
  component. Uses a native number input + named submit buttons so
  the form continues to work with JavaScript disabled:

    name="updates[{{ line_item.key }}]"   → standard Shopify /cart POST
    Plus / minus buttons submit the form with a hidden input bump.
    Remove is a link to line_item.url_to_remove — no JS required.

  Accepts:
    line_item       Shopify line_item object, required
    show_vendor     boolean — defaults to false

  Usage:
    {% render 'cart-line-item', line_item: line_item, show_vendor: true %}
{%- endcomment -%}

{%- liquid
  assign lip = line_item
  assign has_variant_title = false
  if lip.variant.title != blank and lip.variant.title != 'Default Title'
    assign has_variant_title = true
  endif
  assign is_on_sale = false
  if lip.original_price and lip.final_price and lip.original_price > lip.final_price
    assign is_on_sale = true
  endif
  assign name_escaped = lip.product.title | default: '' | escape
-%}

<div
  class="ds-cart-line-item"
  role="group"
  aria-label="{{ name_escaped }}"
  data-cart-line-item
  data-line-key="{{ lip.key }}"
>
  {%- comment -%} ── Image ──────────────────────────────────────── {%- endcomment -%}
  <div class="ds-cart-line-item__image-wrapper">
    {%- if lip.image != blank -%}
      <a href="{{ lip.url }}" class="ds-cart-line-item__image-link" aria-hidden="true" tabindex="-1">
        {% render 'responsive-image',
          image: lip.image,
          alt: lip.product.title,
          sizes: '(min-width: 640px) 96px, 80px',
          class: 'ds-cart-line-item__image'
        %}
      </a>
    {%- else -%}
      <div class="ds-cart-line-item__placeholder" aria-hidden="true">
        {% render 'icon', name: 'cart', size: 'md' %}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Info ───────────────────────────────────────── {%- endcomment -%}
  <div class="ds-cart-line-item__info">
    <a href="{{ lip.url }}" class="ds-cart-line-item__link">
      <span class="ds-text ds-text--sm ds-text--semibold ds-cart-line-item__name">
        {{- lip.product.title | escape -}}
      </span>
    </a>

    {%- if has_variant_title or show_vendor or lip.properties.size > 0 -%}
      <div class="ds-cart-line-item__options">
        {%- if has_variant_title -%}
          {%- for option in lip.options_with_values -%}
            <span class="ds-text ds-text--sm ds-text--muted">
              {{- option.name | escape }}: {{ option.value | escape -}}
            </span>
          {%- endfor -%}
        {%- endif -%}

        {%- if show_vendor and lip.vendor != blank -%}
          <span class="ds-text ds-text--sm ds-text--muted">
            {{- 'By ' -}}{{- lip.vendor | escape -}}
          </span>
        {%- endif -%}

        {%- for property in lip.properties -%}
          {%- assign property_first_char = property.first | slice: 0 -%}
          {%- if property.last != blank and property_first_char != '_' -%}
            <span class="ds-text ds-text--sm ds-text--muted">
              {%- if property.last contains '/uploads/' -%}
                {{ property.first | escape }}:
                <a href="{{ property.last }}" class="ds-cart-line-item__property-link">{{ property.last | split: '/' | last | escape }}</a>
              {%- else -%}
                {{- property.first | escape }}: {{ property.last | escape -}}
              {%- endif -%}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if is_on_sale -%}
      <span class="ds-badge ds-badge--secondary ds-badge--sm">Sale</span>
    {%- endif -%}

    {%- comment -%} Unit price — visible on mobile below info {%- endcomment -%}
    <div class="ds-cart-line-item__unit-price">
      {% render 'price',
        price: lip.final_price,
        compare_at_price: lip.original_price,
        size: 'sm'
      %}
    </div>
  </div>

  {%- comment -%} ── Quantity ──────────────────────────────────── {%- endcomment -%}
  <div class="ds-cart-line-item__quantity">
    <div
      class="ds-quantity-selector ds-quantity-selector--sm"
      role="group"
      aria-label="Quantity for {{ name_escaped }}"
    >
      <button
        type="submit"
        class="ds-quantity-selector__btn"
        name="updates[{{ lip.key }}]"
        value="{{ lip.quantity | minus: 1 }}"
        aria-label="Decrease quantity for {{ name_escaped }}"
        {% if lip.quantity <= 1 %}disabled{% endif %}
        data-qty-decrease
      >
        {% render 'icon', name: 'minus', size: 'sm' %}
      </button>
      <input
        type="number"
        class="ds-quantity-selector__value"
        name="updates[{{ lip.key }}]"
        value="{{ lip.quantity }}"
        min="0"
        aria-label="Quantity"
        data-qty-input
      >
      <button
        type="submit"
        class="ds-quantity-selector__btn"
        name="updates[{{ lip.key }}]"
        value="{{ lip.quantity | plus: 1 }}"
        aria-label="Increase quantity for {{ name_escaped }}"
        data-qty-increase
      >
        {% render 'icon', name: 'plus', size: 'sm' %}
      </button>
    </div>
  </div>

  {%- comment -%} ── Line total ────────────────────────────────── {%- endcomment -%}
  <div class="ds-cart-line-item__price">
    <span class="ds-text ds-text--sm ds-text--semibold">
      {% render 'price', price: lip.final_line_price, size: 'sm' %}
    </span>
  </div>

  {%- comment -%} ── Remove ────────────────────────────────────── {%- endcomment -%}
  <div class="ds-cart-line-item__remove">
    <a
      href="{{ lip.url_to_remove }}"
      class="ds-button ds-button--ghost ds-button--sm ds-button--icon-only"
      aria-label="Remove {{ name_escaped }} from cart"
      data-cart-remove
    >
      {% render 'icon', name: 'close', size: 'sm' %}
    </a>
  </div>
</div>
