---
import BaseLayout from './BaseLayout.astro';

interface PropTable {
  name?: string;
  headers: string[];
  rows: string[][];
}

interface Props {
  title: string;
  description: string;
  installCode: string;
  props?: PropTable[];
  accessibility?: string[];
}

const { title, description, installCode, props, accessibility } = Astro.props;
---

<BaseLayout title={title}>
  <div class="prose">
    <h1>{title}</h1>
    <p set:html={description} />

    <h2>Installation</h2>
    <pre><code>{installCode}</code></pre>

    <slot />

    {props && props.length > 0 && (
      <h2>Props</h2>
    )}
    {props?.map((table) => (
      <>
        {table.name && <h3>{table.name}</h3>}
        <table class="props-table">
          <thead>
            <tr>
              {table.headers.map((h) => <th>{h}</th>)}
            </tr>
          </thead>
          <tbody>
            {table.rows.map((row) => (
              <tr>
                {row.map((cell) => <td set:html={cell} />)}
              </tr>
            ))}
          </tbody>
        </table>
      </>
    ))}

    {accessibility && accessibility.length > 0 && (
      <>
        <h2>Accessibility</h2>
        <ul>
          {accessibility.map((item) => <li set:html={item} />)}
        </ul>
      </>
    )}
  </div>
</BaseLayout>
