{{ 'cart.css' | asset_url | stylesheet_tag }}
{{ 'cart-line-item.css' | asset_url | stylesheet_tag }}
{{ 'quantity-selector.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign show_cart_note = section.settings.show_cart_note
  assign show_vendor = section.settings.show_vendor
  assign item_count = cart.item_count
  assign item_noun = 'items'
  if item_count == 1
    assign item_noun = 'item'
  endif
-%}

<section class="ds-cart ds-page-container" aria-labelledby="cart-heading">
  {% render 'breadcrumb' %}

  <header class="ds-cart__header">
    <h1 id="cart-heading" class="ds-heading ds-heading--3xl">Cart</h1>
    {%- if item_count > 0 -%}
      <span class="ds-text ds-text--sm ds-cart__summary-count">
        {{- item_count }} {{ item_noun }} in your cart
      </span>
    {%- endif -%}
  </header>

  {%- if item_count == 0 -%}

    {%- comment -%} ── Empty state ──────────────────────────────── {%- endcomment -%}
    <div class="ds-cart__empty" role="status">
      <span class="ds-cart__empty-icon" aria-hidden="true">
        {% render 'icon', name: 'cart', size: 'lg' %}
      </span>
      <h2 class="ds-heading ds-heading--xl ds-cart__empty-title">Your cart is empty</h2>
      <p class="ds-text ds-text--base ds-cart__empty-body">
        Nothing here yet. Browse the catalog to find something you love.
      </p>
      <a
        href="{{ routes.all_products_collection_url }}"
        class="ds-button ds-button--primary ds-button--lg"
      >
        Continue shopping
      </a>
    </div>

  {%- else -%}

    {%- comment -%} ── Populated cart ──────────────────────────── {%- endcomment -%}
    <form
      action="{{ routes.cart_url }}"
      method="post"
      novalidate
      class="ds-cart__form ds-layout ds-layout--golden"
      id="cart-form"
    >
      {%- comment -%} Items column (7/12) {%- endcomment -%}
      <div class="ds-cart__items-wrapper">
        <div class="ds-cart__items-header" aria-hidden="true">
          <span class="ds-cart__items-header-label">Product</span>
          <span class="ds-cart__items-header-label"></span>
          <span class="ds-cart__items-header-label ds-cart__items-header-label--quantity">Quantity</span>
          <span class="ds-cart__items-header-label ds-cart__items-header-label--price">Total</span>
          <span class="ds-cart__items-header-label ds-cart__items-header-label--remove"></span>
        </div>

        <div class="ds-cart__items" role="list">
          {%- for line_item in cart.items -%}
            <div role="listitem">
              {% render 'cart-line-item',
                line_item: line_item,
                show_vendor: show_vendor
              %}
            </div>
          {%- endfor -%}
        </div>

        {%- if show_cart_note -%}
          <div class="ds-cart__note">
            <label for="cart-note" class="ds-cart__note-label">
              Order notes
              <span class="ds-text ds-text--sm ds-text--muted"> (optional)</span>
            </label>
            <textarea
              id="cart-note"
              name="note"
              class="ds-cart__note-textarea"
              rows="3"
              placeholder="Add a note for your order…"
            >{{- cart.note -}}</textarea>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Summary column (5/12) — sticky on desktop {%- endcomment -%}
      <aside class="ds-cart__summary-wrapper" aria-labelledby="cart-summary-heading">
        <div class="ds-cart__summary">
          <h2 id="cart-summary-heading" class="ds-heading ds-heading--xl">Summary</h2>

          <div class="ds-cart__summary-row">
            <span class="ds-text ds-text--base">Subtotal</span>
            <span class="ds-text ds-text--base ds-text--semibold ds-cart__summary-total-amount">
              {{- cart.total_price | money -}}
            </span>
          </div>

          {%- if cart.total_discount > 0 -%}
            <div class="ds-cart__summary-row">
              <span class="ds-text ds-text--sm">Discounts</span>
              <span class="ds-text ds-text--sm ds-cart__summary-total-amount">
                &minus;{{ cart.total_discount | money }}
              </span>
            </div>
          {%- endif -%}

          <hr class="ds-cart__summary-divider">

          <p class="ds-text ds-text--sm ds-cart__summary-note">
            Taxes and shipping calculated at checkout.
          </p>

          <button
            type="submit"
            name="checkout"
            class="ds-button ds-button--primary ds-button--lg ds-cart__checkout"
          >
            Checkout
          </button>
        </div>
      </aside>
    </form>

  {%- endif -%}
</section>

{%- comment -%}
  Progressive enhancement: auto-submit the cart form when the
  quantity number input changes, so manual typing updates the
  line. The +/- submit buttons already work without JavaScript.
{%- endcomment -%}
<script>
  (function () {
    var form = document.getElementById('cart-form');
    if (!form) return;

    form.addEventListener('change', function (event) {
      var target = event.target;
      if (target && target.matches('[data-qty-input]')) {
        form.submit();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Cart",
  "tag": "div",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_cart_note",
      "label": "Show order notes textarea",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor on line items",
      "default": true
    }
  ],
  "presets": [{ "name": "Cart" }]
}
{% endschema %}
