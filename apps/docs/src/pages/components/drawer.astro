---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { DrawerDefault, DrawerLeftSide, DrawerCustomWidth, DrawerScrollable } from '../../components/DrawerGallery';
---

<ComponentPage
  title="Drawer"
  description="A slide-out panel anchored to the left or right edge of the viewport. Built on Radix UI Dialog for focus trapping, scroll locking, and keyboard navigation. Used as a primitive for cart drawers, mobile menus, and filter sidebars."
  installCode={`import { Drawer } from '@ds/components';`}
  accessibility={[
    'Focus is trapped inside the drawer while open',
    'Focus returns to the trigger element when the drawer closes',
    'Escape key closes the drawer',
    'Background content is hidden from screen readers via <code>aria-hidden</code>',
    'Title is rendered as a visually hidden <code>Dialog.Title</code> and exposed via <code>aria-label</code>',
    'The panel has <code>role="dialog"</code> and <code>aria-modal="true"</code>',
    'Body scroll is locked while the drawer is open',
  ]}
>
  <h2>Default</h2>
  <p>Slides in from the right by default. Width defaults to <code>var(--size-content-sm)</code> (640px) on desktop, full-width on mobile.</p>
  <DrawerDefault client:load />
  <pre><code>{`const [open, setOpen] = useState(false);

<Button onClick={() => setOpen(true)}>Open drawer</Button>
<Drawer open={open} onOpenChange={setOpen} title="Default drawer">
  <Heading level={3} size="md">Drawer content</Heading>
  <Text>Panel content goes here.</Text>
</Drawer>`}</code></pre>

  <h2>Left side</h2>
  <p>Use <code>side="left"</code> for navigation menus and filter sidebars.</p>
  <DrawerLeftSide client:load />
  <pre><code>{`<Drawer
  open={open}
  onOpenChange={setOpen}
  side="left"
  title="Navigation menu"
>
  <nav>...</nav>
</Drawer>`}</code></pre>

  <h2>Custom width</h2>
  <p>Pass any CSS value to <code>width</code>. On mobile (&lt;768px), the drawer always becomes full-width regardless of the width prop.</p>
  <DrawerCustomWidth client:load />
  <pre><code>{`<Drawer
  open={open}
  onOpenChange={setOpen}
  width="360px"
  title="Shopping cart"
>
  ...
</Drawer>`}</code></pre>

  <h2>Scrollable content</h2>
  <p>Content taller than the viewport scrolls inside the drawer body. The close button stays fixed.</p>
  <DrawerScrollable client:load />
  <pre><code>{`<Drawer open={open} onOpenChange={setOpen} title="Filter products">
  {/* Long content scrolls automatically */}
  {items.map(item => <FilterOption key={item.id} {...item} />)}
</Drawer>`}</code></pre>
</ComponentPage>
