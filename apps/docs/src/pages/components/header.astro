---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { HeaderDefault, HeaderMinimal } from '../../components/HeaderGallery';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<ComponentPage
  title="Header"
  description="A responsive site header with logo, navigation links, theme toggle, and cart icon. Navigation collapses on mobile. Designed for e-commerce storefronts."
  installCode="import { Header } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>logoSrc</code>', '<code>string</code>', '—', 'Logo image URL'],
        ['<code>logoAlt</code>', '<code>string</code>', "<code>'Home'</code>", 'Logo alt text'],
        ['<code>logoHref</code>', '<code>string</code>', "<code>'/'</code>", 'Logo link destination'],
        ['<code>navItems</code>', '<code>HeaderNavItem[]</code>', '<code>[]</code>', 'Main navigation links'],
        ['<code>cartHref</code>', '<code>string</code>', "<code>'/cart'</code>", 'Cart icon link destination'],
        ['<code>cartCount</code>', '<code>number</code>', '<code>0</code>', 'Number of items in cart'],
        ['<code>showThemeToggle</code>', '<code>boolean</code>', '<code>true</code>', 'Show dark/light theme toggle'],
      ],
    },
    {
      name: 'HeaderNavItem',
      headers: ['Property', 'Type', 'Description'],
      rows: [
        ['<code>label</code>', '<code>string</code>', 'Link text'],
        ['<code>href</code>', '<code>string</code>', 'Link destination'],
      ],
    },
  ]}
  accessibility={[
    'Navigation uses <code>&lt;nav aria-label="Main"&gt;</code> for landmark identification',
    'Logo link has an <code>aria-label</code> for screen readers',
    'Cart icon includes item count in its <code>aria-label</code> (e.g. "Shopping bag (3 items)")',
    'Theme toggle button has <code>aria-label="Toggle dark mode"</code>',
    'All interactive elements have visible focus indicators',
  ]}
>
  <h2>Default</h2>
  <HeaderDefault client:load basePath={base} />
  <pre><code>{`<Header
  logoSrc="/logo.svg"
  logoAlt="Brand Name"
  navItems={[
    { label: 'Shop', href: '/shop' },
    { label: 'Collections', href: '/collections' },
    { label: 'About', href: '/about' },
  ]}
  cartHref="/cart"
  cartCount={3}
/>`}</code></pre>

  <h2>Minimal</h2>
  <p>Logo and cart only, no nav links or theme toggle.</p>
  <HeaderMinimal client:load basePath={base} />
  <pre><code>{`<Header
  logoSrc="/logo.svg"
  logoAlt="Brand Name"
  showThemeToggle={false}
/>`}</code></pre>
</ComponentPage>
