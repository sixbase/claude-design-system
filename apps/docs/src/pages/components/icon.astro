---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { IconDefault, IconSizes, IconColors, IconAccessible, IconInline } from '../../components/IconGallery';
---

<ComponentPage
  title="Icon"
  description="Systematic icon wrapper that standardizes sizing, color inheritance, and accessibility. Library-agnostic — pass any SVG content as children."
  installCode="import { Icon } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>size</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Icon dimensions — sm (16px), md (20px), lg (24px)'],
        ['<code>label</code>', '<code>string</code>', '—', 'Accessible label — required when <code>decorative={false}</code>'],
        ['<code>decorative</code>', '<code>boolean</code>', '<code>true</code>', 'When true, applies <code>aria-hidden="true"</code>'],
        ['<code>children</code>', '<code>ReactNode</code>', '—', 'SVG path elements to render inside the wrapper'],
      ],
    },
  ]}
  accessibility={[
    'Decorative icons (default) use <code>aria-hidden="true"</code> — invisible to assistive tech',
    'Meaningful icons set <code>decorative={false}</code> with a <code>label</code> prop, which renders <code>role="img"</code> and <code>aria-label</code>',
    'Color via <code>currentColor</code> — inherits from parent, respects dark mode automatically',
    'SVG defaults: <code>viewBox="0 0 24 24"</code>, <code>stroke-width="1.5"</code>, <code>fill="none"</code> (compatible with Lucide icon paths)',
  ]}
>
  <h2>Default</h2>
  <p>Pass SVG path elements as children. Icons inherit color from their parent.</p>
  <IconDefault client:load />
  <pre><code>{`<Icon><path d="M20.84 4.61a5.5 5.5 0 ..." /></Icon>
<Icon><polygon points="12 2 15.09 8.26 ..." /></Icon>`}</code></pre>

  <h2>Sizes</h2>
  <p>Three sizes: sm (16px), md (20px, default), lg (24px).</p>
  <IconSizes client:load />
  <pre><code>{`<Icon size="sm">...</Icon>
<Icon size="md">...</Icon>   {/* default */}
<Icon size="lg">...</Icon>`}</code></pre>

  <h2>Color inheritance</h2>
  <p>Icons use <code>currentColor</code> — wrap in a colored parent to change the icon color.</p>
  <IconColors client:load />
  <pre><code>{`<span style={{ color: 'var(--color-success)' }}>
  <Icon><path d="..." /></Icon>
</span>`}</code></pre>

  <h2>Accessible icons</h2>
  <p>For icons that convey meaning, set <code>decorative=&#123;false&#125;</code> and provide a <code>label</code>.</p>
  <IconAccessible client:load />
  <pre><code>{`<Icon decorative={false} label="Favorite">
  <path d="..." />
</Icon>`}</code></pre>

  <h2>Inline with text</h2>
  <p>Icons align naturally with text at each size.</p>
  <IconInline client:load />
  <pre><code>{`<span style={{ display: 'inline-flex', alignItems: 'center', gap: 'var(--spacing-2)' }}>
  <Icon size="sm"><path d="..." /></Icon>
  Add to cart
</span>`}</code></pre>
</ComponentPage>
