{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'alert.css' | asset_url | stylesheet_tag }}

{%- paginate customer.addresses by 6 -%}

<section class="ds-page-container ds-section ds-customer ds-customer--wide" aria-labelledby="CustomerAddressesTitle">
  <div class="ds-customer__inner">
    <header class="ds-customer__header">
      <h1 id="CustomerAddressesTitle" class="ds-heading ds-heading--2xl ds-customer__title">
        {{ section.settings.heading | default: 'Addresses' }}
      </h1>
      <p class="ds-text ds-text--sm ds-customer__subtitle">
        Manage the addresses used for shipping and billing.
      </p>
    </header>

    <div class="ds-customer__block">
      <div class="ds-customer__block-header">
        <h2 class="ds-heading ds-heading--xl">Add a new address</h2>
      </div>

      <div class="ds-customer__panel" id="AddressNew" hidden>
        {%- form 'customer_address', customer.new_address, class: 'ds-customer__form' -%}
          {%- if form.errors -%}
            <div class="ds-customer__alerts">
              <div class="ds-alert ds-alert--destructive" role="alert">
                <div class="ds-alert__content">
                  <p class="ds-text ds-text--sm ds-alert__title">
                    We couldn't save this address.
                  </p>
                  <ul class="ds-text ds-text--sm ds-alert__description">
                    {%- for field in form.errors -%}
                      <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                    {%- endfor -%}
                  </ul>
                </div>
              </div>
            </div>
          {%- endif -%}

          <div class="ds-customer__field-row">
            <div class="ds-input-root">
              <label for="AddressFirstNameNew" class="ds-input-label">First name</label>
              <input type="text" name="address[first_name]" id="AddressFirstNameNew" class="ds-input-field ds-input-field--md" autocomplete="given-name" value="{{ form.first_name }}">
            </div>
            <div class="ds-input-root">
              <label for="AddressLastNameNew" class="ds-input-label">Last name</label>
              <input type="text" name="address[last_name]" id="AddressLastNameNew" class="ds-input-field ds-input-field--md" autocomplete="family-name" value="{{ form.last_name }}">
            </div>
          </div>

          <div class="ds-input-root">
            <label for="AddressCompanyNew" class="ds-input-label">Company</label>
            <input type="text" name="address[company]" id="AddressCompanyNew" class="ds-input-field ds-input-field--md" autocomplete="organization" value="{{ form.company }}">
          </div>

          <div class="ds-input-root">
            <label for="AddressStreet1New" class="ds-input-label ds-input-label--required">Address</label>
            <input type="text" name="address[address1]" id="AddressStreet1New" class="ds-input-field ds-input-field--md" autocomplete="address-line1" value="{{ form.address1 }}" required>
          </div>

          <div class="ds-input-root">
            <label for="AddressStreet2New" class="ds-input-label">Apartment, suite, etc.</label>
            <input type="text" name="address[address2]" id="AddressStreet2New" class="ds-input-field ds-input-field--md" autocomplete="address-line2" value="{{ form.address2 }}">
          </div>

          <div class="ds-customer__field-row">
            <div class="ds-input-root">
              <label for="AddressCityNew" class="ds-input-label ds-input-label--required">City</label>
              <input type="text" name="address[city]" id="AddressCityNew" class="ds-input-field ds-input-field--md" autocomplete="address-level2" value="{{ form.city }}" required>
            </div>
            <div class="ds-input-root">
              <label for="AddressZipNew" class="ds-input-label ds-input-label--required">Postal/ZIP code</label>
              <input type="text" name="address[zip]" id="AddressZipNew" class="ds-input-field ds-input-field--md" autocomplete="postal-code" value="{{ form.zip }}" required>
            </div>
          </div>

          <div class="ds-customer__field-row">
            <div class="ds-input-root">
              <label for="AddressCountryNew" class="ds-input-label ds-input-label--required">Country</label>
              <select name="address[country]" id="AddressCountryNew" class="ds-native-select ds-native-select--md" data-default="{{ form.country }}" required>
                {{ all_country_option_tags }}
              </select>
            </div>
            <div class="ds-input-root" data-province-wrapper>
              <label for="AddressProvinceNew" class="ds-input-label">State/Province</label>
              <select name="address[province]" id="AddressProvinceNew" class="ds-native-select ds-native-select--md" data-default="{{ form.province }}"></select>
            </div>
          </div>

          <div class="ds-input-root">
            <label for="AddressPhoneNew" class="ds-input-label">Phone</label>
            <input type="tel" name="address[phone]" id="AddressPhoneNew" class="ds-input-field ds-input-field--md" autocomplete="tel" value="{{ form.phone }}">
          </div>

          <div class="ds-customer__checkbox-row">
            <input type="checkbox" name="address[default]" id="AddressDefaultNew" value="1">
            <label for="AddressDefaultNew" class="ds-input-label">Set as default address</label>
          </div>

          <div class="ds-customer__actions">
            <div class="ds-customer__address-card__actions">
              <button type="submit" class="ds-button ds-button--primary ds-button--md">Add address</button>
              <button type="button" class="ds-button ds-button--ghost ds-button--md" data-address-cancel="New">Cancel</button>
            </div>
          </div>
        {%- endform -%}
      </div>

      <button type="button" class="ds-button ds-button--secondary ds-button--md" data-address-toggle="New" aria-expanded="false" aria-controls="AddressNew">
        Add a new address
      </button>
    </div>

    <div class="ds-customer__block">
      <div class="ds-customer__block-header">
        <h2 class="ds-heading ds-heading--xl">Your addresses</h2>
      </div>

      {%- if customer.addresses.size > 0 -%}
        <div class="ds-customer__address-grid">
          {%- for address in customer.addresses -%}
            <article class="ds-customer__address-card{% if address == customer.default_address %} ds-customer__address-card--default{% endif %}">
              {%- if address == customer.default_address -%}
                <span class="ds-badge ds-badge--sm ds-badge--success" aria-label="Default address">Default</span>
              {%- endif -%}

              <address class="ds-customer__address-card__body">
                {{ address | format_address }}
              </address>

              <div class="ds-customer__address-card__actions">
                <button type="button" class="ds-button ds-button--secondary ds-button--sm" data-address-toggle="{{ address.id }}" aria-expanded="false" aria-controls="Address{{ address.id }}">
                  Edit
                </button>
                {%- form 'customer_address', address -%}
                  <input type="hidden" name="_method" value="delete">
                  <button type="submit" class="ds-button ds-button--ghost ds-button--sm" data-confirm-message="Are you sure you want to delete this address?">
                    Delete
                  </button>
                {%- endform -%}
              </div>

              <div class="ds-customer__panel" id="Address{{ address.id }}" hidden>
                {%- form 'customer_address', address, class: 'ds-customer__form' -%}
                  <div class="ds-customer__field-row">
                    <div class="ds-input-root">
                      <label for="AddressFirstName{{ address.id }}" class="ds-input-label">First name</label>
                      <input type="text" name="address[first_name]" id="AddressFirstName{{ address.id }}" class="ds-input-field ds-input-field--md" autocomplete="given-name" value="{{ address.first_name }}">
                    </div>
                    <div class="ds-input-root">
                      <label for="AddressLastName{{ address.id }}" class="ds-input-label">Last name</label>
                      <input type="text" name="address[last_name]" id="AddressLastName{{ address.id }}" class="ds-input-field ds-input-field--md" autocomplete="family-name" value="{{ address.last_name }}">
                    </div>
                  </div>

                  <div class="ds-input-root">
                    <label for="AddressCompany{{ address.id }}" class="ds-input-label">Company</label>
                    <input type="text" name="address[company]" id="AddressCompany{{ address.id }}" class="ds-input-field ds-input-field--md" autocomplete="organization" value="{{ address.company }}">
                  </div>

                  <div class="ds-input-root">
                    <label for="AddressStreet1{{ address.id }}" class="ds-input-label ds-input-label--required">Address</label>
                    <input type="text" name="address[address1]" id="AddressStreet1{{ address.id }}" class="ds-input-field ds-input-field--md" autocomplete="address-line1" value="{{ address.address1 }}" required>
                  </div>

                  <div class="ds-input-root">
                    <label for="AddressStreet2{{ address.id }}" class="ds-input-label">Apartment, suite, etc.</label>
                    <input type="text" name="address[address2]" id="AddressStreet2{{ address.id }}" class="ds-input-field ds-input-field--md" autocomplete="address-line2" value="{{ address.address2 }}">
                  </div>

                  <div class="ds-customer__field-row">
                    <div class="ds-input-root">
                      <label for="AddressCity{{ address.id }}" class="ds-input-label ds-input-label--required">City</label>
                      <input type="text" name="address[city]" id="AddressCity{{ address.id }}" class="ds-input-field ds-input-field--md" autocomplete="address-level2" value="{{ address.city }}" required>
                    </div>
                    <div class="ds-input-root">
                      <label for="AddressZip{{ address.id }}" class="ds-input-label ds-input-label--required">Postal/ZIP code</label>
                      <input type="text" name="address[zip]" id="AddressZip{{ address.id }}" class="ds-input-field ds-input-field--md" autocomplete="postal-code" value="{{ address.zip }}" required>
                    </div>
                  </div>

                  <div class="ds-customer__field-row">
                    <div class="ds-input-root">
                      <label for="AddressCountry{{ address.id }}" class="ds-input-label ds-input-label--required">Country</label>
                      <select name="address[country]" id="AddressCountry{{ address.id }}" class="ds-native-select ds-native-select--md" data-default="{{ address.country }}" required>
                        {{ all_country_option_tags }}
                      </select>
                    </div>
                    <div class="ds-input-root" data-province-wrapper>
                      <label for="AddressProvince{{ address.id }}" class="ds-input-label">State/Province</label>
                      <select name="address[province]" id="AddressProvince{{ address.id }}" class="ds-native-select ds-native-select--md" data-default="{{ address.province }}"></select>
                    </div>
                  </div>

                  <div class="ds-input-root">
                    <label for="AddressPhone{{ address.id }}" class="ds-input-label">Phone</label>
                    <input type="tel" name="address[phone]" id="AddressPhone{{ address.id }}" class="ds-input-field ds-input-field--md" autocomplete="tel" value="{{ address.phone }}">
                  </div>

                  <div class="ds-customer__checkbox-row">
                    <input type="checkbox" name="address[default]" id="AddressDefault{{ address.id }}" value="1" {% if address == customer.default_address %}checked{% endif %}>
                    <label for="AddressDefault{{ address.id }}" class="ds-input-label">Set as default address</label>
                  </div>

                  <div class="ds-customer__address-card__actions">
                    <button type="submit" class="ds-button ds-button--primary ds-button--md">Update</button>
                    <button type="button" class="ds-button ds-button--ghost ds-button--md" data-address-cancel="{{ address.id }}">Cancel</button>
                  </div>
                {%- endform -%}
              </div>
            </article>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="ds-customer__pagination" aria-label="Addresses pagination">
            {%- if paginate.previous -%}
              <a class="ds-button ds-button--secondary ds-button--sm" href="{{ paginate.previous.url }}" rel="prev">Previous</a>
            {%- else -%}
              <span class="ds-customer__pagination__spacer"></span>
            {%- endif -%}

            <span class="ds-text ds-text--sm ds-text--muted">
              Page {{ paginate.current_page }} of {{ paginate.pages }}
            </span>

            {%- if paginate.next -%}
              <a class="ds-button ds-button--secondary ds-button--sm" href="{{ paginate.next.url }}" rel="next">Next</a>
            {%- else -%}
              <span class="ds-customer__pagination__spacer"></span>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="ds-customer__empty">
          <p class="ds-text ds-text--sm">You don't have any saved addresses yet.</p>
        </div>
      {%- endif -%}
    </div>

    <div class="ds-customer__actions">
      <a class="ds-text ds-text--sm ds-customer__link" href="{{ routes.account_url }}">
        Back to account
      </a>
    </div>
  </div>
</section>

{%- endpaginate -%}

<script>
  (function () {
    // Toggle address edit/create panels.
    var toggles = document.querySelectorAll('[data-address-toggle]');
    toggles.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('data-address-toggle');
        var panel = document.getElementById('Address' + id);
        if (!panel) return;
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', (!expanded).toString());
        panel.hidden = expanded;
      });
    });

    var cancels = document.querySelectorAll('[data-address-cancel]');
    cancels.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('data-address-cancel');
        var panel = document.getElementById('Address' + id);
        var toggle = document.querySelector('[data-address-toggle="' + id + '"]');
        if (panel) panel.hidden = true;
        if (toggle) toggle.setAttribute('aria-expanded', 'false');
      });
    });

    // Delete confirmation.
    var deletes = document.querySelectorAll('[data-confirm-message]');
    deletes.forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        var msg = btn.getAttribute('data-confirm-message');
        if (!confirm(msg)) e.preventDefault();
      });
    });

    // Populate province dropdown from Shopify's built-in countries provider.
    if (window.Shopify && Shopify.CountryProvinceSelector) {
      var countrySelects = document.querySelectorAll('select[name="address[country]"]');
      countrySelects.forEach(function (country) {
        var wrapper = country.closest('.ds-customer__field-row');
        if (!wrapper) return;
        var province = wrapper.querySelector('select[name="address[province]"]');
        var provinceWrapper = province ? province.closest('[data-province-wrapper]') : null;
        if (!province || !provinceWrapper) return;
        new Shopify.CountryProvinceSelector(country.id, province.id, {
          hideElement: provinceWrapper.id || null,
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Addresses",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Addresses"
    }
  ],
  "presets": [{ "name": "Addresses" }]
}
{% endschema %}
