---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tokens from '../../../../../packages/tokens/src/tokens.json';
import '../../styles/token-docs.css';

const { font } = tokens.primitive;
---

<BaseLayout title="Typography">
  <div class="prose">
    <h1>Typography</h1>
    <p>
      All type values live in <code>tokens.json</code> and are available as CSS variables.
      Never hardcode font sizes or weights — always use a token.
    </p>

    <h2>Font families</h2>
    <div class="token-table">
      {Object.entries(font.family).map(([name, value]) => (
        <div class="token-row">
          <span class="token-name"><code>--font-family-{name}</code></span>
          <span class="token-preview" style={`font-family: ${value}; font-size: 1rem;`}>
            The quick brown fox
          </span>
          <span class="token-value">{value}</span>
        </div>
      ))}
    </div>

    <h2>Font sizes</h2>
    <p>
      Three scales, each using a different fractional power of φ as the step multiplier.
      They are <strong>not</strong> for different screen sizes — they are for different <strong>contexts of use</strong>.
      Default for product UI. Tight for dense data surfaces. Display for editorial moments.
    </p>

    <h3>Default scale <span class="scale-badge scale-badge--primary">Use this</span></h3>
    <p class="scale-desc">
      Step ratio: √φ ≈ 1.272. The scale every component in this system uses.
      If you're building product UI — buttons, forms, cards, navigation, modals — you're always on this scale.
      When in doubt, use <code>sm</code> for labels and <code>base</code> for body copy.
    </p>
    <div class="token-table token-table--annotated">
      <div class="token-row">
        <span class="token-name"><code>--font-size-xs</code> <span class="token-size-info">0.75rem / 12px</span><span class="token-usage">Helper text, input hints, timestamps, tag labels, table footnotes</span></span>
        <span class="token-preview" style="font-size: 0.75rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-sm</code> <span class="token-size-info">0.875rem / 14px</span><span class="token-usage">Button labels, form labels, nav items, table cells, badge text — the default for most interactive components</span></span>
        <span class="token-preview" style="font-size: 0.875rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-base</code> <span class="token-size-info">1rem / 16px</span><span class="token-usage">Body copy, card descriptions, modal content, paragraph text</span></span>
        <span class="token-preview" style="font-size: 1rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-lg</code> <span class="token-size-info">1.25rem / 20px</span><span class="token-usage">Section intros, emphasized body copy, large card titles, dialog titles</span></span>
        <span class="token-preview" style="font-size: 1.25rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-xl</code> <span class="token-size-info">1.625rem / 26px</span><span class="token-usage">h3-level section headings, page panel titles, feature card headlines</span></span>
        <span class="token-preview" style="font-size: 1.625rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-2xl</code> <span class="token-size-info">2.0625rem / 33px</span><span class="token-usage">h2-level page section headings, major content dividers</span></span>
        <span class="token-preview" style="font-size: 2.0625rem; line-height: 1.3;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-3xl</code> <span class="token-size-info">2.625rem / 42px</span><span class="token-usage">h1-level page titles, primary heading for a route or screen</span></span>
        <span class="token-preview" style="font-size: 2.625rem; line-height: 1.2;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-4xl</code> <span class="token-size-info">3.375rem / 54px</span><span class="token-usage">Hero subheadings, large feature section titles, checkout confirmation headings</span></span>
        <span class="token-preview" style="font-size: 3.375rem; line-height: 1.1;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-5xl</code> <span class="token-size-info">4.25rem / 68px</span><span class="token-usage">Large hero text within product context — storefront category hero, campaign banner within the app shell</span></span>
        <span class="token-preview" style="font-size: 4.25rem; line-height: 1.1;">Aa</span>
      </div>
    </div>

    <h3>Tight scale <span class="scale-badge scale-badge--secondary">Dense UI only</span></h3>
    <p class="scale-desc">
      Step ratio: φ^(1/3) ≈ 1.175. Steps are closer together — you can stack multiple sizes in a small vertical space without jarring jumps.
      Use this scale when you have a lot of text competing for space: order detail panels, analytics dashboards, data tables, admin interfaces.
      <strong>Do not mix tight and default scale sizes in the same text block.</strong>
    </p>
    <div class="token-table token-table--annotated">
      <div class="token-row">
        <span class="token-name"><code>--font-size-tight-2xs</code> <span class="token-size-info">0.625rem / 10px</span><span class="token-usage">Chart axis labels, table footnotes, micro-metadata in constrained cells</span></span>
        <span class="token-preview" style="font-size: 0.625rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-tight-xs</code> <span class="token-size-info">0.75rem / 12px</span><span class="token-usage">Status badges in dense lists, tag labels, secondary metadata</span></span>
        <span class="token-preview" style="font-size: 0.75rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-tight-sm</code> <span class="token-size-info">0.875rem / 14px</span><span class="token-usage">Table cell body text, sidebar navigation, dense form field text</span></span>
        <span class="token-preview" style="font-size: 0.875rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-tight-base</code> <span class="token-size-info">1rem / 16px</span><span class="token-usage">Table column headers, dense panel section labels</span></span>
        <span class="token-preview" style="font-size: 1rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-tight-lg</code> <span class="token-size-info">1.1875rem / 19px</span><span class="token-usage">Section headings within data panels, filter group labels</span></span>
        <span class="token-preview" style="font-size: 1.1875rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-tight-xl</code> <span class="token-size-info">1.375rem / 22px</span><span class="token-usage">Dashboard card and panel titles, drawer headings in dense interfaces</span></span>
        <span class="token-preview" style="font-size: 1.375rem; line-height: 1.4;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-tight-2xl</code> <span class="token-size-info">1.625rem / 26px</span><span class="token-usage">Key metric values, data callouts — order totals, inventory counts</span></span>
        <span class="token-preview" style="font-size: 1.625rem; line-height: 1.3;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-tight-3xl</code> <span class="token-size-info">1.875rem / 30px</span><span class="token-usage">KPI numbers in dashboards, prominent stats in analytics views</span></span>
        <span class="token-preview" style="font-size: 1.875rem; line-height: 1.2;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-tight-4xl</code> <span class="token-size-info">2.25rem / 36px</span><span class="token-usage">Large single-metric displays — today's revenue, live visitor count</span></span>
        <span class="token-preview" style="font-size: 2.25rem; line-height: 1.1;">Aa</span>
      </div>
    </div>

    <h3>Display scale <span class="scale-badge scale-badge--muted">Editorial / optional</span></h3>
    <p class="scale-desc">
      Step ratio: φ ≈ 1.618 — the full golden ratio. Each step is dramatically larger than the last.
      Use only for marketing pages, campaign landing pages, and editorial content where type <em>is</em> the design.
      None of the product components in this system use the display scale.
      If you're building within the app shell, you almost certainly don't need this.
    </p>
    <div class="token-table token-table--annotated token-table--muted">
      <div class="token-row">
        <span class="token-name"><code>--font-size-display-xs</code> <span class="token-size-info">0.625rem / 10px</span><span class="token-usage">Eyebrow / overline text above a large editorial heading — typically uppercase with wide letter-spacing</span></span>
        <span class="token-preview" style="font-size: 0.625rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-display-sm</code> <span class="token-size-info">1rem / 16px</span><span class="token-usage">Subheadings and pull-quote captions within editorial layouts</span></span>
        <span class="token-preview" style="font-size: 1rem; line-height: 1.5;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-display-md</code> <span class="token-size-info">1.625rem / 26px</span><span class="token-usage">Section headings on marketing and landing pages</span></span>
        <span class="token-preview" style="font-size: 1.625rem; line-height: 1.4;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-display-lg</code> <span class="token-size-info">2.625rem / 42px</span><span class="token-usage">Page hero subheadings, campaign section titles paired with a larger headline</span></span>
        <span class="token-preview" style="font-size: 2.625rem; line-height: 1.2;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-display-xl</code> <span class="token-size-info">4.25rem / 68px</span><span class="token-usage">Primary hero headline on a marketing page or campaign landing</span></span>
        <span class="token-preview" style="font-size: 4.25rem; line-height: 1.1;">Aa</span>
      </div>
      <div class="token-row">
        <span class="token-name"><code>--font-size-display-2xl</code> <span class="token-size-info">6.875rem / 110px</span><span class="token-usage">Full-screen hero text — a single word or short phrase at maximum visual impact</span></span>
        <span class="token-preview" style="font-size: 6.875rem; line-height: 1.0;">Aa</span>
      </div>
    </div>

    <h2>Font weights</h2>
    <div class="token-table">
      {Object.entries(font.weight).map(([name, value]) => (
        <div class="token-row">
          <span class="token-name"><code>--font-weight-{name}</code></span>
          <span class="token-preview" style={`font-weight: ${value}; font-size: 1rem;`}>
            Design System
          </span>
          <span class="token-value">{value}</span>
        </div>
      ))}
    </div>

    <h2>Line heights</h2>
    <div class="token-table">
      {Object.entries(font.lineHeight).map(([name, value]) => (
        <div class="token-row">
          <span class="token-name"><code>--line-height-{name}</code></span>
          <span class="token-preview" style={`line-height: ${value}; font-size: 0.875rem;`}>
            The quick brown fox jumps<br />over the lazy dog nearby
          </span>
          <span class="token-value">{value}</span>
        </div>
      ))}
    </div>

    <h2>Letter spacing</h2>
    <div class="token-table">
      {Object.entries(font.letterSpacing).map(([name, value]) => (
        <div class="token-row">
          <span class="token-name"><code>--letter-spacing-{name}</code></span>
          <span class="token-preview" style={`letter-spacing: ${value}; font-size: 1.25rem;`}>
            Design System
          </span>
          <span class="token-value">{value}</span>
        </div>
      ))}
    </div>

    <h2>Semantic mapping</h2>
    <p>How the typography components combine these tokens. Use this table when building custom text styles outside the components.</p>
    <table class="mapping-table">
      <thead>
        <tr>
          <th>Element</th>
          <th>Size</th>
          <th>Weight</th>
          <th>Line height</th>
          <th>Letter spacing</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Heading h1</td>
          <td><code>4xl</code> / 54px</td>
          <td><code>semibold</code></td>
          <td><code>tight</code> / 1.15</td>
          <td><code>tight</code> / -0.025em</td>
        </tr>
        <tr>
          <td>Heading h2</td>
          <td><code>3xl</code> / 42px</td>
          <td><code>semibold</code></td>
          <td><code>tight</code> / 1.15</td>
          <td><code>tight</code> / -0.025em</td>
        </tr>
        <tr>
          <td>Heading h3</td>
          <td><code>2xl</code> / 33px</td>
          <td><code>semibold</code></td>
          <td><code>tight</code> / 1.15</td>
          <td><code>tight</code> / -0.025em</td>
        </tr>
        <tr>
          <td>Heading h4</td>
          <td><code>xl</code> / 26px</td>
          <td><code>semibold</code></td>
          <td><code>tight</code> / 1.15</td>
          <td><code>tight</code> / -0.025em</td>
        </tr>
        <tr>
          <td>Text lg</td>
          <td><code>lg</code> / 20px</td>
          <td><code>normal</code></td>
          <td><code>snug</code> / 1.375</td>
          <td>—</td>
        </tr>
        <tr>
          <td>Text base</td>
          <td><code>base</code> / 16px</td>
          <td><code>normal</code></td>
          <td><code>snug</code> / 1.375</td>
          <td>—</td>
        </tr>
        <tr>
          <td>Text sm</td>
          <td><code>sm</code> / 14px</td>
          <td><code>normal</code></td>
          <td><code>normal</code> / 1.5</td>
          <td>—</td>
        </tr>
        <tr>
          <td>Caption</td>
          <td><code>xs</code> / 12px</td>
          <td><code>normal</code></td>
          <td><code>normal</code> / 1.5</td>
          <td>—</td>
        </tr>
        <tr>
          <td>Code</td>
          <td>0.9em (relative)</td>
          <td><code>normal</code></td>
          <td>inherited</td>
          <td>—</td>
        </tr>
      </tbody>
    </table>
  </div>
</BaseLayout>

<style>
  /* ─── Typography-specific: grid layout for token rows ─── */
  .token-table {
    margin: var(--spacing-4) 0 var(--spacing-8);
  }

  .token-row {
    display: grid;
    grid-template-columns: 220px 1fr 120px;
    align-items: center;
    gap: var(--spacing-4);
  }

  .token-table--annotated .token-row {
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--spacing-3);
  }

  .token-table--annotated .token-name code {
    display: inline;
  }

  .token-table--annotated .token-value {
    display: none;
  }

  .token-row--header {
    background: var(--color-background-subtle);
    align-items: center;
  }

  .token-row--header span {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    color: var(--color-foreground-subtle);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
  }

  .token-row--header .token-value {
    text-align: right;
  }

  .token-table--two-col .token-row {
    grid-template-columns: 1fr auto;
  }

  .token-px {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-foreground-muted);
    margin-top: 2px;
  }

  /* ─── Semantic mapping table ─────────────────────────── */
  .mapping-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
    margin: var(--spacing-4) 0 var(--spacing-8);
    background-color: var(--color-background-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .mapping-table th {
    text-align: left;
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 2px solid var(--color-border);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-xs);
    color: var(--color-foreground);
  }
  .mapping-table td {
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-foreground-subtle);
  }
  .mapping-table tr:last-child td {
    border-bottom: none;
  }
  .mapping-table code {
    font-size: var(--font-size-xs);
    background: none;
    border: none;
    padding: 0;
    color: var(--color-foreground);
  }
</style>
