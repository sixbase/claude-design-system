---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { ProductCardSingle, ProductCardLarge, ProductCardWithBadge, ProductCardWithRenderPrice, ProductCardWithHoverImage, ProductCardGrid } from '../../components/ProductCardGallery';
---

<ComponentPage
  title="Product Card"
  description="A minimal product card composing <code>Card</code>, <code>CardImage</code>, and <code>Typography</code>. Displays a 4:5 product image, name, and formatted price. Supports badge overlays, custom price rendering, and secondary hover images."
  installCode="import { ProductCard } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>name</code>', '<code>string</code>', '—', 'Product display name'],
        ['<code>price</code>', '<code>number</code>', '—', 'Price in cents (e.g. 3200 = $32.00)'],
        ['<code>image</code>', '<code>string</code>', '—', 'Product image URL'],
        ['<code>currency</code>', '<code>string</code>', "<code>'USD'</code>", 'ISO 4217 currency code'],
        ['<code>size</code>', "<code>'default' | 'lg'</code>", "<code>'default'</code>", 'Card size variant'],
        ['<code>fluid</code>', '<code>boolean</code>', '<code>false</code>', 'Fill parent width (use inside CSS Grid layouts)'],
        ['<code>badge</code>', '<code>ReactNode</code>', '—', 'Badge or label overlay positioned over the image'],
        ['<code>renderPrice</code>', '<code>(price, currency) =&gt; ReactNode</code>', '—', 'Custom price renderer — overrides the default formatted price'],
        ['<code>hoverImage</code>', '<code>string</code>', '—', 'Secondary image URL shown on hover'],
      ],
    },
  ]}
  accessibility={[
    'Image <code>alt</code> text is derived from the product <code>name</code>',
    'Hover image uses <code>aria-hidden="true"</code> (decorative)',
    'Inherits interactive hover behavior from <code>Card</code>',
    'Hover effects respect <code>prefers-reduced-motion</code>',
  ]}
>
  <h2>Single card</h2>
  <ProductCardSingle client:load />
  <pre><code>{`<ProductCard
  name="Aramid Fiber iPhone 17 Pro Max Case"
  price={8500}
  image="/products/phone-case.jpg"
/>`}</code></pre>

  <h2>Large card</h2>
  <ProductCardLarge client:load />
  <pre><code>{`<ProductCard
  name="Aramid Fiber iPhone 17 Pro Max Case"
  price={8500}
  image="/products/phone-case.jpg"
  size="lg"
/>`}</code></pre>

  <h2>With badge</h2>
  <p>
    Use the <code>badge</code> prop to position a label over the image — ideal for sale tags, "New" indicators, or stock badges.
  </p>
  <ProductCardWithBadge client:load />
  <pre><code>{`<ProductCard
  name="Aramid Fiber iPhone 17 Pro Max Case"
  price={8500}
  image="/products/phone-case.jpg"
  badge={<Badge variant="destructive" size="sm">Sale</Badge>}
/>`}</code></pre>

  <h2>Custom price</h2>
  <p>
    Use <code>renderPrice</code> with the <code>PriceDisplay</code> component to show strikethrough compare-at pricing.
  </p>
  <ProductCardWithRenderPrice client:load />
  <pre><code>{`<ProductCard
  name="Aramid Fiber iPhone 17 Pro Max Case"
  price={6800}
  image="/products/phone-case.jpg"
  badge={<Badge variant="destructive" size="sm">20% Off</Badge>}
  renderPrice={(price, currency) => (
    <PriceDisplay
      price={\`$\${(price / 100).toFixed(2)}\`}
      comparePrice="$85.00"
      size="sm"
    />
  )}
/>`}</code></pre>

  <h2>Hover image</h2>
  <p>
    Provide a <code>hoverImage</code> to swap to a secondary product shot on hover — useful for showing lifestyle vs product photography.
  </p>
  <ProductCardWithHoverImage client:load />
  <pre><code>{`<ProductCard
  name="Aramid Fiber iPhone 17 Pro Max Case"
  price={8500}
  image="/products/front.jpg"
  hoverImage="/products/lifestyle.jpg"
/>`}</code></pre>

  <h2>Product grid</h2>
  <p>
    Place cards in a CSS Grid for product listings. The card fills the column width automatically.
  </p>
  <ProductCardGrid client:load />
  <pre><code>{`<Grid cols={4}>
  {products.map((p) => (
    <ProductCard key={p.name} {...p} fluid />
  ))}
</Grid>`}</code></pre>
</ComponentPage>
