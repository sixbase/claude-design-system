{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'alert.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Two states:
  - Request: user enters email to receive a reset link.
    (template/customers/reset_password.json)
  - Reset: user arrived via emailed link (has reset token), enters new password.
    Shopify exposes this via `form 'reset_customer_password'` on the same route.
  We detect the reset state using the `reset_password_token` param Shopify renders
  in the form action; practically, a customer object is available on the reset URL.
{%- endcomment -%}

<section class="ds-page-container ds-section ds-customer ds-customer--narrow" aria-labelledby="CustomerResetTitle">
  <div class="ds-customer__inner">

    {%- if customer -%}
      {%- comment -%} Reset state — came from email link {%- endcomment -%}
      <header class="ds-customer__header">
        <h1 id="CustomerResetTitle" class="ds-heading ds-heading--2xl ds-customer__title">
          {{ section.settings.heading_reset | default: 'Reset your password' }}
        </h1>
        <p class="ds-text ds-text--sm ds-customer__subtitle">
          Choose a new password for your account.
        </p>
      </header>

      {%- form 'reset_customer_password', class: 'ds-customer__form', novalidate: 'novalidate' -%}
        {%- if form.errors -%}
          <div class="ds-customer__alerts">
            <div class="ds-alert ds-alert--destructive" role="alert">
              <div class="ds-alert__content">
                <p class="ds-text ds-text--sm ds-alert__title">
                  We couldn't reset your password.
                </p>
                <ul class="ds-text ds-text--sm ds-alert__description">
                  {%- for field in form.errors -%}
                    <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                  {%- endfor -%}
                </ul>
              </div>
            </div>
          </div>
        {%- endif -%}

        <div class="ds-input-root">
          <label for="CustomerResetPassword" class="ds-input-label ds-input-label--required">
            New password
          </label>
          <input
            type="password"
            name="customer[password]"
            id="CustomerResetPassword"
            class="ds-input-field ds-input-field--md"
            autocomplete="new-password"
            minlength="5"
            required
          >
          <span class="ds-input-hint">
            At least 5 characters.
          </span>
        </div>

        <div class="ds-input-root">
          <label for="CustomerResetPasswordConfirm" class="ds-input-label ds-input-label--required">
            Confirm password
          </label>
          <input
            type="password"
            name="customer[password_confirmation]"
            id="CustomerResetPasswordConfirm"
            class="ds-input-field ds-input-field--md"
            autocomplete="new-password"
            minlength="5"
            required
          >
        </div>

        <div class="ds-customer__actions">
          <button type="submit" class="ds-button ds-button--primary ds-button--md ds-button--full-width">
            Reset password
          </button>
        </div>
      {%- endform -%}

    {%- else -%}
      {%- comment -%} Request state — enter email for reset link {%- endcomment -%}
      <header class="ds-customer__header">
        <h1 id="CustomerResetTitle" class="ds-heading ds-heading--2xl ds-customer__title">
          {{ section.settings.heading_request | default: 'Forgot your password?' }}
        </h1>
        <p class="ds-text ds-text--sm ds-customer__subtitle">
          Enter your email and we'll send you a reset link.
        </p>
      </header>

      {%- form 'recover_customer_password', class: 'ds-customer__form', novalidate: 'novalidate' -%}
        {%- if form.posted_successfully? -%}
          <div class="ds-customer__alerts">
            <div class="ds-alert ds-alert--success" role="status">
              <div class="ds-alert__content">
                <p class="ds-text ds-text--sm ds-alert__title">
                  Check your email.
                </p>
                <p class="ds-text ds-text--sm ds-alert__description">
                  We've sent you a link to reset your password.
                </p>
              </div>
            </div>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="ds-customer__alerts">
            <div class="ds-alert ds-alert--destructive" role="alert">
              <div class="ds-alert__content">
                <p class="ds-text ds-text--sm ds-alert__title">
                  We couldn't send the reset link.
                </p>
                <ul class="ds-text ds-text--sm ds-alert__description">
                  {%- for field in form.errors -%}
                    <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                  {%- endfor -%}
                </ul>
              </div>
            </div>
          </div>
        {%- endif -%}

        <div class="ds-input-root">
          <label for="CustomerRecoverEmail" class="ds-input-label ds-input-label--required">
            Email
          </label>
          <input
            type="email"
            name="email"
            id="CustomerRecoverEmail"
            class="ds-input-field ds-input-field--md"
            autocomplete="email"
            autocapitalize="off"
            autocorrect="off"
            spellcheck="false"
            required
          >
        </div>

        <div class="ds-customer__actions">
          <button type="submit" class="ds-button ds-button--primary ds-button--md ds-button--full-width">
            Send reset link
          </button>
        </div>

        <div class="ds-customer__meta">
          <a class="ds-text ds-text--sm ds-customer__link" href="{{ routes.account_login_url }}">
            Back to sign in
          </a>
        </div>
      {%- endform -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Reset password",
  "settings": [
    {
      "type": "text",
      "id": "heading_request",
      "label": "Heading (request state)",
      "default": "Forgot your password?"
    },
    {
      "type": "text",
      "id": "heading_reset",
      "label": "Heading (reset state)",
      "default": "Reset your password"
    }
  ],
  "presets": [{ "name": "Reset password" }]
}
{% endschema %}
