---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { InputStates } from '../../components/InputGallery';
---

<BaseLayout title="Input">
  <div class="prose">
    <h1>Input</h1>
    <p>
      A text field with a built-in label, helper text, and error state.
      It's accessible out of the box — the label is always linked to the field,
      and error messages are announced to screen readers automatically.
    </p>

    <h2>Installation</h2>
    <pre><code>{`import { Input } from '@ds/components';`}</code></pre>

    <h2>All states</h2>
    <InputStates client:load />

    <h2>Default</h2>
    <pre><code>{`<Input label="Email address" type="email" placeholder="you@example.com" />`}</code></pre>

    <h2>With helper text</h2>
    <p>Use <code>hint</code> to show guidance below the field.</p>
    <pre><code>{`<Input label="Password" type="password" hint="Must be at least 8 characters" />`}</code></pre>

    <h2>Error state</h2>
    <p>Pass <code>error</code> to show a red message and highlight the border. The message is read aloud by screen readers.</p>
    <pre><code>{`<Input label="Email" error="Please enter a valid email address" />`}</code></pre>

    <h2>Required</h2>
    <pre><code>{`<Input label="Full name" required />`}</code></pre>

    <h2>Disabled</h2>
    <pre><code>{`<Input label="Username" defaultValue="jane_smith" disabled />`}</code></pre>

    <h2>With icon</h2>
    <pre><code>{`<Input
  placeholder="Search..."
  leadingAdornment={<SearchIcon />}
/>`}</code></pre>

    <h2>Props</h2>
    <table class="props-table">
      <thead>
        <tr><th>Prop</th><th>Type</th><th>Default</th><th>What it does</th></tr>
      </thead>
      <tbody>
        <tr><td><code>label</code></td><td><code>string</code></td><td>—</td><td>Visible label above the field</td></tr>
        <tr><td><code>hint</code></td><td><code>string</code></td><td>—</td><td>Helper text below the field</td></tr>
        <tr><td><code>error</code></td><td><code>string</code></td><td>—</td><td>Error message — turns border red, hides hint</td></tr>
        <tr><td><code>disabled</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Grays out the field, blocks typing</td></tr>
        <tr><td><code>required</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Adds * to label, marks field as required</td></tr>
        <tr><td><code>leadingAdornment</code></td><td><code>ReactNode</code></td><td>—</td><td>Icon or element before the text</td></tr>
        <tr><td><code>trailingAdornment</code></td><td><code>ReactNode</code></td><td>—</td><td>Icon or element after the text</td></tr>
      </tbody>
    </table>

    <h2>Accessibility</h2>
    <ul>
      <li>Label is always linked to the input — never use a placeholder as a label substitute</li>
      <li>Error messages use <code>role="alert"</code> so screen readers announce them immediately</li>
      <li>Hint and error are wired up via <code>aria-describedby</code> automatically</li>
    </ul>
  </div>
</BaseLayout>

<style>
  .props-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
    margin: var(--spacing-4) 0;
    background-color: var(--color-background-surface);
    border: 1px solid var(--color-border);
  }
  .props-table th {
    text-align: left;
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 2px solid var(--color-border);
    font-weight: var(--font-weight-semibold);
  }
  .props-table td {
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-foreground-subtle);
    vertical-align: top;
  }
</style>
