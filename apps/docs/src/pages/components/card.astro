---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CardVariants, CardProduct } from '../../components/CardGallery';
---

<BaseLayout title="Card">
  <div class="prose">
    <h1>Card</h1>
    <p>
      A surface for grouping related content. Compound component — compose
      <code>CardImage</code>, <code>CardBody</code>, and <code>CardFooter</code> as needed.
      The <code>interactive</code> prop adds hover lift and image zoom for clickable cards.
    </p>

    <h2>Installation</h2>
    <pre><code>{`import { Card, CardImage, CardBody, CardFooter } from '@ds/components';`}</code></pre>

    <h2>Variants</h2>
    <CardVariants client:load />
    <pre><code>{`<Card variant="elevated">...</Card>   {/* default — border + subtle shadow */}
<Card variant="outlined">...</Card>   {/* border only, no shadow */}
<Card variant="ghost">...</Card>      {/* subtle background fill */}`}</code></pre>

    <h2>Product card</h2>
    <p>
      Add <code>interactive</code> for clickable cards. The image zooms on hover and the card
      lifts slightly. Combine with <code>Badge</code> and <code>Button</code>.
    </p>
    <CardProduct client:load />
    <pre><code>{`<Card variant="elevated" interactive>
  <CardImage src="/product.jpg" alt="Product name" aspectRatio="4/3" />
  <CardBody>
    <div style={{ display: 'flex', justifyContent: 'space-between' }}>
      <strong>Minimalist Watch</strong>
      <Badge variant="default" size="sm">New</Badge>
    </div>
    <p>$249</p>
  </CardBody>
  <CardFooter>
    <Button size="sm" fullWidth>Add to cart</Button>
  </CardFooter>
</Card>`}</code></pre>

    <h2>Props — Card</h2>
    <table class="props-table">
      <thead>
        <tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>variant</code></td><td><code>'elevated' | 'outlined' | 'ghost'</code></td><td><code>'elevated'</code></td><td>Visual style</td></tr>
        <tr><td><code>interactive</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Hover lift + image zoom</td></tr>
      </tbody>
    </table>

    <h2>Props — CardImage</h2>
    <table class="props-table">
      <thead>
        <tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>src</code></td><td><code>string</code></td><td>—</td><td>Image URL</td></tr>
        <tr><td><code>alt</code></td><td><code>string</code></td><td>—</td><td>Alt text (required)</td></tr>
        <tr><td><code>aspectRatio</code></td><td><code>string</code></td><td><code>'4/3'</code></td><td>CSS aspect-ratio value</td></tr>
      </tbody>
    </table>

    <h2>Accessibility</h2>
    <ul>
      <li>Interactive cards should be wrapped in <code>&lt;a&gt;</code> or use <code>onClick</code> — the card itself doesn't add interactivity semantics</li>
      <li><code>CardImage</code> requires a meaningful <code>alt</code> attribute</li>
      <li>Hover effects respect <code>prefers-reduced-motion</code></li>
    </ul>
  </div>
</BaseLayout>

<style>
  .props-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
    margin: var(--spacing-4) 0;
    background-color: var(--color-background-surface);
    border: 1px solid var(--color-border);
  }
  .props-table th {
    text-align: left;
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 2px solid var(--color-border);
    font-weight: var(--font-weight-semibold);
    color: var(--color-foreground);
  }
  .props-table td {
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-foreground-subtle);
    vertical-align: top;
  }
</style>
