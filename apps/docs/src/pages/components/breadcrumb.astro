---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BreadcrumbDefault, BreadcrumbCustomSeparator, BreadcrumbShort } from '../../components/BreadcrumbGallery';
---

<BaseLayout title="Breadcrumb">
  <div class="prose">
    <h1>Breadcrumb</h1>
    <p>
      A navigation aid showing the user's location within a site hierarchy.
      The last item is automatically marked as the current page.
    </p>

    <h2>Installation</h2>
    <pre><code>{`import { Breadcrumb } from '@ds/components';`}</code></pre>

    <h2>Default</h2>
    <p>Pass an array of items. The last item renders as plain text.</p>
    <BreadcrumbDefault client:load />
    <pre><code>{`<Breadcrumb
  items={[
    { label: 'Home', href: '/' },
    { label: 'Women', href: '/women' },
    { label: 'Dresses', href: '/women/dresses' },
    { label: 'Midi Dresses' },
  ]}
/>`}</code></pre>

    <h2>Custom separator</h2>
    <p>Override the default "/" separator with any string or ReactNode.</p>
    <BreadcrumbCustomSeparator client:load />
    <pre><code>{`<Breadcrumb
  items={[...]}
  separator="›"
/>`}</code></pre>

    <h2>Short trail</h2>
    <BreadcrumbShort client:load />
    <pre><code>{`<Breadcrumb
  items={[
    { label: 'Home', href: '/' },
    { label: 'Cart' },
  ]}
/>`}</code></pre>

    <h2>Props</h2>
    <table class="props-table">
      <thead>
        <tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>items</code></td><td><code>BreadcrumbItem[]</code></td><td>—</td><td>Ordered list of breadcrumb items</td></tr>
        <tr><td><code>separator</code></td><td><code>ReactNode</code></td><td><code>'/'</code></td><td>Separator between items</td></tr>
      </tbody>
    </table>

    <h3>BreadcrumbItem</h3>
    <table class="props-table">
      <thead>
        <tr><th>Property</th><th>Type</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>label</code></td><td><code>string</code></td><td>Display text</td></tr>
        <tr><td><code>href</code></td><td><code>string</code></td><td>Optional link URL. Omit for the current page.</td></tr>
      </tbody>
    </table>

    <h2>Accessibility</h2>
    <ul>
      <li>Renders as <code>&lt;nav aria-label="Breadcrumb"&gt;</code></li>
      <li>Uses an <code>&lt;ol&gt;</code> for ordered semantic structure</li>
      <li>Last item has <code>aria-current="page"</code></li>
      <li>Separators are hidden from screen readers with <code>aria-hidden</code></li>
    </ul>
  </div>
</BaseLayout>

<style>
  .props-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
    margin: var(--spacing-4) 0;
    background-color: var(--color-background-surface);
    border: 1px solid var(--color-border);
  }
  .props-table th {
    text-align: left;
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 2px solid var(--color-border);
    font-weight: var(--font-weight-semibold);
    color: var(--color-foreground);
  }
  .props-table td {
    padding: var(--spacing-2) var(--spacing-3);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-foreground-subtle);
    vertical-align: top;
  }
</style>
