---
import ComponentPage from '../../layouts/ComponentPage.astro';
import {
  CollectionFiltersDefault,
  CollectionFiltersActive,
  CollectionFiltersWithHeader,
  CollectionFiltersManyValues,
  CollectionFiltersMobile,
} from '../../components/CollectionFiltersGallery';
---

<ComponentPage
  title="Collection Filters"
  description="Faceted navigation for collection pages. Supports list filters (checkboxes), price range (min/max inputs), and boolean filters. Desktop renders as a sidebar; mobile opens a Drawer. Composes Accordion, Checkbox, Button, Badge, Input, Drawer, and Text."
  installCode={`import { CollectionFilters } from '@ds/components';\nimport type { Filter, FilterValue } from '@ds/components';`}
  props={[
    {
      name: 'CollectionFiltersProps',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>filters</code>', '<code>Filter[]</code>', '—', 'Filter definitions'],
        ['<code>activeCount</code>', '<code>number</code>', '—', 'Total number of active filters'],
        ['<code>onFilterChange</code>', '<code>(id, value, active) => void</code>', '—', 'Called when a filter value changes'],
        ['<code>onClearAll</code>', '<code>() => void</code>', '—', 'Called when "Clear all" is clicked'],
        ['<code>showMoreThreshold</code>', '<code>number</code>', '<code>5</code>', 'Values shown before "Show more" toggle'],
        ['<code>mobileButtonLabel</code>', '<code>string</code>', '<code>"Filters"</code>', 'Mobile trigger button label'],
        ['<code>header</code>', '<code>ReactNode</code>', '—', 'Optional header above filter groups'],
        ['<code>resultsCount</code>', '<code>number</code>', '—', 'Products count for aria-live region'],
      ],
    },
    {
      name: 'Filter',
      headers: ['Prop', 'Type', 'Description'],
      rows: [
        ['<code>id</code>', '<code>string</code>', 'Unique identifier'],
        ['<code>label</code>', '<code>string</code>', 'Display label (e.g. "Color", "Size")'],
        ['<code>type</code>', '<code>"list" | "price_range" | "boolean"</code>', 'Filter type'],
        ['<code>values</code>', '<code>FilterValue[]</code>', 'Available values (for list/boolean)'],
        ['<code>min / max</code>', '<code>number</code>', 'Price range bounds in cents'],
        ['<code>activeMin / activeMax</code>', '<code>number</code>', 'Currently active price range'],
      ],
    },
    {
      name: 'FilterValue',
      headers: ['Prop', 'Type', 'Description'],
      rows: [
        ['<code>label</code>', '<code>string</code>', 'Display label'],
        ['<code>value</code>', '<code>string</code>', 'Value identifier'],
        ['<code>count</code>', '<code>number</code>', 'Product count'],
        ['<code>active</code>', '<code>boolean</code>', 'Whether currently active'],
      ],
    },
  ]}
  accessibility={[
    'Filter groups use Accordion with <code>aria-expanded</code> for collapsible sections',
    'Checkboxes use native Radix semantics via the Checkbox component',
    'Active filter count is announced via <code>aria-live="polite"</code> region',
    'Each active filter pill has <code>aria-label="Remove filter: [label]"</code>',
    'Clear all button has <code>aria-label="Clear all filters"</code>',
    'Results count updates are announced via <code>aria-live="polite"</code>',
    'Price range inputs have descriptive <code>aria-label</code> attributes',
    'Filter values with 0 products are disabled',
    'Mobile drawer inherits all Drawer accessibility: focus trapping, Escape to close',
  ]}
>
  <h2>Default</h2>
  <p>Renders filter groups as collapsible accordion sections. The first 3 are open by default.</p>
  <CollectionFiltersDefault client:load />
  <pre><code>{`const [filters, setFilters] = useState(initialFilters);

<CollectionFilters
  filters={filters}
  activeCount={activeCount}
  onFilterChange={handleFilterChange}
  onClearAll={handleClearAll}
  resultsCount={64}
/>`}</code></pre>

  <h2>With active filters</h2>
  <p>Active filters appear as dismissible pills above the filter panel. A "Clear all" button appears when any filter is active.</p>
  <CollectionFiltersActive client:load />

  <h2>With header</h2>
  <p>Pass a <code>header</code> prop to render content above the filter groups.</p>
  <CollectionFiltersWithHeader client:load />
  <pre><code>{`<CollectionFilters
  {...state}
  header={<Heading level={3} size="sm">Filter by</Heading>}
/>`}</code></pre>

  <h2>Show more / Show less</h2>
  <p>When a filter has more values than <code>showMoreThreshold</code> (default: 5), a "Show more" toggle appears.</p>
  <CollectionFiltersManyValues client:load />
  <pre><code>{`<CollectionFilters
  {...state}
  showMoreThreshold={5}
/>`}</code></pre>

  <h2>Mobile drawer</h2>
  <p>On screens below 768px, the desktop sidebar hides and a "Filters" button opens a Drawer from the left. The badge shows the active filter count.</p>
  <CollectionFiltersMobile client:load />
</ComponentPage>
