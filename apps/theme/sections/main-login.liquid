{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'alert.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading_text = section.settings.heading
  if heading_text == blank
    assign heading_text = 'Sign in'
  endif
-%}

<section class="ds-page-container ds-section ds-customer ds-customer--narrow" aria-labelledby="CustomerLoginTitle">
  <div class="ds-customer__inner">
    <header class="ds-customer__header">
      <h1 id="CustomerLoginTitle" class="ds-heading ds-heading--2xl ds-customer__title">
        {{ heading_text }}
      </h1>
      <p class="ds-text ds-text--sm ds-customer__subtitle">
        Sign in to your account to view orders and manage addresses.
      </p>
    </header>

    {%- form 'customer_login', class: 'ds-customer__form', novalidate: 'novalidate' -%}
      {%- if form.errors -%}
        <div class="ds-customer__alerts">
          <div class="ds-alert ds-alert--destructive" role="alert">
            <div class="ds-alert__content">
              <p class="ds-text ds-text--sm ds-alert__title">
                We couldn't sign you in.
              </p>
              <ul class="ds-text ds-text--sm ds-alert__description">
                {%- for field in form.errors -%}
                  <li>{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          </div>
        </div>
      {%- endif -%}

      <div class="ds-input-root">
        <label for="CustomerLoginEmail" class="ds-input-label ds-input-label--required">
          Email
        </label>
        <input
          type="email"
          name="customer[email]"
          id="CustomerLoginEmail"
          class="ds-input-field ds-input-field--md"
          autocomplete="email"
          autocapitalize="off"
          autocorrect="off"
          spellcheck="false"
          required
        >
      </div>

      <div class="ds-input-root">
        <label for="CustomerLoginPassword" class="ds-input-label ds-input-label--required">
          Password
        </label>
        <input
          type="password"
          name="customer[password]"
          id="CustomerLoginPassword"
          class="ds-input-field ds-input-field--md"
          autocomplete="current-password"
          required
        >
      </div>

      <div class="ds-customer__actions">
        <button type="submit" class="ds-button ds-button--primary ds-button--md ds-button--full-width">
          Sign in
        </button>
      </div>

      <div class="ds-customer__meta">
        <a class="ds-text ds-text--sm ds-customer__link" href="{{ routes.account_recover_url }}">
          Forgot your password?
        </a>
        <a class="ds-text ds-text--sm ds-customer__link" href="{{ routes.account_register_url }}">
          Create account
        </a>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Login",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sign in"
    }
  ],
  "presets": [{ "name": "Login" }]
}
{% endschema %}
