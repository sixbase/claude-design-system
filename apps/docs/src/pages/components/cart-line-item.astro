---
import ComponentPage from '../../layouts/ComponentPage.astro';
import {
  CartLineItemDefault,
  CartLineItemWithOptions,
  CartLineItemOnSale,
  CartLineItemWithLink,
  CartLineItemNoImage,
  CartLineItemMultiple,
} from '../../components/CartLineItemGallery';
---

<ComponentPage
  title="Cart Line Item"
  description="A single row in the cart — thumbnail, product info, quantity controls, line price, and remove action. Used in both the Cart page and Cart Drawer. Composes <code>QuantitySelector</code>, <code>PriceDisplay</code>, <code>Button</code>, <code>Badge</code>, and <code>Text</code>."
  installCode="import { CartLineItem } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>id</code>', '<code>string</code>', '—', 'Unique identifier for this cart item'],
        ['<code>name</code>', '<code>string</code>', '—', 'Product name'],
        ['<code>image</code>', '<code>string</code>', '—', 'Product image URL'],
        ['<code>imageAlt</code>', '<code>string</code>', 'name', 'Alt text for product image'],
        ['<code>price</code>', '<code>number</code>', '—', 'Unit price in cents (e.g. 4800 = $48.00)'],
        ['<code>compareAtPrice</code>', '<code>number</code>', '—', 'Original price in cents, shown with strikethrough when on sale'],
        ['<code>quantity</code>', '<code>number</code>', '—', 'Current quantity'],
        ['<code>maxQuantity</code>', '<code>number</code>', '<code>99</code>', 'Maximum allowed quantity'],
        ['<code>options</code>', '<code>Array&lt;{ name: string; value: string }&gt;</code>', '—', 'Product options (e.g. Size, Color)'],
        ['<code>onQuantityChange</code>', '<code>(quantity: number) =&gt; void</code>', '—', 'Called when quantity changes'],
        ['<code>onRemove</code>', '<code>() =&gt; void</code>', '—', 'Called when item is removed'],
        ['<code>href</code>', '<code>string</code>', '—', 'Link to product detail page'],
      ],
    },
  ]}
  accessibility={[
    'Wrapping element uses <code>role="group"</code> with <code>aria-label</code> set to the product name',
    'Remove button has <code>aria-label="Remove {name} from cart"</code>',
    'QuantitySelector has <code>aria-label="Quantity for {name}"</code>',
    'Product link wraps name only, not entire row',
    'Image placeholder is <code>aria-hidden="true"</code>',
    'Focus states use the design system focus ring token',
  ]}
>
  <h2>Default</h2>
  <CartLineItemDefault client:load />
  <pre><code>{`<CartLineItem
  id="1"
  name="Canvas Tote Bag"
  price={4800}
  quantity={1}
  image="/tote.jpg"
  onQuantityChange={(q) => update(q)}
  onRemove={() => remove()}
/>`}</code></pre>

  <h2>With options</h2>
  <p>Display product variant options like size and color.</p>
  <CartLineItemWithOptions client:load />
  <pre><code>{`<CartLineItem
  ...
  options={[
    { name: 'Size', value: 'XL' },
    { name: 'Color', value: 'Stone' },
  ]}
/>`}</code></pre>

  <h2>On sale</h2>
  <p>When <code>compareAtPrice</code> is provided and greater than <code>price</code>, a sale badge and strikethrough price are shown via <code>PriceDisplay</code>.</p>
  <CartLineItemOnSale client:load />
  <pre><code>{`<CartLineItem
  ...
  price={12800}
  compareAtPrice={16500}
/>`}</code></pre>

  <h2>With product link</h2>
  <p>The product name becomes a link to the product detail page.</p>
  <CartLineItemWithLink client:load />
  <pre><code>{`<CartLineItem ... href="/products/beanie" />`}</code></pre>

  <h2>No image (placeholder)</h2>
  <p>When no image is provided, a placeholder icon is shown.</p>
  <CartLineItemNoImage client:load />

  <h2>Multiple items</h2>
  <p>Cart line items use inner-only dividers — no border on the last item.</p>
  <CartLineItemMultiple client:load />
</ComponentPage>
