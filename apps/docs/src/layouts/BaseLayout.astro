---
import '@ds/tokens/css';
import '@ds/components/styles';
import './base.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Design system documentation' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Design System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Ancizar+Serif:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <nav>
          <div class="sidebar__logo">
            <span class="sidebar__logo-text">Design System</span>
          </div>

          <div class="sidebar__section">
            <p class="sidebar__section-label">Getting Started</p>
            <a href="/" class="sidebar__link">Introduction</a>
            <a href="/getting-started" class="sidebar__link">Installation</a>
          </div>

          <div class="sidebar__section">
            <p class="sidebar__section-label">Foundation</p>
            <a href="/tokens/colors" class="sidebar__link">Colors</a>
            <a href="/tokens/typography" class="sidebar__link">Typography</a>
            <a href="/tokens/spacing" class="sidebar__link">Spacing</a>
          </div>

          <div class="sidebar__section">
            <p class="sidebar__section-label">Components</p>
            <a href="/components/accordion" class="sidebar__link">Accordion</a>
            <a href="/components/button" class="sidebar__link">Button</a>
            <a href="/components/input" class="sidebar__link">Input</a>
            <a href="/components/typography" class="sidebar__link">Typography</a>
            <a href="/components/badge" class="sidebar__link">Badge</a>
            <a href="/components/card" class="sidebar__link">Card</a>
            <a href="/components/select" class="sidebar__link">Select</a>
            <a href="/components/checkbox" class="sidebar__link">Checkbox</a>
            <a href="/components/modal" class="sidebar__link">Modal</a>
            <a href="/components/product-card" class="sidebar__link">Product Card</a>
            <a href="/components/breadcrumb" class="sidebar__link">Breadcrumb</a>
            <a href="/components/quantity-selector" class="sidebar__link">Quantity Selector</a>
            <a href="/components/image-gallery" class="sidebar__link">Image Gallery</a>
            <a href="/components/star-rating" class="sidebar__link">Star Rating</a>
            <a href="/components/carousel" class="sidebar__link">Carousel</a>
            <a href="/components/color-swatch" class="sidebar__link">Color Swatch</a>
            <a href="/components/feature-block" class="sidebar__link">Feature Block</a>
            <a href="/components/stock-indicator" class="sidebar__link">Stock Indicator</a>
          </div>

          <div class="sidebar__section">
            <p class="sidebar__section-label">Examples</p>
            <a href="/examples/product-detail" class="sidebar__link">Product Detail Page</a>
          </div>
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>
