---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { ButtonVariants, ButtonSizes, ButtonStates, ButtonWithIcons } from '../../components/ButtonGallery';
---

<ComponentPage
  title="Button"
  description="The primary interactive element. Supports four variants (primary, secondary, ghost, destructive), three sizes, loading state, icon-only layout, and polymorphic rendering via <code>asChild</code>."
  installCode="import { Button } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>variant</code>', "<code>'primary' | 'secondary' | 'ghost' | 'destructive'</code>", "<code>'primary'</code>", 'Visual style'],
        ['<code>size</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Size'],
        ['<code>loading</code>', '<code>boolean</code>', '<code>false</code>', 'Show spinner, disable'],
        ['<code>disabled</code>', '<code>boolean</code>', '<code>false</code>', 'Disable interaction'],
        ['<code>asChild</code>', '<code>boolean</code>', '<code>false</code>', 'Render as child element'],
        ['<code>fullWidth</code>', '<code>boolean</code>', '<code>false</code>', '100% width'],
        ['<code>leadingIcon</code>', '<code>ReactNode</code>', '—', 'Icon before label'],
        ['<code>trailingIcon</code>', '<code>ReactNode</code>', '—', 'Icon after label'],
      ],
    },
  ]}
  accessibility={[
    'Keyboard: <kbd>Enter</kbd> and <kbd>Space</kbd> activate',
    'Loading state sets <code>aria-busy="true"</code>',
    'Disabled state sets <code>aria-disabled="true"</code>',
    'Focus ring is visible for keyboard navigation, hidden for mouse',
    'Icon-only buttons require <code>aria-label</code>',
  ]}
>
  <h2>Variants</h2>
  <p>Four variants to match the weight of the action.</p>
  <ButtonVariants client:load />
  <pre><code>{`<Button variant="primary">Primary</Button>
<Button variant="secondary">Secondary</Button>
<Button variant="ghost">Ghost</Button>
<Button variant="destructive">Destructive</Button>`}</code></pre>

  <h2>Sizes</h2>
  <ButtonSizes client:load />
  <pre><code>{`<Button size="sm">Small</Button>
<Button size="md">Medium</Button>   {/* default */}
<Button size="lg">Large</Button>`}</code></pre>

  <h2>States</h2>
  <ButtonStates client:load />
  <pre><code>{`<Button loading>Saving…</Button>
<Button disabled>Disabled</Button>
<Button fullWidth>Full width</Button>`}</code></pre>

  <h2>With icons</h2>
  <ButtonWithIcons client:load />
  <pre><code>{`<Button leadingIcon={<PlusIcon />}>New item</Button>
<Button variant="secondary" trailingIcon={<ArrowRightIcon />}>Continue</Button>
<Button variant="ghost" leadingIcon={<DownloadIcon />}>Export</Button>
<Button variant="destructive" leadingIcon={<TrashIcon />}>Delete</Button>`}</code></pre>

  <h2>Polymorphic (asChild)</h2>
  <p>
    Use <code>asChild</code> to render as a different element while keeping all button styles.
    Uses Radix UI's Slot primitive under the hood.
  </p>
  <pre><code>{`<Button asChild variant="secondary">
  <a href="/dashboard">Go to dashboard</a>
</Button>`}</code></pre>
</ComponentPage>
