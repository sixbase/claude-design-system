---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { ColorPickerDefault, ColorPickerSizes } from '../../components/ColorPickerGallery';
---

<ComponentPage
  title="Color Picker"
  description="A group of selectable color swatches for product option selection. Uses radio group semantics for full keyboard and screen reader support."
  installCode="import { ColorPicker } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>options</code>', '<code>ColorOption[]</code>', '—', 'Available color options. Each has <code>value</code>, <code>color</code> (CSS), and <code>label</code>.'],
        ['<code>value</code>', '<code>string</code>', '—', 'Currently selected value'],
        ['<code>onChange</code>', '<code>(value: string) =&gt; void</code>', '—', 'Called when a color is selected'],
        ['<code>size</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Size of the swatches'],
      ],
    },
  ]}
  accessibility={[
    'Uses <code>role="radiogroup"</code> on the container and <code>role="radio"</code> on each swatch',
    'Each swatch has an <code>aria-label</code> with the color name (e.g. "Carbon Black")',
    '<code>aria-checked</code> indicates the selected swatch',
    'Color is not the sole indicator — the active ring visually marks the selection',
  ]}
>
  <h2>Default</h2>
  <ColorPickerDefault client:load />
  <pre><code>{`const COLORS = [
  { value: 'black', color: '#1a1a1a', label: 'Carbon Black' },
  { value: 'navy', color: '#1e3a5f', label: 'Navy Blue' },
  { value: 'olive', color: '#556b2f', label: 'Olive Green' },
];

<ColorPicker options={COLORS} value={value} onChange={setValue} />`}</code></pre>

  <h2>Sizes</h2>
  <p>Three swatch sizes to fit different contexts.</p>
  <ColorPickerSizes client:load />
  <pre><code>{`<ColorPicker options={COLORS} value={value} onChange={setValue} size="sm" />
<ColorPicker options={COLORS} value={value} onChange={setValue} size="md" />
<ColorPicker options={COLORS} value={value} onChange={setValue} size="lg" />`}</code></pre>
</ComponentPage>
