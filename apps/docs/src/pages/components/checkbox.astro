---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { CheckboxStates, CheckboxWithText, CheckboxFilter } from '../../components/CheckboxGallery';
---

<ComponentPage
  title="Checkbox"
  description="An accessible checkbox built on Radix UI. Supports checked, unchecked, and indeterminate states. Label, hint, and error all built in. Common ecommerce uses: filter panels, newsletter opt-in, terms acceptance, cart item selection."
  installCode="import { Checkbox } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>label</code>', '<code>string</code>', '—', 'Visible label'],
        ['<code>hint</code>', '<code>string</code>', '—', 'Helper text below'],
        ['<code>error</code>', '<code>string</code>', '—', 'Error message'],
        ['<code>size</code>', "<code>'sm' | 'md'</code>", "<code>'md'</code>", 'Checkbox size'],
        ['<code>checked</code>', "<code>boolean | 'indeterminate'</code>", '—', 'Controlled checked state'],
        ['<code>defaultChecked</code>', '<code>boolean</code>', '<code>false</code>', 'Uncontrolled initial state'],
        ['<code>disabled</code>', '<code>boolean</code>', '<code>false</code>', 'Disable interaction'],
        ['<code>onCheckedChange</code>', "<code>(checked: boolean | 'indeterminate') =&gt; void</code>", '—', 'Change handler'],
      ],
    },
  ]}
  accessibility={[
    'Label is associated via <code>htmlFor</code>/<code>id</code> — clicking the label toggles the checkbox',
    'Keyboard: <kbd>Space</kbd> toggles',
    'Error message is announced via <code>role="alert"</code>',
    'Indeterminate state is communicated via <code>aria-checked="mixed"</code> (Radix handles this)',
  ]}
>
  <h2>States</h2>
  <CheckboxStates client:load />
  <pre><code>{`<Checkbox label="Unchecked" />
<Checkbox label="Checked" defaultChecked />
<Checkbox label="Indeterminate" checked="indeterminate" />
<Checkbox label="Disabled" disabled />
<Checkbox label="Disabled checked" disabled defaultChecked />`}</code></pre>

  <h2>With hint and error</h2>
  <CheckboxWithText client:load />
  <pre><code>{`<Checkbox
  label="Subscribe to newsletter"
  hint="We send at most one email per week"
/>
<Checkbox
  label="I agree to the terms and conditions"
  error="You must accept the terms to continue"
/>`}</code></pre>

  <h2>Filter panel (size="sm")</h2>
  <p>Small checkboxes are ideal for dense filter UIs in product listings.</p>
  <CheckboxFilter client:load />
  <pre><code>{`<Checkbox size="sm" label="XS" defaultChecked />
<Checkbox size="sm" label="S" defaultChecked />
<Checkbox size="sm" label="M" />
<Checkbox size="sm" label="XL" disabled />`}</code></pre>
</ComponentPage>
