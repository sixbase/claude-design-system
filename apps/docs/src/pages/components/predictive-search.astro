---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { PredictiveSearchInteractive, PredictiveSearchProducts, PredictiveSearchSizes } from '../../components/PredictiveSearchGallery';
---

<ComponentPage
  title="Predictive Search"
  description="Live search autocomplete showing products, collections, pages, and articles as the user types. Implements the WAI-ARIA combobox pattern. Data fetching is the consumer's responsibility via the onSearch callback."
  installCode={`import { PredictiveSearch } from '@ds/components';
import type { SearchResult, SearchResultType } from '@ds/components';`}
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'What it does'],
      rows: [
        ['<code>onSearch</code>', '<code>(query: string) =&gt; void</code>', '\u2014', 'Called after debounce when query meets minChars. Consumer fetches data and passes back via <code>results</code>.'],
        ['<code>results</code>', '<code>SearchResult[]</code>', '<code>[]</code>', 'Search results to display, grouped by type'],
        ['<code>onSelect</code>', '<code>(result: SearchResult) =&gt; void</code>', '\u2014', 'Called when a result is selected (click or Enter)'],
        ['<code>placeholder</code>', '<code>string</code>', '<code>"Search products\u2026"</code>', 'Input placeholder text'],
        ['<code>maxResults</code>', '<code>number</code>', '<code>4</code>', 'Maximum results shown per type group'],
        ['<code>showTypes</code>', '<code>SearchResultType[]</code>', '<code>all 4</code>', 'Which result types to show and in what order'],
        ['<code>loading</code>', '<code>boolean</code>', '<code>false</code>', 'Shows skeleton loading placeholders when true'],
        ['<code>debounce</code>', '<code>number</code>', '<code>300</code>', 'Debounce delay in milliseconds'],
        ['<code>minChars</code>', '<code>number</code>', '<code>2</code>', 'Minimum characters before triggering search'],
        ['<code>onViewAll</code>', '<code>(query: string) =&gt; void</code>', '\u2014', 'Called when "View all results" footer link is clicked'],
        ['<code>formatPrice</code>', '<code>(cents: number) =&gt; string</code>', 'USD formatter', 'Format price from cents for display'],
        ['<code>label</code>', '<code>string</code>', '<code>"Search"</code>', 'Accessible label (visually hidden)'],
        ['<code>size</code>', '<code>"sm" | "md" | "lg"</code>', '<code>"md"</code>', 'Size of the search input'],
      ],
    },
  ]}
  accessibility={[
    'Implements WAI-ARIA combobox pattern: <code>role="combobox"</code> on input with <code>aria-expanded</code>, <code>aria-controls</code>, <code>aria-activedescendant</code>',
    'Results use <code>role="listbox"</code> with <code>role="option"</code> items and <code>role="group"</code> for type grouping',
    '<code>aria-live="polite"</code> region announces result count when results load',
    'Full keyboard navigation: Arrow keys, Enter, Escape, Home, End',
    'Visually-hidden label associated with input via <code>htmlFor</code>',
    'Clear button has <code>aria-label="Clear search"</code>',
    'Loading state uses <code>aria-busy="true"</code> and <code>role="status"</code>',
  ]}
>
  <h2>Interactive demo</h2>
  <p>Type at least 2 characters to trigger a search. Results appear after a simulated 400ms API delay. Use arrow keys to navigate, Enter to select, Escape to close.</p>
  <PredictiveSearchInteractive client:load />
  <pre><code>{`const [results, setResults] = useState([]);
const [loading, setLoading] = useState(false);

function handleSearch(query) {
  setLoading(true);
  fetch(\`/search/suggest.json?q=\${query}\`)
    .then(res => res.json())
    .then(data => { setResults(data); setLoading(false); });
}

<PredictiveSearch
  onSearch={handleSearch}
  results={results}
  loading={loading}
  onSelect={(r) => navigate(r.url)}
  onViewAll={(q) => navigate(\`/search?q=\${q}\`)}
/>`}</code></pre>

  <h2>Products only</h2>
  <p>Use <code>showTypes</code> to filter which result types appear. Here only products are shown.</p>
  <PredictiveSearchProducts client:load />
  <pre><code>{`<PredictiveSearch
  onSearch={handleSearch}
  results={results}
  loading={loading}
  showTypes={['product']}
  onSelect={(r) => navigate(r.url)}
/>`}</code></pre>

  <h2>Sizes</h2>
  <p>Three sizes matching the Input component: small (34px), medium (42px), and large (55px).</p>
  <PredictiveSearchSizes client:load />

</ComponentPage>
