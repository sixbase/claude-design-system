---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { VariantSelectorGallery } from '../../components/VariantSelectorGallery';
---

<ComponentPage
  title="Variant Selector"
  description="Unified variant picker for all Shopify product option types — color, size, material, style. Orchestrates ColorPicker swatches and button groups on the PDP."
  installCode="import { VariantSelector } from '@ds/components';"
  props={[
    {
      name: 'VariantSelectorProps',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>options</code>', '<code>VariantOption[]</code>', '—', 'Product option groups to render'],
        ['<code>selectedValues</code>', '<code>Record&lt;string, string&gt;</code>', '—', 'Currently selected value per option name'],
        ['<code>onValueChange</code>', '<code>(optionName: string, value: string) =&gt; void</code>', '—', 'Called when a value is selected'],
        ['<code>size</code>', "<code>'sm' | 'md'</code>", "<code>'md'</code>", 'Size of the controls'],
      ],
    },
    {
      name: 'VariantOption',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>name</code>', '<code>string</code>', '—', 'Option name (e.g. "Color", "Size")'],
        ['<code>type</code>', "<code>'color' | 'button'</code>", '—', '<code>color</code> renders swatches, <code>button</code> renders text buttons'],
        ['<code>values</code>', '<code>VariantOptionValue[]</code>', '—', 'Available values for this option'],
      ],
    },
    {
      name: 'VariantOptionValue',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>label</code>', '<code>string</code>', '—', 'Display label'],
        ['<code>value</code>', '<code>string</code>', '—', 'Shopify variant value identifier'],
        ['<code>colorHex</code>', '<code>string</code>', '—', 'Hex color for <code>type: "color"</code> options'],
        ['<code>available</code>', '<code>boolean</code>', '<code>true</code>', 'Out of stock but browsable (shown with strikethrough)'],
        ['<code>disabled</code>', '<code>boolean</code>', '<code>false</code>', 'Completely unavailable — not clickable'],
      ],
    },
  ]}
  accessibility={[
    'Each button option group uses <code>role="radiogroup"</code> with <code>aria-label</code> set to the option name',
    'Each option uses <code>role="radio"</code> with <code>aria-checked</code> and <code>aria-label</code>',
    'Arrow keys navigate within a group with wrap-around',
    'Unavailable options append "(out of stock)" to <code>aria-label</code>',
    'Color options delegate to ColorPicker, which provides its own radio group semantics',
    'Focus ring uses <code>var(--focus-ring)</code> composite token',
    'Reduced motion: scale animation disabled via <code>@media (prefers-reduced-motion: reduce)</code>',
  ]}
>
  <VariantSelectorGallery client:load />
</ComponentPage>
