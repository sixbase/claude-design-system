---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { ImageGalleryDefault, ImageGalleryAspectRatios, ImageGalleryThumbsLeft } from '../../components/ImageGalleryGallery';
---

<ComponentPage
  title="Image Gallery"
  description="A product image viewer with thumbnail navigation and swipe support. Configurable aspect ratios and thumbnail placement for different layouts."
  installCode="import { ImageGallery } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>images</code>', '<code>GalleryImage[]</code>', '—', 'Array of images to display'],
        ['<code>aspectRatio</code>', "<code>'1/1' | '4/5' | '3/4' | '4/3' | '16/9'</code>", "<code>'4/5'</code>", 'Main image aspect ratio'],
        ['<code>defaultIndex</code>', '<code>number</code>', '<code>0</code>', 'Initially selected image'],
        ['<code>thumbnailPosition</code>', "<code>'bottom' | 'left'</code>", "<code>'bottom'</code>", 'Thumbnail strip placement'],
      ],
    },
    {
      name: 'GalleryImage',
      headers: ['Property', 'Type', 'Description'],
      rows: [
        ['<code>src</code>', '<code>string</code>', 'Image source URL'],
        ['<code>alt</code>', '<code>string</code>', 'Alt text for accessibility'],
        ['<code>thumbSrc</code>', '<code>string</code>', 'Optional smaller thumbnail URL'],
      ],
    },
  ]}
  accessibility={[
    'Thumbnails use <code>role="tablist"</code> and <code>role="tab"</code> pattern',
    'Arrow keys navigate between thumbnails',
    '<kbd>Home</kbd> / <kbd>End</kbd> jump to first/last image',
    'Active thumbnail has <code>aria-selected="true"</code>',
    'Roving tabindex keeps only active thumb in tab order',
  ]}
>
  <h2>Default</h2>
  <p>Bottom thumbnails with 4:5 aspect ratio. Swipe to navigate on touch devices.</p>
  <ImageGalleryDefault client:load />
  <pre><code>{`<ImageGallery
  images={[
    { src: '/product-1.jpg', alt: 'Front view' },
    { src: '/product-2.jpg', alt: 'Side view' },
    { src: '/product-3.jpg', alt: 'Back view' },
    { src: '/product-4.jpg', alt: 'Detail view' },
  ]}
/>`}</code></pre>

  <h2>Aspect ratios</h2>
  <p>Square format works well for product detail pages.</p>
  <ImageGalleryAspectRatios client:load />
  <pre><code>{`<ImageGallery images={images} aspectRatio="1/1" />
{/* Also supports: '4/5' (default), '3/4', '4/3', '16/9' */}`}</code></pre>

  <h2>Thumbnails on left</h2>
  <p>Vertical thumbnail strip for wider layouts.</p>
  <ImageGalleryThumbsLeft client:load />
  <pre><code>{`<ImageGallery images={images} thumbnailPosition="left" />`}</code></pre>
</ComponentPage>
