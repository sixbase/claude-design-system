---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { ToastVariants, ToastWithTitle, ToastWithAction, ToastStacking, ToastEcommerce } from '../../components/ToastGallery';
---

<ComponentPage
  title="Toast"
  description="Transient notification for user feedback. Auto-dismisses after a duration. Non-blocking. Common uses: add-to-cart confirmation, wishlist toggle, form submission feedback, error alerts."
  installCode={`import { ToastProvider, useToast } from '@ds/components';

// Wrap your app (or layout) with ToastProvider:
<ToastProvider position="bottom-right">
  <App />
</ToastProvider>

// Inside any component:
const { toast } = useToast();
toast({ description: 'Item added to cart', variant: 'success' });`}
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>position</code>', "<code>'top-right' | 'bottom-right' | 'bottom-center'</code>", "<code>'bottom-right'</code>", 'Where toasts appear on screen (ToastProvider)'],
        ['<code>maxToasts</code>', '<code>number</code>', '<code>3</code>', 'Maximum visible toasts (ToastProvider)'],
      ],
    },
    {
      headers: ['Option', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>description</code>', '<code>string</code>', '—', 'Toast message (required)'],
        ['<code>title</code>', '<code>string</code>', '—', 'Optional heading above description'],
        ['<code>variant</code>', "<code>'default' | 'success' | 'error' | 'warning'</code>", "<code>'default'</code>", 'Visual style and icon'],
        ['<code>duration</code>', '<code>number</code>', '<code>5000</code>', 'Auto-dismiss delay in ms (0 to disable)'],
        ['<code>action</code>', '<code>{ label: string; onClick: () => void }</code>', '—', 'Optional action button (e.g., Undo)'],
        ['<code>onDismiss</code>', '<code>() => void</code>', '—', 'Called when toast is dismissed'],
      ],
    },
  ]}
  accessibility={[
    'Error toasts use <code>role="alert"</code> with <code>aria-live="assertive"</code>',
    'All other variants use <code>role="status"</code> with <code>aria-live="polite"</code>',
    'Dismiss button includes <code>aria-label="Dismiss notification"</code>',
    'Auto-dismiss pauses on hover and focus (keyboard users can read content)',
    '<code>prefers-reduced-motion</code>: animations disabled, toasts appear/disappear instantly',
    'Action button is fully keyboard accessible',
  ]}
>
  <h2>Variants</h2>
  <p>Four semantic variants with distinct colors and icons for status communication.</p>
  <ToastVariants client:load />
  <pre><code>{`const { toast } = useToast();

toast({ description: 'Notification message.', variant: 'default' });
toast({ description: 'Item added to cart.', variant: 'success' });
toast({ description: 'Something went wrong.', variant: 'error' });
toast({ description: 'Session expiring soon.', variant: 'warning' });`}</code></pre>

  <h2>With title</h2>
  <p>Add a bold title above the description for more prominent notifications.</p>
  <ToastWithTitle client:load />
  <pre><code>{`toast({
  title: 'Changes Saved',
  description: 'Your preferences have been updated successfully.',
  variant: 'success',
});`}</code></pre>

  <h2>With action</h2>
  <p>Include an action button for reversible operations like undo.</p>
  <ToastWithAction client:load />
  <pre><code>{`toast({
  title: 'Item Removed',
  description: 'The item was removed from your cart.',
  variant: 'success',
  action: { label: 'Undo', onClick: handleUndo },
});`}</code></pre>

  <h2>Stacking</h2>
  <p>Multiple toasts stack with a gap. Oldest toasts are removed when <code>maxToasts</code> is exceeded.</p>
  <ToastStacking client:load />
  <pre><code>{`<ToastProvider maxToasts={3}>
  {/* toasts stack up to 3, oldest removed */}
</ToastProvider>`}</code></pre>

  <h2>Ecommerce context</h2>
  <p>Common Shopify use cases: cart feedback, wishlist, stock alerts, discount codes.</p>
  <ToastEcommerce client:load />
</ComponentPage>
