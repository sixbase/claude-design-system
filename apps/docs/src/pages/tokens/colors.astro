---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tokens from '../../../../../packages/tokens/src/tokens.json';
---

<BaseLayout title="Colors">
  <div class="prose">
    <h1>Colors</h1>
    <p>
      The color system uses a 3-tier model: <strong>primitive palettes → semantic tokens → component tokens</strong>.
      Components always consume semantic tokens, never primitives directly.
      This is what makes dark mode work — same token names, different values.
    </p>

    <h2>Semantic tokens <span class="scale-badge scale-badge--primary">Use these</span></h2>
    <p class="section-desc">
      These are the tokens you reference in component CSS. They resolve to different hex values
      in light and dark mode automatically. If you're writing a component, this is the only
      section you need.
    </p>

    <h3>Backgrounds</h3>
    <div class="color-table">
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-background); border: 1px solid var(--color-border);" />
        <div class="color-info">
          <code>--color-background</code>
          <span class="color-hex">{tokens.primitive.color.stone[50]}</span>
          <span class="color-usage">Page background — the warm off-white default canvas</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-background-subtle); border: 1px solid var(--color-border);" />
        <div class="color-info">
          <code>--color-background-subtle</code>
          <span class="color-hex">{tokens.primitive.color.stone[100]}</span>
          <span class="color-usage">Sidebar, code blocks, section differentiation, zebra-striped table rows</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-background-surface); border: 1px solid var(--color-border);" />
        <div class="color-info">
          <code>--color-background-surface</code>
          <span class="color-hex">{tokens.primitive.color.stone[0]}</span>
          <span class="color-usage">Cards, modals, inputs, dropdowns — elevated surfaces that lift off the page background</span>
        </div>
      </div>
    </div>

    <h3>Foregrounds</h3>
    <div class="color-table">
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-foreground);" />
        <div class="color-info">
          <code>--color-foreground</code>
          <span class="color-hex">{tokens.primitive.color.stone[950]}</span>
          <span class="color-usage">Primary body text, headings, input values — any text that must be maximally readable</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-foreground-subtle);" />
        <div class="color-info">
          <code>--color-foreground-subtle</code>
          <span class="color-hex">{tokens.primitive.color.stone[500]}</span>
          <span class="color-usage">Captions, placeholders, secondary labels, breadcrumb separators, muted icons — text that should recede</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-foreground-muted);" />
        <div class="color-info">
          <code>--color-foreground-muted</code>
          <span class="color-hex">{tokens.primitive.color.stone[400]}</span>
          <span class="color-usage">Disabled text, watermarks, ghost-state elements — lowest contrast text that is still perceptible</span>
        </div>
      </div>
    </div>

    <h3>Borders</h3>
    <div class="color-table">
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-border);" />
        <div class="color-info">
          <code>--color-border</code>
          <span class="color-hex">{tokens.primitive.color.stone[200]}</span>
          <span class="color-usage">Card borders, dividers, table cell borders, input default borders — subtle structural lines</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-border-strong);" />
        <div class="color-info">
          <code>--color-border-strong</code>
          <span class="color-hex">{tokens.primitive.color.stone[300]}</span>
          <span class="color-usage">Input hover borders, active tab underlines, selected item outlines — borders that need more emphasis</span>
        </div>
      </div>
    </div>

    <h3>Interactive</h3>
    <div class="color-table">
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-primary);" />
        <div class="color-info">
          <code>--color-primary</code>
          <span class="color-hex">{tokens.primitive.color.stone[800]}</span>
          <span class="color-usage">Primary button fill, primary link color, active toggle fill, primary CTA backgrounds</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-primary-hover);" />
        <div class="color-info">
          <code>--color-primary-hover</code>
          <span class="color-hex">{tokens.primitive.color.stone[900]}</span>
          <span class="color-usage">Hover state for primary buttons and links — one step darker to confirm interactivity</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-primary-foreground); border: 1px solid var(--color-border);" />
        <div class="color-info">
          <code>--color-primary-foreground</code>
          <span class="color-hex">{tokens.primitive.color.stone[0]}</span>
          <span class="color-usage">Text and icons on primary-colored backgrounds — always paired with <code>--color-primary</code></span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-secondary); border: 1px solid var(--color-border);" />
        <div class="color-info">
          <code>--color-secondary</code>
          <span class="color-hex">{tokens.primitive.color.stone[200]}</span>
          <span class="color-usage">Secondary button fill, ghost button hover, chip backgrounds, tag backgrounds</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-secondary-hover);" />
        <div class="color-info">
          <code>--color-secondary-hover</code>
          <span class="color-hex">{tokens.primitive.color.stone[300]}</span>
          <span class="color-usage">Hover state for secondary buttons, pressed chip state</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-secondary-foreground);" />
        <div class="color-info">
          <code>--color-secondary-foreground</code>
          <span class="color-hex">{tokens.primitive.color.stone[900]}</span>
          <span class="color-usage">Text and icons on secondary-colored backgrounds</span>
        </div>
      </div>
    </div>

    <h3>Status</h3>
    <div class="color-table">
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-destructive);" />
        <div class="color-info">
          <code>--color-destructive</code>
          <span class="color-hex">{tokens.primitive.color.brick[600]}</span>
          <span class="color-usage">Delete buttons, error borders, destructive action fills — signals irreversible or dangerous actions</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-destructive-hover);" />
        <div class="color-info">
          <code>--color-destructive-hover</code>
          <span class="color-hex">{tokens.primitive.color.brick[700]}</span>
          <span class="color-usage">Hover state for destructive buttons</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-success);" />
        <div class="color-info">
          <code>--color-success</code>
          <span class="color-hex">{tokens.primitive.color.sage[600]}</span>
          <span class="color-usage">Success toast borders, form validation checkmarks, order confirmation indicators, in-stock badges</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-warning);" />
        <div class="color-info">
          <code>--color-warning</code>
          <span class="color-hex">{tokens.primitive.color.amber[600]}</span>
          <span class="color-usage">Warning banners, low-stock indicators, expiring session notices — something needs attention but isn't broken</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-info);" />
        <div class="color-info">
          <code>--color-info</code>
          <span class="color-hex">{tokens.primitive.color.slate[600]}</span>
          <span class="color-usage">Informational banners, help text callouts, tooltip backgrounds — neutral contextual information</span>
        </div>
      </div>
      <div class="color-row">
        <div class="color-sample" style="background-color: var(--color-focus-ring);" />
        <div class="color-info">
          <code>--color-focus-ring</code>
          <span class="color-hex">{tokens.primitive.color.stone[700]}</span>
          <span class="color-usage">Keyboard focus outlines via <code>:focus-visible</code> — do not use for decoration, only accessibility</span>
        </div>
      </div>
    </div>

    <h2>Primitive palettes <span class="scale-badge scale-badge--secondary">Reference only</span></h2>
    <p class="section-desc">
      Raw color values organized by hue. Components should <strong>never reference these directly</strong> — always
      go through a semantic token. These exist so you can see the full palette and understand what the semantic
      tokens resolve to. Named for personality, not function: <em>stone</em> not gray, <em>brick</em> not red,
      <em>sage</em> not green.
    </p>

    {Object.entries(tokens.primitive.color).map(([paletteName, shades]) => (
      <div>
        <h3>{paletteName.charAt(0).toUpperCase() + paletteName.slice(1)}</h3>
        <div class="palette-grid">
          {Object.entries(shades).map(([shade, value]) => (
            <div class="palette-swatch">
              <div class="palette-sample" style={`background-color: ${value};`} />
              <code class="palette-name">{shade}</code>
              <span class="palette-hex">{value}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .section-desc {
    font-size: var(--font-size-sm);
    color: var(--color-foreground-subtle);
    margin-top: calc(var(--spacing-1) * -1);
    margin-bottom: var(--spacing-4);
  }

  .scale-badge {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    vertical-align: middle;
    margin-left: var(--spacing-2);
    font-family: var(--font-family-mono);
  }
  .scale-badge--primary {
    background: var(--color-primary);
    color: var(--color-primary-foreground);
  }
  .scale-badge--secondary {
    background: var(--color-secondary);
    color: var(--color-secondary-foreground);
    border: 1px solid var(--color-border);
  }

  /* ─── Semantic color table ───────────────────────── */
  .color-table {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin: var(--spacing-3) 0 var(--spacing-6);
    background-color: var(--color-background-surface);
  }

  .color-row {
    display: grid;
    grid-template-columns: 48px 1fr;
    align-items: start;
    gap: var(--spacing-3);
    padding: var(--spacing-3) var(--spacing-4);
    border-bottom: 1px solid var(--color-border);
  }
  .color-row:last-child { border-bottom: none; }

  .color-sample {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .color-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .color-info code {
    font-size: var(--font-size-xs);
    background: none;
    border: none;
    padding: 0;
    color: var(--color-foreground);
  }
  .color-hex {
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    color: var(--color-foreground-muted);
  }
  .color-usage {
    font-size: var(--font-size-xs);
    color: var(--color-foreground-subtle);
    line-height: var(--line-height-relaxed);
  }

  /* ─── Primitive palette grid ─────────────────────── */
  .palette-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-4);
    margin: var(--spacing-3) 0 var(--spacing-6);
  }

  .palette-swatch {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
    min-width: 72px;
  }

  .palette-sample {
    height: 48px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .palette-name {
    font-size: var(--font-size-xs);
    background: none;
    border: none;
    padding: 0;
    color: var(--color-foreground);
  }

  .palette-hex {
    font-family: var(--font-family-mono);
    font-size: var(--font-size-xs);
    color: var(--color-foreground-subtle);
  }
</style>
