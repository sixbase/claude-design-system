---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { FooterDefault, FooterMinimal } from '../../components/FooterGallery';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<ComponentPage
  title="Footer"
  description="A responsive site footer with brand section, configurable link columns, copyright, and legal links. Collapses to a single column on mobile."
  installCode="import { Footer } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>logoSrc</code>', '<code>string</code>', '—', 'Logo image URL'],
        ['<code>logoAlt</code>', '<code>string</code>', "<code>'Home'</code>", 'Logo alt text'],
        ['<code>logoHref</code>', '<code>string</code>', "<code>'/'</code>", 'Logo link destination'],
        ['<code>tagline</code>', '<code>string</code>', '—', 'Brand tagline below the logo'],
        ['<code>columns</code>', '<code>FooterColumn[]</code>', '<code>[]</code>', 'Link columns'],
        ['<code>copyright</code>', '<code>string</code>', '—', 'Copyright text'],
        ['<code>legalLinks</code>', '<code>&#123; label, href &#125;[]</code>', '<code>[]</code>', 'Legal links at the bottom'],
      ],
    },
    {
      name: 'FooterColumn',
      headers: ['Property', 'Type', 'Description'],
      rows: [
        ['<code>heading</code>', '<code>string</code>', 'Column heading text'],
        ['<code>links</code>', '<code>&#123; label: string; href: string &#125;[]</code>', 'Links in the column'],
      ],
    },
  ]}
  accessibility={[
    'Uses semantic <code>&lt;footer&gt;</code> element for landmark identification',
    'Column headings use <code>&lt;h3&gt;</code> for proper document structure',
    'Logo link has an <code>aria-label</code> for screen readers',
    'All links have visible focus indicators and hover states',
  ]}
>
  <h2>Default</h2>
  <FooterDefault client:load basePath={base} />
  <pre><code>{`<Footer
  logoSrc="/logo.svg"
  logoAlt="Brand Name"
  tagline="Thoughtfully designed accessories."
  columns={[
    {
      heading: 'Shop',
      links: [
        { label: 'Phone Cases', href: '/cases' },
        { label: 'Wallets', href: '/wallets' },
      ],
    },
    {
      heading: 'Company',
      links: [
        { label: 'About', href: '/about' },
        { label: 'Careers', href: '/careers' },
      ],
    },
  ]}
  copyright="© 2026 Brand Name. All rights reserved."
  legalLinks={[
    { label: 'Privacy Policy', href: '/privacy' },
    { label: 'Terms of Service', href: '/terms' },
  ]}
/>`}</code></pre>

  <h2>Minimal</h2>
  <p>Logo and copyright only — no columns or legal links.</p>
  <FooterMinimal client:load basePath={base} />
  <pre><code>{`<Footer
  logoSrc="/logo.svg"
  logoAlt="Brand Name"
  copyright="© 2026 Brand Name. All rights reserved."
/>`}</code></pre>
</ComponentPage>
