---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { SelectDefault, SelectStates, SelectSizes, SelectGroups } from '../../components/SelectGallery';
---

<ComponentPage
  title="Select"
  description="An accessible dropdown for choosing a single value. Built on Radix UI Select for correct keyboard navigation, ARIA roles, and screen reader announcements. Common ecommerce uses: size picker, quantity, sort order, country/state selector."
  installCode="import { Select, SelectItem, SelectGroup, SelectSeparator } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>label</code>', '<code>string</code>', '—', 'Label above trigger'],
        ['<code>placeholder</code>', '<code>string</code>', "<code>'Select an option'</code>", 'Placeholder text'],
        ['<code>hint</code>', '<code>string</code>', '—', 'Helper text below'],
        ['<code>error</code>', '<code>string</code>', '—', 'Error message (adds error styling)'],
        ['<code>size</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Trigger size'],
        ['<code>fullWidth</code>', '<code>boolean</code>', '<code>false</code>', 'Stretch to container width'],
        ['<code>disabled</code>', '<code>boolean</code>', '<code>false</code>', 'Disable all interaction'],
      ],
    },
  ]}
  accessibility={[
    'Keyboard: <kbd>↑</kbd> <kbd>↓</kbd> navigate options, <kbd>Enter</kbd>/<kbd>Space</kbd> select, <kbd>Escape</kbd> close',
    'Label is linked to trigger via <code>aria-labelledby</code>',
    'Error message is announced via <code>role="alert"</code>',
    'Disabled items remain focusable but not selectable',
  ]}
>
  <h2>Default</h2>
  <SelectDefault client:load />
  <pre><code>{`<Select label="Size" placeholder="Choose a size">
  <SelectItem value="xs">XS</SelectItem>
  <SelectItem value="sm">SM</SelectItem>
  <SelectItem value="md">MD</SelectItem>
  <SelectItem value="lg">LG</SelectItem>
</Select>`}</code></pre>

  <h2>States</h2>
  <SelectStates client:load />
  <pre><code>{`{/* Hint */}
<Select label="Size" hint="Choose your preferred size" placeholder="Select...">...</Select>

{/* Error */}
<Select label="Size" error="Please select a size" placeholder="Select...">...</Select>

{/* Disabled */}
<Select label="Size" disabled placeholder="Out of stock">...</Select>`}</code></pre>

  <h2>Sizes</h2>
  <SelectSizes client:load />
  <pre><code>{`<Select size="sm" label="Small" placeholder="32px">...</Select>
<Select size="md" label="Medium" placeholder="40px">...</Select>   {/* default */}
<Select size="lg" label="Large" placeholder="48px">...</Select>`}</code></pre>

  <h2>Groups and separators</h2>
  <SelectGroups client:load />
  <pre><code>{`<Select label="Category" placeholder="Browse categories">
  <SelectGroup label="Clothing">
    <SelectItem value="tops">Tops</SelectItem>
    <SelectItem value="bottoms">Bottoms</SelectItem>
  </SelectGroup>
  <SelectSeparator />
  <SelectGroup label="Accessories">
    <SelectItem value="bags">Bags</SelectItem>
  </SelectGroup>
</Select>`}</code></pre>
</ComponentPage>
