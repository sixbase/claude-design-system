---
import '@ds/tokens/css';
import '@ds/components/styles';
import './base.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Design system documentation' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Design System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Ancizar+Serif:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  main {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--spacing-4);
  }

  @media (min-width: 1024px) {
    main {
      padding: var(--spacing-8);
    }
  }
</style>
