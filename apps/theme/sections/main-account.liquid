{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'alert.css' | asset_url | stylesheet_tag }}

{%- paginate customer.orders by 10 -%}

<section class="ds-page-container ds-section ds-customer ds-customer--wide" aria-labelledby="CustomerAccountTitle">
  <div class="ds-customer__inner">
    <header class="ds-customer__header">
      <h1 id="CustomerAccountTitle" class="ds-heading ds-heading--2xl ds-customer__title">
        {{ section.settings.heading | default: 'Account' }}
      </h1>
      <p class="ds-text ds-text--sm ds-customer__subtitle">
        Signed in as
        {%- if customer.name != blank %} {{ customer.name }} &middot;{% endif %}
        {{ customer.email }}
      </p>
    </header>

    <div class="ds-customer__block">
      <div class="ds-customer__block-header">
        <h2 class="ds-heading ds-heading--xl">Order history</h2>
      </div>

      {%- if customer.orders.size > 0 -%}
        <div class="ds-table-scroll">
          <table class="ds-table">
            <caption class="ds-sr-only">Your recent orders</caption>
            <thead>
              <tr>
                <th scope="col">Order</th>
                <th scope="col">Date</th>
                <th scope="col">Payment</th>
                <th scope="col">Fulfillment</th>
                <th scope="col" class="ds-table__numeric">Total</th>
              </tr>
            </thead>
            <tbody>
              {%- for order in customer.orders -%}
                <tr>
                  <td>
                    <a class="ds-customer__link" href="{{ order.customer_url }}" aria-label="Order {{ order.name }}">
                      {{ order.name }}
                    </a>
                  </td>
                  <td>{{ order.created_at | date: format: 'month_day_year' }}</td>
                  <td>
                    <span class="ds-badge ds-badge--sm ds-badge--{% if order.financial_status == 'paid' %}success{% elsif order.financial_status == 'refunded' or order.financial_status == 'voided' %}outline{% else %}warning{% endif %}">
                      {{ order.financial_status_label }}
                    </span>
                  </td>
                  <td>
                    <span class="ds-badge ds-badge--sm ds-badge--{% if order.fulfillment_status == 'fulfilled' %}success{% else %}outline{% endif %}">
                      {{ order.fulfillment_status_label | default: 'Unfulfilled' }}
                    </span>
                  </td>
                  <td class="ds-table__numeric">{{ order.total_price | money }}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="ds-customer__pagination" aria-label="Order history pagination">
            {%- if paginate.previous -%}
              <a class="ds-button ds-button--secondary ds-button--sm" href="{{ paginate.previous.url }}" rel="prev">
                Previous
              </a>
            {%- else -%}
              <span class="ds-customer__pagination__spacer"></span>
            {%- endif -%}

            <span class="ds-text ds-text--sm ds-text--muted">
              Page {{ paginate.current_page }} of {{ paginate.pages }}
            </span>

            {%- if paginate.next -%}
              <a class="ds-button ds-button--secondary ds-button--sm" href="{{ paginate.next.url }}" rel="next">
                Next
              </a>
            {%- else -%}
              <span class="ds-customer__pagination__spacer"></span>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="ds-customer__empty">
          <p class="ds-text ds-text--sm">You haven't placed any orders yet.</p>
        </div>
      {%- endif -%}
    </div>

    <div class="ds-customer__block">
      <div class="ds-customer__block-header">
        <h2 class="ds-heading ds-heading--xl">Account details</h2>
      </div>

      <dl class="ds-customer__dl">
        {%- if customer.name != blank -%}
          <dt>Name</dt>
          <dd>{{ customer.name }}</dd>
        {%- endif -%}
        <dt>Email</dt>
        <dd>{{ customer.email }}</dd>
        {%- if customer.default_address -%}
          <dt>Default address</dt>
          <dd>
            {{ customer.default_address.street }},
            {{ customer.default_address.city }},
            {{ customer.default_address.province_code }}
            {{ customer.default_address.zip }}
          </dd>
        {%- endif -%}
      </dl>

      <div class="ds-customer__actions">
        <a class="ds-button ds-button--secondary ds-button--md" href="{{ routes.account_addresses_url }}">
          Manage addresses
          {%- if customer.addresses_count > 0 %} ({{ customer.addresses_count }}){% endif -%}
        </a>
        <a class="ds-text ds-text--sm ds-customer__link" href="{{ routes.account_logout_url }}">
          Sign out
        </a>
      </div>
    </div>
  </div>
</section>

{%- endpaginate -%}

{% schema %}
{
  "name": "Account",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Account"
    }
  ],
  "presets": [{ "name": "Account" }]
}
{% endschema %}
