---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { CookieConsentDefault, CookieConsentWithCategories, CookieConsentControlled } from '../../components/CookieConsentGallery';
---

<ComponentPage
  title="Cookie Consent"
  description="A fixed bottom-bar banner for cookie consent. Supports Accept All / Reject All with an optional Preferences panel that reveals accordion sections for granular category toggles. Designed for GDPR and CCPA compliance."
  installCode={`import { CookieConsent } from '@ds/components';
import type { CookieCategory } from '@ds/components';`}
  props={[
    {
      name: 'CookieConsent',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>open</code>', '<code>boolean</code>', '—', 'Controlled visibility'],
        ['<code>onOpenChange</code>', '<code>(open: boolean) =&gt; void</code>', '—', 'Callback when visibility changes'],
        ['<code>defaultOpen</code>', '<code>boolean</code>', '<code>true</code>', 'Initial visibility (uncontrolled)'],
        ['<code>categories</code>', '<code>CookieCategory[]</code>', '—', 'Cookie categories for preferences panel'],
        ['<code>onAccept</code>', '<code>(ids: string[]) =&gt; void</code>', '—', 'Called with accepted category IDs'],
        ['<code>onReject</code>', '<code>() =&gt; void</code>', '—', 'Called when all non-essential rejected'],
        ['<code>heading</code>', '<code>string</code>', "<code>'We value your privacy'</code>", 'Banner heading text'],
        ['<code>description</code>', '<code>string</code>', "<code>'We use cookies…'</code>", 'Banner description'],
        ['<code>acceptLabel</code>', '<code>string</code>', "<code>'Accept All'</code>", 'Accept button label'],
        ['<code>rejectLabel</code>', '<code>string</code>', "<code>'Reject All'</code>", 'Reject button label'],
        ['<code>preferencesLabel</code>', '<code>string</code>', "<code>'Preferences'</code>", 'Preferences button label'],
        ['<code>saveLabel</code>', '<code>string</code>', "<code>'Save Preferences'</code>", 'Save button label'],
        ['<code>closeLabel</code>', '<code>string</code>', "<code>'Close'</code>", 'Close button label'],
      ],
    },
    {
      name: 'CookieCategory',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>id</code>', '<code>string</code>', '—', 'Unique identifier'],
        ['<code>label</code>', '<code>string</code>', '—', 'Display name'],
        ['<code>description</code>', '<code>string</code>', '—', 'Text shown when accordion section is expanded'],
        ['<code>required</code>', '<code>boolean</code>', '<code>false</code>', 'Always on, checkbox disabled'],
        ['<code>defaultChecked</code>', '<code>boolean</code>', '<code>false</code>', 'Initial checked state'],
      ],
    },
  ]}
  accessibility={[
    'Banner has <code>role="dialog"</code> with <code>aria-labelledby</code> pointing to the heading',
    '<code>aria-modal="false"</code> — background content remains interactive',
    '<kbd>Escape</kbd> closes the banner',
    'Preferences panel uses Accordion with full keyboard navigation',
    'Checkboxes are independently clickable without toggling accordion sections',
    'Required categories have disabled checkboxes with clear labeling',
    'All labels customizable for i18n / localization',
    'Respects <code>prefers-reduced-motion</code> — animations disabled',
  ]}
>
  <h2>Basic usage</h2>
  <p>Without categories, the banner shows Accept All and Reject All buttons.</p>
  <CookieConsentDefault client:load />
  <pre><code>{`<CookieConsent
  onAccept={(ids) => saveCookiePreferences(ids)}
  onReject={() => rejectAllCookies()}
/>`}</code></pre>

  <h2>With categories</h2>
  <p>
    Pass <code>categories</code> to show a Preferences button. Clicking it reveals
    accordion sections for each cookie category with inline checkboxes. Categories
    with <code>required: true</code> are always checked and disabled.
  </p>
  <CookieConsentWithCategories client:load />
  <pre><code>{`const categories: CookieCategory[] = [
  { id: 'essential', label: 'Strictly Necessary Cookies', description: 'Essential for the site to function.', required: true },
  { id: 'functional', label: 'Functional Cookies', description: 'Enhanced functionality and personalization.' },
  { id: 'performance', label: 'Performance Cookies', description: 'Help us understand usage.' },
  { id: 'targeting', label: 'Targeting Cookies', description: 'Personalized advertisements.' },
];

<CookieConsent
  categories={categories}
  onAccept={(ids) => saveCookiePreferences(ids)}
  onReject={() => rejectAllCookies()}
/>`}</code></pre>

  <h2>Controlled</h2>
  <p>
    Use <code>open</code> and <code>onOpenChange</code> for external state management.
    Useful when you need to re-show the banner from a settings page.
  </p>
  <CookieConsentControlled client:load />
  <pre><code>{`const [open, setOpen] = useState(false);

<CookieConsent
  open={open}
  onOpenChange={setOpen}
  categories={categories}
  onAccept={(ids) => { saveCookiePreferences(ids); setOpen(false); }}
  onReject={() => { rejectAllCookies(); setOpen(false); }}
/>`}</code></pre>
</ComponentPage>
