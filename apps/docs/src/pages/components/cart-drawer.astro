---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { CartDrawerDefault, CartDrawerEmpty, CartDrawerManyItems, CartDrawerWithFooter } from '../../components/CartDrawerGallery';
---

<ComponentPage
  title="Cart Drawer"
  description="Slide-out cart panel from the right edge showing current cart contents. Composes Drawer, CartLineItem, Button, and typography primitives. Appears on add-to-cart without full page navigation."
  installCode={`import { CartDrawer } from '@ds/components';
import type { CartDrawerItemData } from '@ds/components';`}
  accessibility={[
    'Inherits Drawer accessibility: <code>role="dialog"</code>, <code>aria-modal="true"</code>, focus trap, Escape to close',
    '<code>aria-label="Shopping cart"</code> on the dialog',
    'Item count announced via <code>aria-live="polite"</code> region when the drawer opens',
    'Each line item has <code>role="group"</code> with product name as label',
    'Remove buttons include <code>aria-label="Remove {product name} from cart"</code>',
    'Quantity selectors have <code>aria-label="Quantity for {product name}"</code>',
    'Body scroll is locked while the drawer is open',
  ]}
>
  <h2>Default</h2>
  <p>A cart drawer with items. Quantity can be adjusted and items removed. The footer shows the subtotal, checkout link, and continue shopping button.</p>
  <CartDrawerDefault client:load />
  <pre><code>{`const [open, setOpen] = useState(false);
const [items, setItems] = useState(cartItems);
const subtotal = computeSubtotal(items);

<CartDrawer
  open={open}
  onOpenChange={setOpen}
  items={items}
  subtotal={subtotal}
  onUpdateQuantity={(id, qty) => updateItem(id, qty)}
  onRemoveItem={(id) => removeItem(id)}
/>`}</code></pre>

  <h2>Empty state</h2>
  <p>When the cart has no items, a centered message and continue shopping button are shown. Customize the message with <code>emptyMessage</code>.</p>
  <CartDrawerEmpty client:load />
  <pre><code>{`<CartDrawer
  open={open}
  onOpenChange={setOpen}
  items={[]}
  subtotal={0}
  onUpdateQuantity={() => {}}
  onRemoveItem={() => {}}
  emptyMessage="Your bag is empty"  // default
/>`}</code></pre>

  <h2>Many items (scrollable)</h2>
  <p>With many items, the drawer body scrolls while the footer stays sticky at the bottom. The checkout button remains accessible regardless of item count.</p>
  <CartDrawerManyItems client:load />

  <h2>Footer content slot</h2>
  <p>Pass children to render content in the footer area above the subtotal. Useful for shipping thresholds, promo codes, or trust badges.</p>
  <CartDrawerWithFooter client:load />
  <pre><code>{`<CartDrawer
  open={open}
  onOpenChange={setOpen}
  items={items}
  subtotal={subtotal}
  onUpdateQuantity={handleUpdateQuantity}
  onRemoveItem={handleRemoveItem}
>
  <Text size="xs" muted>
    Free shipping on orders over $50
  </Text>
</CartDrawer>`}</code></pre>
</ComponentPage>
