---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { CarouselDefault, CarouselSizes } from '../../components/CarouselGallery';
---

<ComponentPage
  title="Carousel"
  description="A horizontally scrollable container with scroll-snap alignment. Compose with <code>CarouselSlide</code> to create image galleries, product rows, or any horizontal scrolling content."
  installCode="import { Carousel, CarouselSlide } from '@ds/components';"
  props={[
    {
      name: 'Carousel',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>children</code>', '<code>ReactNode</code>', '—', 'CarouselSlide elements'],
        ['<code>gap</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Gap between slides'],
      ],
    },
    {
      name: 'CarouselSlide',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>children</code>', '<code>ReactNode</code>', '—', 'Slide content'],
        ['<code>size</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Responsive slide width preset'],
      ],
    },
  ]}
  accessibility={[
    'Scrollable via touch, trackpad, or mouse drag',
    'Scroll-snap ensures slides align cleanly on release',
    'Content inside slides should include appropriate <code>alt</code> text for images',
  ]}
>
  <h2>Default</h2>
  <CarouselDefault client:load />
  <pre><code>{`<Carousel>
  <CarouselSlide>
    <img src="..." alt="Slide 1" />
  </CarouselSlide>
  <CarouselSlide>
    <img src="..." alt="Slide 2" />
  </CarouselSlide>
  <CarouselSlide>
    <img src="..." alt="Slide 3" />
  </CarouselSlide>
</Carousel>`}</code></pre>

  <h2>Slide sizes</h2>
  <p>Control how many slides are visible at once with the <code>size</code> prop on each slide.</p>
  <CarouselSizes client:load />
  <pre><code>{`<CarouselSlide size="sm">...</CarouselSlide>  {/* 70% → 45% → 33% */}
<CarouselSlide size="md">...</CarouselSlide>  {/* 85% → 65% → 50% (default) */}
<CarouselSlide size="lg">...</CarouselSlide>  {/* 95% → 80% → 66% */}`}</code></pre>
</ComponentPage>
