---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { BreadcrumbDefault, BreadcrumbCustomSeparator, BreadcrumbTruncated, BreadcrumbShort } from '../../components/BreadcrumbGallery';
---

<ComponentPage
  title="Breadcrumb"
  description="A navigation aid showing the user's location within a site hierarchy. The last item is automatically marked as the current page."
  installCode="import { Breadcrumb } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>items</code>', '<code>BreadcrumbItem[]</code>', '—', 'Ordered list of breadcrumb items'],
        ['<code>separator</code>', '<code>ReactNode</code>', "<code>'›'</code>", 'Separator between items'],
        ['<code>maxItems</code>', '<code>number</code>', '—', 'Max visible items. Middle items collapse to "…"'],
      ],
    },
    {
      name: 'BreadcrumbItem',
      headers: ['Property', 'Type', 'Description'],
      rows: [
        ['<code>label</code>', '<code>string</code>', 'Display text'],
        ['<code>href</code>', '<code>string</code>', 'Optional link URL. Omit for the current page.'],
      ],
    },
  ]}
  accessibility={[
    'Renders as <code>&lt;nav aria-label="Breadcrumb"&gt;</code>',
    'Uses an <code>&lt;ol&gt;</code> for ordered semantic structure',
    'Last item has <code>aria-current="page"</code>',
    'Separators and ellipsis are hidden from screen readers with <code>aria-hidden</code>',
  ]}
>
  <h2>Default</h2>
  <p>Pass an array of items. The last item renders as plain text with a chevron (›) separator.</p>
  <BreadcrumbDefault client:load />
  <pre><code>{`<Breadcrumb
  items={[
    { label: 'Home', href: '/' },
    { label: 'Women', href: '/women' },
    { label: 'Dresses', href: '/women/dresses' },
    { label: 'Midi Dresses' },
  ]}
/>`}</code></pre>

  <h2>Truncated</h2>
  <p>Use <code>maxItems</code> to collapse middle items into an ellipsis. Useful for deep hierarchies on mobile.</p>
  <BreadcrumbTruncated client:load />
  <pre><code>{`<Breadcrumb
  items={[
    { label: 'Home', href: '/' },
    { label: 'Electronics', href: '#' },
    { label: 'Phone Accessories', href: '#' },
    { label: 'Cases & Covers', href: '#' },
    { label: 'Aramid Fiber iPhone 17 Pro Max Case' },
  ]}
  maxItems={3}
/>`}</code></pre>

  <h2>Custom separator</h2>
  <p>Override the default "›" separator with any string or ReactNode.</p>
  <BreadcrumbCustomSeparator client:load />
  <pre><code>{`<Breadcrumb items={[...]} separator="/" />`}</code></pre>

  <h2>Short trail</h2>
  <BreadcrumbShort client:load />
  <pre><code>{`<Breadcrumb
  items={[
    { label: 'Home', href: '/' },
    { label: 'Cart' },
  ]}
/>`}</code></pre>
</ComponentPage>
