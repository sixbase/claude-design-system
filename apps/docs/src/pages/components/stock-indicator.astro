---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { StockIndicatorDefault, StockIndicatorStatuses, StockIndicatorCustomLabel } from '../../components/StockIndicatorGallery';
---

<ComponentPage
  title="Stock Indicator"
  description="Displays inventory status with a colored dot and label. Supports three statuses — in stock, low stock, and out of stock — with a pulsing animation for available items."
  installCode="import { StockIndicator } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>status</code>', "<code>'in-stock' | 'low-stock' | 'out-of-stock'</code>", "<code>'in-stock'</code>", 'Inventory status'],
        ['<code>label</code>', '<code>string</code>', '—', 'Custom label text. Defaults to a label based on status.'],
      ],
    },
  ]}
  accessibility={[
    'Renders as a <code>&lt;p&gt;</code> element for semantic text content',
    'Color is not the sole indicator — text label always accompanies the dot',
    'Pulse animation respects <code>prefers-reduced-motion</code> (inherits from system)',
  ]}
>
  <h2>Default</h2>
  <StockIndicatorDefault client:load />
  <pre><code>{`<StockIndicator />`}</code></pre>

  <h2>Statuses</h2>
  <p>Three built-in statuses with default labels and color-coded dots.</p>
  <StockIndicatorStatuses client:load />
  <pre><code>{`<StockIndicator status="in-stock" />
<StockIndicator status="low-stock" />
<StockIndicator status="out-of-stock" />`}</code></pre>

  <h2>Custom labels</h2>
  <p>Override the default label with the <code>label</code> prop.</p>
  <StockIndicatorCustomLabel client:load />
  <pre><code>{`<StockIndicator status="in-stock" label="Ships in 1–2 days" />
<StockIndicator status="low-stock" label="Only 3 left" />
<StockIndicator status="out-of-stock" label="Back in stock March 20" />`}</code></pre>
</ComponentPage>
