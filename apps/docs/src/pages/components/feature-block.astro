---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { FeatureBlockDefault, FeatureBlockReverse } from '../../components/FeatureBlockGallery';
---

<ComponentPage
  title="Feature Block"
  description="A side-by-side layout pairing an image with marketing text. Stacks vertically on mobile and sits side-by-side on tablet and up. Use <code>reverse</code> to alternate the image position for visual rhythm."
  installCode="import { FeatureBlock } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>title</code>', '<code>string</code>', '—', 'Heading text'],
        ['<code>description</code>', '<code>string</code>', '—', 'Body text'],
        ['<code>image</code>', '<code>ReactNode</code>', '—', 'Image element or custom node'],
        ['<code>reverse</code>', '<code>boolean</code>', '<code>false</code>', 'Swap image/text positions on tablet+'],
      ],
    },
  ]}
  accessibility={[
    'Title renders as an <code>&lt;h2&gt;</code> — adjust heading level via CSS if needed in context',
    'Image content should include appropriate <code>alt</code> text',
    'Content order in the DOM remains image → text regardless of <code>reverse</code>, preserving reading order',
  ]}
>
  <h2>Default</h2>
  <FeatureBlockDefault client:load />
  <pre><code>{`<FeatureBlock
  title="Engineered for Everyday Protection"
  description="Woven from 600D aramid fiber..."
  image={<img src="..." alt="Feature image" />}
/>`}</code></pre>

  <h2>Reversed</h2>
  <p>Swap image and text positions on tablet+ to create alternating layouts.</p>
  <FeatureBlockReverse client:load />
  <pre><code>{`<FeatureBlock
  reverse
  title="Seamless MagSafe Integration"
  description="Precision-aligned magnets..."
  image={<img src="..." alt="Feature image" />}
/>`}</code></pre>
</ComponentPage>
