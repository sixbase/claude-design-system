---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { AccordionDefault, AccordionMultiple, AccordionSizes, AccordionWithCheckbox, AccordionBordered } from '../../components/AccordionGallery';
---

<ComponentPage
  title="Accordion"
  description="A vertically stacked set of collapsible sections. Common for FAQs, product details, and filtering. Built on Radix UI for full keyboard and screen reader support."
  installCode="import { Accordion, AccordionItem, AccordionTrigger, AccordionContent } from '@ds/components';"
  props={[
    {
      name: 'Accordion (root)',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>type</code>', "<code>'single' | 'multiple'</code>", '—', 'Whether one or many items can be open'],
        ['<code>collapsible</code>', '<code>boolean</code>', '<code>false</code>', 'Allow closing all items (single mode only)'],
        ['<code>defaultValue</code>', '<code>string | string[]</code>', '—', 'Initially open item(s)'],
        ['<code>value</code>', '<code>string | string[]</code>', '—', 'Controlled open item(s)'],
        ['<code>onValueChange</code>', '<code>(value) =&gt; void</code>', '—', 'Called when open items change'],
        ['<code>size</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Size variant'],
        ['<code>flush</code>', '<code>boolean</code>', '<code>false</code>', 'Legacy — now a no-op. Inner-only dividers are the default behavior.'],
        ['<code>bordered</code>', '<code>boolean</code>', '<code>false</code>', 'Wraps in a bordered, rounded panel'],
      ],
    },
    {
      name: 'AccordionItem',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>value</code>', '<code>string</code>', '—', 'Unique identifier for this item'],
        ['<code>disabled</code>', '<code>boolean</code>', '<code>false</code>', 'Prevent opening this item'],
      ],
    },
    {
      name: 'AccordionTrigger',
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>checked</code>', "<code>boolean | 'indeterminate'</code>", '—', 'Show a checkbox and control its state'],
        ['<code>onCheckedChange</code>', '<code>(checked) =&gt; void</code>', '—', 'Called when checkbox is toggled'],
        ['<code>checkboxDisabled</code>', '<code>boolean</code>', '<code>false</code>', 'Disable only the checkbox'],
        ['<code>checkboxLabel</code>', '<code>string</code>', '—', 'Accessible label for the checkbox'],
      ],
    },
  ]}
  accessibility={[
    'Keyboard: <kbd>Enter</kbd> / <kbd>Space</kbd> toggle the focused item',
    '<kbd>Arrow Down</kbd> / <kbd>Arrow Up</kbd> move between triggers',
    '<kbd>Home</kbd> / <kbd>End</kbd> jump to first / last trigger',
    'Each trigger has <code>aria-expanded</code> and <code>aria-controls</code>',
    'Content regions have <code>role="region"</code> with <code>aria-labelledby</code>',
    'Checkbox variant: checkbox and trigger are independent — checking doesn\'t expand, expanding doesn\'t check',
  ]}
>
  <h2>Single (collapsible)</h2>
  <p>Only one item open at a time. Set <code>collapsible</code> to allow closing all items.</p>
  <AccordionDefault client:load />
  <pre><code>{`<Accordion type="single" collapsible>
  <AccordionItem value="shipping">
    <AccordionTrigger>Shipping & Delivery</AccordionTrigger>
    <AccordionContent>Free standard shipping…</AccordionContent>
  </AccordionItem>
  <AccordionItem value="returns">
    <AccordionTrigger>Returns & Exchanges</AccordionTrigger>
    <AccordionContent>We accept returns…</AccordionContent>
  </AccordionItem>
</Accordion>`}</code></pre>

  <h2>Multiple</h2>
  <p>Multiple items can be open simultaneously. Use <code>defaultValue</code> to pre-expand items.</p>
  <AccordionMultiple client:load />
  <pre><code>{`<Accordion type="multiple" defaultValue={['features', 'specs']}>
  <AccordionItem value="features">…</AccordionItem>
  <AccordionItem value="specs">…</AccordionItem>
</Accordion>`}</code></pre>

  <h2>Sizes</h2>
  <AccordionSizes client:load />
  <pre><code>{`<Accordion size="sm">…</Accordion>
<Accordion size="md">…</Accordion>  {/* default */}
<Accordion size="lg">…</Accordion>`}</code></pre>

  <h2>Bordered</h2>
  <p>Wraps the accordion in a bordered, rounded panel.</p>
  <AccordionBordered client:load />
  <pre><code>{`<Accordion type="single" collapsible bordered>
  <AccordionItem value="faq-1">
    <AccordionTrigger>Question?</AccordionTrigger>
    <AccordionContent>Answer.</AccordionContent>
  </AccordionItem>
</Accordion>`}</code></pre>

  <h2>With Checkbox</h2>
  <p>
    Add checkboxes to accordion triggers for selection-based patterns like cookie preferences
    or notification settings. The checkbox operates independently from the expand/collapse behavior.
  </p>
  <AccordionWithCheckbox client:load />
  <pre><code>{`<Accordion type="multiple" size="sm" bordered>
  <AccordionItem value="essential">
    <AccordionTrigger
      checked={true}
      checkboxDisabled
      checkboxLabel="Strictly Necessary Cookies"
    >
      Strictly Necessary Cookies
    </AccordionTrigger>
    <AccordionContent>Required for the site to function.</AccordionContent>
  </AccordionItem>
  <AccordionItem value="functional">
    <AccordionTrigger
      checked={checked}
      onCheckedChange={setChecked}
      checkboxLabel="Functional Cookies"
    >
      Functional Cookies
    </AccordionTrigger>
    <AccordionContent>Enable enhanced functionality.</AccordionContent>
  </AccordionItem>
</Accordion>`}</code></pre>
</ComponentPage>
