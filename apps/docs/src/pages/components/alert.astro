---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { AlertVariants, AlertDescriptionOnly, AlertDismissible, AlertEcommerce } from '../../components/AlertGallery';
---

<ComponentPage
  title="Alert"
  description="Persistent informational message within page flow. Use for stock status, shipping notices, payment errors, and promotional banners. Not a toast — alerts stay until dismissed or conditions change."
  installCode="import { Alert } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>variant</code>', "<code>'info' | 'success' | 'warning' | 'destructive'</code>", "<code>'info'</code>", 'Visual style and ARIA role'],
        ['<code>title</code>', '<code>string</code>', '—', 'Optional heading'],
        ['<code>children</code>', '<code>ReactNode</code>', '—', 'Description content'],
        ['<code>dismissible</code>', '<code>boolean</code>', '<code>false</code>', 'Show dismiss button'],
        ['<code>onDismiss</code>', '<code>() =&gt; void</code>', '—', 'Called when dismiss button is clicked'],
        ['<code>icon</code>', '<code>ReactNode</code>', '—', 'Override default variant icon'],
      ],
    },
  ]}
  accessibility={[
    '<code>warning</code> and <code>destructive</code> variants use <code>role="alert"</code> (assertive live region)',
    '<code>info</code> and <code>success</code> variants use <code>role="status"</code> (polite live region)',
    'Dismiss button has <code>aria-label="Dismiss alert"</code>',
    'Icons are <code>aria-hidden="true"</code> — text carries the message',
    'All variant backgrounds use solid primitive tokens for WCAG AA contrast compliance',
  ]}
>
  <h2>Variants</h2>
  <p>Four semantic variants with left border accent, variant icon, and subtle background.</p>
  <AlertVariants client:load />
  <pre><code>{`<Alert variant="info" title="Free shipping">
  Orders over $100 qualify for free standard shipping.
</Alert>
<Alert variant="success" title="Back in stock">
  The Organic Cotton Tee in size M is available again.
</Alert>
<Alert variant="warning" title="Low stock">
  Only 2 left in this size. Order soon to secure yours.
</Alert>
<Alert variant="destructive" title="Payment failed">
  Your card was declined. Please update your payment method.
</Alert>`}</code></pre>

  <h2>Description only</h2>
  <p>Omit <code>title</code> for a compact single-line alert.</p>
  <AlertDescriptionOnly client:load />
  <pre><code>{`<Alert variant="info">Free returns within 30 days of purchase.</Alert>
<Alert variant="success">Item added to your cart.</Alert>`}</code></pre>

  <h2>Dismissible</h2>
  <p>Pass <code>dismissible</code> and <code>onDismiss</code> to allow the user to close the alert. Parent controls unmounting.</p>
  <AlertDismissible client:load />
  <pre><code>{`<Alert variant="warning" title="Limited time offer" dismissible onDismiss={handleDismiss}>
  Use code SAVE20 at checkout for 20% off your order.
</Alert>`}</code></pre>

  <h2>Ecommerce context</h2>
  <p>Alerts for cart feedback, stock status, and return policy notices.</p>
  <AlertEcommerce client:load />
  <pre><code>{`<Alert variant="success">Item added to your cart.</Alert>
<Alert variant="warning" title="Low stock">Only 3 remaining at this price.</Alert>
<Alert variant="destructive" title="Out of stock">
  This item is no longer available in the selected size.
</Alert>
<Alert variant="info" dismissible onDismiss={handleDismiss}>
  Free returns within 30 days of purchase.
</Alert>`}</code></pre>
</ComponentPage>
