---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { DividerDefault, DividerVariants, DividerSpacings, DividerVertical } from '../../components/DividerGallery';
---

<ComponentPage
  title="Divider"
  description="A horizontal or vertical rule that separates content sections. Consistent styling across all usage."
  installCode="import { Divider } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>orientation</code>', "<code>'horizontal' | 'vertical'</code>", "<code>'horizontal'</code>", 'Direction of the divider'],
        ['<code>variant</code>', "<code>'default' | 'subtle'</code>", "<code>'default'</code>", 'Visual style — subtle uses reduced opacity'],
        ['<code>spacing</code>', "<code>'none' | 'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Margin above/below (horizontal) or left/right (vertical)'],
      ],
    },
  ]}
  accessibility={[
    'Horizontal renders as native <code>&lt;hr&gt;</code> with built-in separator semantics',
    'Vertical renders as <code>&lt;div role="separator" aria-orientation="vertical"&gt;</code>',
    'No focus styles needed — dividers are not interactive elements',
  ]}
>
  <h2>Default</h2>
  <p>A simple horizontal rule between content sections.</p>
  <DividerDefault client:load />
  <pre><code>{`<Divider />`}</code></pre>

  <h2>Variants</h2>
  <p>The <code>subtle</code> variant uses reduced opacity for less visual weight.</p>
  <DividerVariants client:load />
  <pre><code>{`<Divider />                    {/* default */}
<Divider variant="subtle" />   {/* reduced opacity */}`}</code></pre>

  <h2>Spacing</h2>
  <p>Control the margin around the divider with the <code>spacing</code> prop.</p>
  <DividerSpacings client:load />
  <pre><code>{`<Divider spacing="none" />   {/* 0px */}
<Divider spacing="sm" />     {/* 8px */}
<Divider spacing="md" />     {/* 16px — default */}
<Divider spacing="lg" />     {/* 32px */}`}</code></pre>

  <h2>Vertical</h2>
  <p>Use <code>orientation="vertical"</code> to separate inline content. The divider stretches to fill its container height.</p>
  <DividerVertical client:load />
  <pre><code>{`<div style={{ display: 'flex', alignItems: 'center' }}>
  <span>Left</span>
  <Divider orientation="vertical" />
  <span>Right</span>
</div>`}</code></pre>
</ComponentPage>
