---
import ComponentPage from '../../layouts/ComponentPage.astro';
import { StarRatingDefault, StarRatingSizes, StarRatingValues, StarRatingWithCount } from '../../components/StarRatingGallery';
---

<ComponentPage
  title="Star Rating"
  description="Displays a visual rating using filled, half-filled, and empty stars. Supports an optional review count and three size variants."
  installCode="import { StarRating } from '@ds/components';"
  props={[
    {
      headers: ['Prop', 'Type', 'Default', 'Description'],
      rows: [
        ['<code>rating</code>', '<code>number</code>', '—', 'Rating value from 0 to 5. Supports halves (e.g. 4.5).'],
        ['<code>reviewCount</code>', '<code>number</code>', '—', 'Total number of reviews displayed next to stars'],
        ['<code>size</code>', "<code>'sm' | 'md' | 'lg'</code>", "<code>'md'</code>", 'Size variant — sm (14px), md (16px), lg (20px)'],
      ],
    },
  ]}
  accessibility={[
    'Container has <code>role="img"</code> with <code>aria-label="4.5 out of 5 stars"</code>',
    'Individual star SVGs are hidden from screen readers with <code>aria-hidden="true"</code>',
    'Review count text is accessible to screen readers',
  ]}
>
  <h2>Default</h2>
  <StarRatingDefault client:load />
  <pre><code>{`<StarRating rating={4.5} reviewCount={128} />`}</code></pre>

  <h2>Sizes</h2>
  <StarRatingSizes client:load />
  <pre><code>{`<StarRating rating={4} reviewCount={42} size="sm" />
<StarRating rating={4} reviewCount={42} size="md" />  {/* default */}
<StarRating rating={4} reviewCount={42} size="lg" />`}</code></pre>

  <h2>Rating values</h2>
  <p>Supports whole and half-star values from 0 to 5. Values are clamped to this range.</p>
  <StarRatingValues client:load />
  <pre><code>{`<StarRating rating={5} />
<StarRating rating={4.5} />
<StarRating rating={3} />
<StarRating rating={1.5} />
<StarRating rating={0} />`}</code></pre>

  <h2>With review count</h2>
  <p>The review count is optional. When provided, it renders next to the stars with automatic singular/plural handling.</p>
  <StarRatingWithCount client:load />
  <pre><code>{`<StarRating rating={4.5} reviewCount={1} />
<StarRating rating={4} reviewCount={128} />
<StarRating rating={3.5} reviewCount={2403} />`}</code></pre>
</ComponentPage>
